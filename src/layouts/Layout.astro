---
import '../styles/global.css';
import ChatbotButton from '../components/ChatbotButton.astro';
import bgBottom1 from '../assets/index/bg_linear_1.png';
import bgBottom2 from '../assets/index/bg_linear_2.png';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>LeapIn - AI 人才智能决策平台</title>
		<script is:inline src="https://cdn.leapin-ai.com/components/@kne-components/leapin-ai-agent-sdk/0.0.7/build/static/js/sdk-main.js"></script>
		<script is:inline>
			// 语言检测 - 只检测并保存到 localStorage，不进行路径跳转
			(function() {
				// 检测是否为英文锁定环境（通过 npm-tools entryHtml 注入的 runtimeEnv）
				var isEnForced = window.runtimeEnv && window.runtimeEnv.locale === 'en';

				// 检测浏览器语言
				function detectLanguage() {
					// 英文锁定环境，直接返回英文
					if (isEnForced) {
						return 'en';
					}

					// 1. 先检查 localStorage
					const savedLang = localStorage.getItem('language');
					if (savedLang === 'zh' || savedLang === 'en') {
						return savedLang;
					}

					// 2. 检查浏览器语言
					const browserLang = navigator.language.toLowerCase();
					
					// 如果是中文相关语言，返回中文
					if (browserLang.startsWith('zh')) {
						return 'zh';
					}
					
					// 如果是英文相关语言，返回英文
					if (browserLang.startsWith('en')) {
						return 'en';
					}

					// 3. 其他语言默认返回中文
					return 'zh';
				}

				// 如果是英文锁定环境，强制设置语言为英文
				if (isEnForced) {
					localStorage.setItem('language', 'en');
				} else if (!localStorage.getItem('language')) {
					// 如果 localStorage 中没有语言设置，则保存检测到的语言
					const detectedLang = detectLanguage();
					localStorage.setItem('language', detectedLang);
				}

				// 设置 html lang 属性
				const currentLang = isEnForced ? 'en' : (localStorage.getItem('language') || 'zh');
				document.documentElement.setAttribute('lang', currentLang);

				// 根据语言设置页面标题
				const titles = {
					zh: 'AI 人才智能决策平台',
					en: 'AI Workforce Intelligence'
				};
				document.title = titles[currentLang] || titles.zh;

				// 如果 URL 中有 /en 路径，重定向到根路径（因为我们已经删除了 /en 目录）
				const currentPath = window.location.pathname;
				if (currentPath.startsWith('/en')) {
					const newPath = currentPath.replace(/^\/en/, '') || '/';
					// 保存英文语言偏好
					localStorage.setItem('language', 'en');
					window.location.href = newPath;
				}
			})();
		</script>
	</head>
	<body>
		<slot />
		<ChatbotButton />
	</body>
</html>

<style define:vars={{
  bgBottom1: `url(${bgBottom1.src})`,
  bgBottom2: `url(${bgBottom2.src})`,
}} is:global>
	:root {
		--color-primary: #0066ff;
		--color-secondary: #00d4ff;
		--color-text: #111827;
		--color-text-light: #666666;
		--color-bg: #ffffff;
		--color-bg-light: #f5f5f5;
		--font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
		--spacing-xs: 0.5rem;
		--spacing-sm: 1rem;
		--spacing-md: 2rem;
		--spacing-lg: 4rem;
		--spacing-xl: 6rem;
		--border-radius: 8px;
		--max-width: 96rem; /* 1536px */
		--AI-Gradient-Neon-Horizon-Heavy: linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%);
		--Neutrals-White-00: #FFF;
		--Neutrals-Dark-40: #6B7280;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	body {
		margin: 0;
		width: 100%;
		min-height: 100vh;
		color: var(--color-text);
		background-color: var(--color-bg);
		line-height: 1.6;
	}

	img {
		max-width: 100%;
		height: auto;
		display: block;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	button {
		cursor: pointer;
		border: none;
		background: none;
	}
	
	.hero-glow {
		position: absolute;
		width: 18.75rem;
		height: 18.75rem;
		aspect-ratio: 1/1;
		border-radius: 18.75rem;
		border: 20px solid #FFF;
		background: linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%);
		box-shadow: 0 0 10px 10px #FFF inset;
		filter: blur(40px);
		opacity: 0.9;
		pointer-events: none;
		z-index: 0;
		transform: translate(-50%, -50%);
		transition: opacity 0.3s ease;
	}

	.hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 4.75rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-bottom-1,
  .hero-bg-bottom-2 {
    position: absolute;
    inset: 0;
    height: 100%;
    background-repeat: no-repeat;
    background-position: center bottom;
    background-size: cover;
  }

  .hero-bg-bottom-1 {
		background-image: var(--bgBottom1);
    animation: bgFadeInOut1 8s ease-in-out infinite;
    z-index: 1;
  }

  .hero-bg-bottom-2 {
	background-image: var(--bgBottom2);
    animation: bgFadeInOut2 8s ease-in-out infinite;
    z-index: 2;
  }

  @keyframes bgFadeInOut1 {
    0% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }

  @keyframes bgFadeInOut2 {
    0% {
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }


  .scroll-container {
    overflow-y: scroll;
    height: 100vh;
	}
  
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 4rem;
	background: none !important;
  }

	.scroll-section {
		min-height: 100vh;
	}

	/* PC 端启用滚动捕捉 */
	@media (min-width: 769px) {
		.scroll-container {
			scroll-snap-type: y mandatory;
		}

		.scroll-section {
			scroll-snap-align: start;
			scroll-snap-stop: always;
		}
	}

	/* 移动端禁用固定高度 */
	@media (max-width: 768px) {
		.scroll-container {
			height: auto;
		}

		.scroll-section {
			min-height: auto;
		}
    
    .container {
      padding: 0 1rem;
    }
	}
</style>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();

	// 检测是否为 PC 端
	const isDesktop = window.innerWidth > 768;

	if (isDesktop) {
		let currentSectionIndex = 0;
		const sections = document.querySelectorAll('.scroll-section');
		const container = document.querySelector('.scroll-container');

		// 滚动控制变量
		let isAnimating = false;
		let scrollAccumulator = 0;
		let lastScrollDirection = 0;
		let animationTimeout: number | null = null;
		let scrollEndTimeout: number | null = null;
		let isInitialized = false; // 页面是否已初始化
		const SCROLL_THRESHOLD = 50;
		const ANIMATION_DURATION = 1000;
		const SCROLL_END_DELAY = 500; // 增加到 500ms，给用户更多时间

		// 全局状态：用于子组件通知父级滚动控制
		(window as any).scrollState = {
			canScrollToNext: true,
			canScrollToPrev: true,
			isInnerScrolling: false
		};

		// 存储每个区域的滚动控制器引用
		const sectionControllers = new Map<number, any>();

		// 注册区域滚动控制器
		(window as any).registerSectionController = (sectionId: string, controller: any) => {
			// 首先尝试直接查找元素
			let sectionElement = document.getElementById(sectionId);
			
			// 如果找不到，尝试查找包含该元素的 scroll-section
			if (sectionElement && !sectionElement.classList.contains('scroll-section')) {
				// 向上查找最近的 scroll-section
				sectionElement = sectionElement.closest('.scroll-section') as HTMLElement;
			}
			
			if (sectionElement) {
				const index = Array.from(sections).indexOf(sectionElement as Element);
				if (index !== -1) {
					sectionControllers.set(index, controller);
	
				} else {
	
				}
			} else {

			}
		};

		// 检查相邻区域并调整它们的 slide 索引
		function adjustAdjacentSections() {
			const viewportHeight = window.innerHeight;
			const viewportCenter = viewportHeight / 2;

			sections.forEach((section, index) => {
				const rect = section.getBoundingClientRect();
				const controller = sectionControllers.get(index);
				
				if (!controller) return;

				const totalSlides = controller.getTotalSlides ? controller.getTotalSlides() : 0;
				if (totalSlides === 0) return;

				// 区域是否在视口中（至少部分可见）
				const isInViewport = rect.top < viewportHeight && rect.bottom > 0;
				
				// 如果区域在视口中，不要调整它的 slide（让用户自己滚动）
				if (isInViewport) return;

				// 区域完全在视口上方（用户已经向下滚动过了这个区域）
				const isCompletelyAbove = rect.bottom <= 0;
				
				// 区域完全在视口下方（用户还未滚动到这个区域）
				const isCompletelyBelow = rect.top >= viewportHeight;

				const currentSlide = controller.getCurrentIndex();

				if (isCompletelyAbove) {
					// 区域在视口上方
					// 只有当前不是最后一个 slide 时才调整
					if (currentSlide !== totalSlides - 1) {
						controller.goToSlide(totalSlides - 1);
					}
				} else if (isCompletelyBelow) {
					// 区域在视口下方
					// 只有当前不是第一个 slide 时才调整
					if (currentSlide !== 0) {
						controller.goToSlide(0);
					}
				}
			});
		}

		// 防抖函数
		function debounce(func: Function, wait: number) {
			let timeout: number;
			return function executedFunction(...args: any[]) {
				const later = () => {
					clearTimeout(timeout);
					func(...args);
				};
				clearTimeout(timeout);
				timeout = window.setTimeout(later, wait);
			};
		}

		// 获取最近的区域索引
		function getClosestSectionIndex(): number {
			const windowHeight = window.innerHeight;
			let closestIndex = 0;
			let minDistance = Infinity;

			sections.forEach((section, index) => {
				const rect = section.getBoundingClientRect();
				const distance = Math.abs(rect.top);
				
				if (distance < minDistance) {
					minDistance = distance;
					closestIndex = index;
				}
			});

			return closestIndex;
		}

		// 滚动到指定区域
		function scrollToSection(index: number, smooth: boolean = true) {
			if (index < 0 || index >= sections.length) return;
			
			currentSectionIndex = index;
			
			sections[index].scrollIntoView({
				behavior: smooth ? 'smooth' : 'auto',
				block: 'start'
			});
			
			// 如果是非平滑滚动（初始化），立即重置动画状态
			if (!smooth) {
				isAnimating = false;
				scrollAccumulator = 0;
			}
		}

		// 处理滚动结束，确保对齐到最近的区域
		function handleScrollEnd() {
			if (scrollEndTimeout) {
				clearTimeout(scrollEndTimeout);
			}

			scrollEndTimeout = window.setTimeout(() => {
				// 如果正在动画中或者子组件正在滚动，不要对齐
				if (isAnimating) return;
				
				const scrollState = (window as any).scrollState;
				if (scrollState && scrollState.isInnerScrolling) return;

				const closestIndex = getClosestSectionIndex();
				
				// 如果当前不在某个区域的顶部，滚动到最近的区域
				if (closestIndex !== currentSectionIndex) {
					currentSectionIndex = closestIndex;
					scrollToSection(closestIndex, true);
				} else {
					// 检查是否完全对齐
					const rect = sections[currentSectionIndex].getBoundingClientRect();
					if (Math.abs(rect.top) > 5) {
						scrollToSection(currentSectionIndex, true);
					}
				}
			}, SCROLL_END_DELAY);
		}

		// 处理滚轮事件
		function handleWheel(e: Event) {
			if (!(e instanceof WheelEvent)) return;
			
			// 如果页面还未初始化完成，忽略滚动
			if (!isInitialized) {
				return;
			}
			
			// 如果正在动画中，完全忽略滚动事件
			if (isAnimating) {
				e.preventDefault();
				e.stopPropagation();
				return;
			}
			
			const scrollState = (window as any).scrollState;
			
			// 如果子组件正在处理内部滚动，不干预
			if (scrollState && scrollState.isInnerScrolling) {
				return;
			}

			const scrollDirection = e.deltaY > 0 ? 1 : -1;

			// 边界检测 - 在开始或结束时允许自然滚动
			const atStart = currentSectionIndex === 0 && scrollDirection < 0;
			const atEnd = currentSectionIndex === sections.length - 1 && scrollDirection > 0;

			if (atStart || atEnd) {
				scrollAccumulator = 0;
				lastScrollDirection = 0;
				return;
			}

			// 检查子组件是否允许滚动
			if (scrollState) {
				if (scrollDirection > 0 && !scrollState.canScrollToNext) {
					return;
				}
				if (scrollDirection < 0 && !scrollState.canScrollToPrev) {
					return;
				}
			}

			e.preventDefault();
			e.stopPropagation();

			// 如果滚动方向改变，重置状态
			if (lastScrollDirection !== 0 && scrollDirection !== lastScrollDirection) {
				scrollAccumulator = 0;
			}

			lastScrollDirection = scrollDirection;

			// 累积滚动量
			scrollAccumulator += Math.abs(e.deltaY);

			// 未达到阈值时不触发滚动
			if (scrollAccumulator < SCROLL_THRESHOLD) {
				return;
			}

			// 达到阈值，执行切换
			scrollAccumulator = 0;
			isAnimating = true;

			const targetIndex = scrollDirection > 0 ? currentSectionIndex + 1 : currentSectionIndex - 1;
			
			// 确保目标索引有效
			if (targetIndex >= 0 && targetIndex < sections.length) {
				scrollToSection(targetIndex);
			} else {
				isAnimating = false;
				return;
			}

			// 设置动画完成后的重置
			if (animationTimeout) {
				clearTimeout(animationTimeout);
			}
			animationTimeout = window.setTimeout(() => {
				isAnimating = false;
				scrollAccumulator = 0;
				lastScrollDirection = 0; // 重置方向
				animationTimeout = null;
			}, ANIMATION_DURATION);
		}

		// 监听滚动位置，更新当前区域索引
		function handleScroll() {
			if (isAnimating) return;

			const windowHeight = window.innerHeight;

			sections.forEach((section, index) => {
				const rect = section.getBoundingClientRect();
				if (rect.top >= -windowHeight / 2 && rect.top < windowHeight / 2) {
					currentSectionIndex = index;
				}
			});

			// 暂时禁用滚动结束对齐，避免跳过区域
			// handleScrollEnd();
		}

		// 使用节流函数来调整相邻区域，避免过于频繁
		let adjustThrottleTimeout: number | null = null;
		function throttledAdjustAdjacentSections() {
			if (adjustThrottleTimeout) return;
			
			adjustThrottleTimeout = window.setTimeout(() => {
				adjustAdjacentSections();
				adjustThrottleTimeout = null;
			}, 300); // 300ms 节流
		}

		const debouncedHandleScroll = debounce(handleScroll, 100);

		// 添加事件监听
		if (container) {
			container.addEventListener('wheel', handleWheel, { passive: false });
			container.addEventListener('scroll', debouncedHandleScroll);
			// 单独监听滚动来调整相邻区域（使用节流）
			container.addEventListener('scroll', throttledAdjustAdjacentSections);
		}

		// 初始化当前区域 - 延迟执行，确保页面完全加载
		setTimeout(() => {
			currentSectionIndex = getClosestSectionIndex();
			scrollToSection(currentSectionIndex, false);
			// 确保初始化后状态正确
			isAnimating = false;
			scrollAccumulator = 0;
			lastScrollDirection = 0;
			isInitialized = true;
		}, 100);

		// 监听窗口大小变化
		window.addEventListener('resize', debounce(() => {
			if (window.innerWidth <= 768) {
				// 切换到移动端时移除事件监听
				if (container) {
					container.removeEventListener('wheel', handleWheel);
					container.removeEventListener('scroll', debouncedHandleScroll);
					container.removeEventListener('scroll', throttledAdjustAdjacentSections);
				}
			}
		}, 250));
	}
</script>
