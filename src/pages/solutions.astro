---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommonHero from '../components/hero/CommonHero.astro';
import CTA from '../components/CTA.astro';
import Section1 from '../components/solutions/Section1.astro';
import Section2 from '../components/solutions/Section2.astro';
---

<Layout>
	<Header />
	
	<main class="solutions-page scroll-container">
		<!-- Hero Section -->
		<section class="scroll-section" data-section="hero">
			<CommonHero pageName="solutions" />
		</section>

		<!-- Talent Sourcing Section - Dark -->
		<section class="scroll-section solution-dark">
			<Section1 />
		</section>

		<section class="scroll-section solution-dark">
			<Section2 />
		</section>

		<!-- Development Section - Light -->
		<section class="scroll-section solutions-cta alt">
			<CTA pageName='solutions' />
		</section>

		<section class="scroll-section footer-section" data-section="footer">
			<Footer />
		</section>
	</main>
	<!-- <section class="scroll-section footer-section">
		<Footer />
	</section> -->
</Layout>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();
</script>

<style>
	.footer-section,
	.solutions-cta {
		min-height: auto;
	}

	.container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* Dark Solution Sections */
	.solution-dark {
		padding: 2rem 0;
		overflow: hidden;
		background: var(--grey-gray-60-base, #111827);
		border: none;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	/* Footer Dark */
	.footer-dark {
		padding: 2rem 0;
		background: #0f172a;
		color: rgba(255, 255, 255, 0.5);
		text-align: center;
	}
</style>
