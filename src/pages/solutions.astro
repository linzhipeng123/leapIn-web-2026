---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommonHero from '../components/hero/CommonHero.astro';
import CTA from '../components/CTA.astro';
import Hire from '../components/solutions/Hire.astro';
import Mobilize from '../components/solutions/Mobilize.astro';
import Develop from '../components/solutions/Develop.astro';
---

<Layout>
	<Header />
	
	<main class="solutions-page scroll-container">
		<!-- Hero Section -->
		<section class="scroll-section" data-section="hero">
			<CommonHero pageName="solutions" />
		</section>

		<!-- Hire Section -->
		<section class="scroll-section solution-dark" data-section="hire">
			<Hire />
		</section>

		<!-- Mobilize Section -->
		<section class="scroll-section solution-dark" data-section="mobilize">
			<Mobilize />
		</section>

		<!-- Develop Section -->
		<section class="scroll-section solution-dark" data-section="develop">
			<Develop />
		</section>

		<!-- CTA Section -->
		<section class="scroll-section solutions-cta alt" data-section="cta">
			<CTA pageName='solutions' />
		</section>

		<!-- Footer Section -->
		<section class="scroll-section footer-section" data-section="footer">
			<Footer />
		</section>
	</main>
</Layout>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();
</script>

<style>
	.footer-section,
	.solutions-cta {
		min-height: auto;
	}

	.container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* Dark Solution Sections */
	.solution-dark {
		padding: 0;
		background: var(--grey-gray-60-base, #111827);
		border: none;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	/* Develop section needs full width */
	.solution-dark[data-section="develop"] {
		padding: 0;
		background: #0F1419;
	}

	/* Footer Dark */
	.footer-dark {
		padding: 2rem 0;
		background: #0f172a;
		color: rgba(255, 255, 255, 0.5);
		text-align: center;
	}
</style>
