---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommonHero from '../components/hero/CommonHero.astro';
import CTA from '../components/CTA.astro';
---

<Layout>
	<Header />
	
	<main class="solutions-page scroll-container">
		<!-- Hero Section -->
		<section class="scroll-section" data-section="hero">
			<CommonHero pageName="solutions" />
		</section>

		<!-- Talent Sourcing Section - Dark -->
		<section class="scroll-section solution-dark">
			<div class="container">
				<div class="solution-content">
					<div class="solution-visual">
						<div class="visual-card">
							<div class="card-grid">
								<div class="profile-card">
									<div class="profile-avatar">👤</div>
									<div class="profile-info">
										<div class="profile-name"></div>
										<div class="profile-role"></div>
									</div>
								</div>
								<div class="profile-card">
									<div class="profile-avatar">👤</div>
									<div class="profile-info">
										<div class="profile-name"></div>
										<div class="profile-role"></div>
									</div>
								</div>
								<div class="profile-card">
									<div class="profile-avatar">👤</div>
									<div class="profile-info">
										<div class="profile-name"></div>
										<div class="profile-role"></div>
									</div>
								</div>
							</div>
						</div>
					</div>
					<div class="solution-text">
						<h2 data-i18n="solutions.talentSourcing.title"></h2>
						<h3 data-i18n="solutions.talentSourcing.subtitle"></h3>
						<p data-i18n="solutions.talentSourcing.description"></p>
						<ul class="feature-list" data-i18n-list="solutions.talentSourcing.features"></ul>
					</div>
				</div>
			</div>
		</section>

		<!-- Talent Assessment Section - Dark -->
		<section class="scroll-section solution-dark">
			<div class="container">
				<div class="solution-content reverse">
					<div class="solution-text">
						<h2 data-i18n="solutions.talentAssessment.title"></h2>
						<h3 data-i18n="solutions.talentAssessment.subtitle"></h3>
						<p data-i18n="solutions.talentAssessment.description"></p>
						<ul class="feature-list" data-i18n-list="solutions.talentAssessment.features"></ul>
					</div>
					<div class="solution-visual">
						<div class="visual-card assessment">
							<div class="assessment-chart">
								<div class="chart-circle">
									<div class="chart-percentage">85%</div>
								</div>
								<div class="chart-label">匹配度</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Onboarding Section - Light -->
		<section class="scroll-section solution-light">
			<div class="container">
				<div class="solution-content-center">
					<h2 data-i18n="solutions.onboarding.title"></h2>
					<h3 data-i18n="solutions.onboarding.subtitle"></h3>
					<p data-i18n="solutions.onboarding.description"></p>
					<button class="btn-primary" data-i18n="solutions.onboarding.button"></button>
				</div>
			</div>
		</section>

		<!-- Development Section - Light -->
		<section class="scroll-section solutions-cta alt">
			<CTA pageName='solutions' />
		</section>

		<section class="scroll-section footer-section" data-section="footer">
			<Footer />
		</section>
	</main>
	<!-- <section class="scroll-section footer-section">
		<Footer />
	</section> -->
</Layout>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();
</script>

<style>
	.footer-section,
	.solutions-cta {
		min-height: auto;
	}

	.container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* Dark Solution Sections */
	.solution-dark {
		padding: 6rem 0;
		background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
		color: white;
	}

	.solution-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.solution-content.reverse {
		direction: rtl;
	}

	.solution-content.reverse > * {
		direction: ltr;
	}

	.solution-visual {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.visual-card {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 16px;
		padding: 2rem;
		width: 100%;
		max-width: 400px;
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.profile-card {
		background: rgba(255, 255, 255, 0.08);
		border-radius: 12px;
		padding: 1rem;
		text-align: center;
	}

	.profile-avatar {
		font-size: 2rem;
		margin-bottom: 0.5rem;
	}

	.profile-info {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.profile-name,
	.profile-role {
		height: 8px;
		background: rgba(255, 255, 255, 0.2);
		border-radius: 4px;
	}

	.profile-role {
		width: 70%;
		margin: 0 auto;
	}

	.visual-card.assessment {
		display: flex;
		justify-content: center;
		align-items: center;
		min-height: 300px;
	}

	.assessment-chart {
		text-align: center;
	}

	.chart-circle {
		width: 150px;
		height: 150px;
		border-radius: 50%;
		border: 8px solid rgba(99, 102, 241, 0.3);
		border-top-color: #6366f1;
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto 1rem;
		animation: rotate 3s linear infinite;
	}

	@keyframes rotate {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	.chart-percentage {
		font-size: 2rem;
		font-weight: 700;
		color: white;
	}

	.chart-label {
		color: rgba(255, 255, 255, 0.7);
		font-size: 1.1rem;
	}

	.solution-text h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.solution-text h3 {
		font-size: 1.5rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		color: white;
	}

	.solution-text p {
		font-size: 1.1rem;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.8);
		margin-bottom: 2rem;
	}

	.feature-list {
		list-style: none;
		padding: 0;
	}

	.feature-list li {
		padding: 0.75rem 0;
		padding-left: 2rem;
		position: relative;
		color: rgba(255, 255, 255, 0.9);
		font-size: 1.05rem;
	}

	.feature-list li::before {
		content: "✓";
		position: absolute;
		left: 0;
		color: #6366f1;
		font-weight: bold;
		font-size: 1.2rem;
	}

	/* Light Solution Sections */
	.solution-light {
	}

	.solution-light.alt {
		background: linear-gradient(135deg, #fef3f2 0%, #fee2e2 100%);
	}

	.solution-content-center {
		text-align: center;
		max-width: 700px;
		margin: 0 auto;
	}

	.solution-content-center h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		color: var(--color-text);
	}

	.solution-content-center h3 {
		font-size: 1.5rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		color: var(--color-text);
	}

	.solution-content-center p {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--color-text-light);
		margin-bottom: 2rem;
	}

	.btn-primary {
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
		color: white;
		padding: 1rem 2rem;
		border-radius: 12px;
		font-size: 1rem;
		font-weight: 600;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 24px rgba(99, 102, 241, 0.3);
	}

	/* Footer Dark */
	.footer-dark {
		padding: 2rem 0;
		background: #0f172a;
		color: rgba(255, 255, 255, 0.5);
		text-align: center;
	}

	@media (max-width: 768px) {
		.hero-title {
			font-size: 2rem;
		}

		.solution-content {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.solution-content.reverse {
			direction: ltr;
		}

		.card-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.solution-text h2 {
			font-size: 1.75rem;
		}

		.solution-content-center h2 {
			font-size: 1.75rem;
		}
	}
</style>
