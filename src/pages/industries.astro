---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommonHero from '../components/hero/CommonHero.astro';
import IndustriesCovered from '../components/industries/IndustriesCovered.astro';
import CTA from '../components/CTA.astro';
---

<Layout>
	<Header />
	
	<main class="industries-page scroll-container">
		<!-- Hero Section -->
		<section class="scroll-section" data-section="hero">
			<CommonHero pageName="industries" />
		</section>

		<!-- Industries Grid -->
		<section class="scroll-section industries-covered" data-section="industries-covered">
			<!-- <div class="industries-grid" data-i18n-array="industries.list" data-i18n-template='<div class="industry-card"><div class="industry-icon">{{icon}}</div><h3>{{title}}</h3><p>{{description}}</p></div>'>
				</div>
			</div> -->
			<IndustriesCovered />
		</section>

		<!-- CTA Section -->
		<section class="scroll-section industries-cta alt">
			<CTA pageName='industries' />
		</section>

		<section class="scroll-section footer-section" data-section="footer">
			<Footer />
		</section>
	</main>
</Layout>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();

	// PC端监听 industries-covered 可见性
	if (typeof window !== 'undefined') {
		const isMobile = () => window.innerWidth <= 768;
		
		if (!isMobile()) {
			const industriesCovered = document.querySelector('.industries-covered');
			const featureSlide = document.querySelector('.feature-slide');

			if (industriesCovered && featureSlide) {
				const observerCallback = (entries: IntersectionObserverEntry[]) => {
					entries.forEach(entry => {
						const currentIndex = parseInt(featureSlide.getAttribute('data-index') || '0');
						
						if (!entry.isIntersecting && currentIndex === 0) {
							// 不在可视区域内，且 data-index 为 0
							featureSlide.setAttribute('class', 'feature-slide feature-slide-pre')
						} else {
							featureSlide.setAttribute('class', 'feature-slide feature-slide-inner')
						}
					});
				};

				const observer = new IntersectionObserver(observerCallback, {
					threshold: 0.1,
					rootMargin: '0px'
				});

				observer.observe(industriesCovered);
			}
		}
	}
</script>

<style>
	.container {
		width: 100%;
	}
	.footer-section,
	.industries-cta {
		min-height: auto;
	}

	.industries-covered {
		padding-top: 4.75rem;
	}

	/* CTA Section */
	.industries-cta {
		background: linear-gradient(135deg, #f8f9ff 0%, #e0e7ff 100%);
	}

	@media (max-width: 768px) {

		.industries-covered {
			padding: 2.625rem 0;
		}
	}
</style>
