---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommonHero from '../components/hero/CommonHero.astro';
import IndustriesCovered from '../components/industries/IndustriesCovered.astro';
import CTA from '../components/CTA.astro';
---

<Layout>
	<Header />
	
	<main class="industries-page scroll-container">
		<!-- Hero Section -->
		<section class="scroll-section" data-section="hero">
			<CommonHero pageName="industries" />
		</section>

		<!-- Industries Grid -->
		<section class="scroll-section industries-covered" data-section="industries-covered">
			<!-- <div class="industries-grid" data-i18n-array="industries.list" data-i18n-template='<div class="industry-card"><div class="industry-icon">{{icon}}</div><h3>{{title}}</h3><p>{{description}}</p></div>'>
				</div>
			</div> -->
			<IndustriesCovered />
		</section>

		<!-- CTA Section -->
		<section class="scroll-section industries-cta alt">
			<CTA pageName='industries' />
		</section>

		<section class="scroll-section footer-section" data-section="footer">
			<Footer />
		</section>
	</main>
</Layout>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();

	// PC端监听 industries-covered 可见性
	if (typeof window !== 'undefined') {
		const isMobile = () => window.innerWidth <= 768;
		
		if (!isMobile()) {
			const industriesCovered = document.querySelector('.industries-covered');
			const featureSlide = document.querySelector('.feature-slide');

			if (industriesCovered && featureSlide) {
				const observerCallback = (entries: IntersectionObserverEntry[]) => {
					entries.forEach(entry => {
						const currentIndex = parseInt(featureSlide.getAttribute('data-index') || '0');
						
				console.log("featureSlide", entry.isIntersecting, currentIndex)
						if (!entry.isIntersecting && currentIndex === 0) {
							// 不在可视区域内，且 data-index 为 0
							featureSlide.setAttribute('class', 'feature-slide feature-slide-pre')
						} else {
							featureSlide.setAttribute('class', 'feature-slide feature-slide-inner')
						}
					});
				};

				const observer = new IntersectionObserver(observerCallback, {
					threshold: 0.1,
					rootMargin: '0px'
				});

				observer.observe(industriesCovered);
			}
		}
	}
</script>

<style>
	.container {
		width: 100%;
	}
	.footer-section,
	.industries-cta {
		min-height: auto;
	}

	.industries-covered {
		padding-top: 4.75rem;
	}

	/* Industries Grid */
	.industries-grid-section {
		padding: 6rem 0;
		background: white;
	}

	.industries-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.industry-card {
		padding: 2.5rem;
		background: white;
		border: 1px solid rgba(0, 0, 0, 0.08);
		border-radius: 16px;
		text-align: center;
		transition: all 0.3s;
	}

	.industry-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
		border-color: rgba(99, 102, 241, 0.3);
	}

	.industry-icon {
		font-size: 3.5rem;
		margin-bottom: 1.5rem;
	}

	.industry-card h3 {
		font-size: 1.5rem;
		font-weight: 600;
		margin-bottom: 1rem;
		color: var(--color-text);
	}

	.industry-card p {
		color: var(--color-text-light);
		line-height: 1.6;
	}

	/* CTA Section */
	.industries-cta {
		background: linear-gradient(135deg, #f8f9ff 0%, #e0e7ff 100%);
	}

	.cta-content {
		text-align: center;
		max-width: 700px;
		margin: 0 auto;
	}

	.cta-content h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: var(--color-text);
	}

	.cta-content p {
		font-size: 1.25rem;
		color: var(--color-text-light);
		margin-bottom: 2rem;
	}

    .cta-btn {
        margin: 0 auto;
    }

	.btn-primary {
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
		color: white;
		padding: 1.25rem 2.5rem;
		border-radius: 12px;
		font-size: 1.1rem;
		font-weight: 600;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 24px rgba(99, 102, 241, 0.3);
	}

	@media (max-width: 768px) {
		.hero-title {
			font-size: 2rem;
		}

		.industries-grid {
			grid-template-columns: 1fr;
		}

		.cta-content h2 {
			font-size: 1.75rem;
		}
	}
</style>
