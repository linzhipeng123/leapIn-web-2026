---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommonHero from '../components/hero/CommonHero.astro';
import IndustriesCovered from '../components/industries/IndustriesCovered.astro';
import CTA from '../components/CTA.astro';
import industriesBg from '../assets/industries/cta-bg.png';
import bgDot from '../assets/bg_dot.png';
---

<Layout>
	<Header />
	
	<main class="industries-page scroll-container">
		<!-- Hero Section -->
		<section class="scroll-section" data-section="hero">
			<CommonHero pageName="industries" />
		</section>

		<!-- Industries Grid -->
		<section class="scroll-section industries-covered" data-section="industries-covered">
			<!-- <div class="industries-grid" data-i18n-array="industries.list" data-i18n-template='<div class="industry-card"><div class="industry-icon">{{icon}}</div><h3>{{title}}</h3><p>{{description}}</p></div>'>
				</div>
			</div> -->
			<IndustriesCovered />
		</section>

		<!-- CTA Section -->
		<section class="scroll-section industries-cta alt" data-section="cta" id="industries-cta">
			<div class="industries-slide" id="industries-slide">
				<h2 class="cta-title" data-i18n={`industries.cta.title`}></h2>
			</div>
			<CTA pageName='industries' />
		</section>

		<section class="scroll-section footer-section" data-section="footer">
			<Footer />
		</section>
	</main>
</Layout>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();

	// PC端监听 industries-covered 可见性
	if (typeof window !== 'undefined') {
		const isMobile = () => window.innerWidth <= 768;
		
		if (!isMobile()) {
			const industriesCovered = document.querySelector('.industries-covered');
			const featureSlide = document.querySelector('.feature-slide');

			if (industriesCovered && featureSlide) {
				const observerCallback = (entries: IntersectionObserverEntry[]) => {
					entries.forEach(entry => {
						const currentIndex = parseInt(featureSlide.getAttribute('data-index') || '0');
						
						if (!entry.isIntersecting && currentIndex === 0) {
							// 不在可视区域内，且 data-index 为 0
							featureSlide.setAttribute('class', 'feature-slide feature-slide-pre')
						} else {
							featureSlide.setAttribute('class', 'feature-slide feature-slide-inner')
						}
					});
				};

				const observer = new IntersectionObserver(observerCallback, {
					threshold: 0.1,
					rootMargin: '0px'
				});

				observer.observe(industriesCovered);
			}
		}
	}
</script>

<style define:vars={{ 
  industriesBg: `url(${industriesBg.src})`,
  bgDot: `url(${bgDot.src})`,
}}>
	.container {
		width: 100%;
	}
	.footer-section,
	.industries-cta {
		min-height: auto;
	}

	.industries-covered {
		padding-top: 4.75rem;
	}

	/* CTA Section */
	.industries-cta {
		position: relative;
	}

    .industries-slide {
        width: 100%;
        height: 100%;
        background: var(--grey-gray-60-base, #111827);
		background-image: var(--industriesBg);
        background-repeat: no-repeat;
        background-position: center;
        background-size: cover;
        display: flex;
        align-items: center;
        justify-content: center;
		transition: all 0.5s ease;
    }

	.industries-slide::before {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		top: 0;
		background-image: var(--bgDot);
		background-repeat: no-repeat;
		background-position: center;
		background-size: cover;
		z-index: 1;
	}

	.industries-cta[active-slider="0"] .industries-slide {
		opacity: 1;
		min-height: 100vh;
	}

	.industries-cta[active-slider="1"] .industries-slide {
		position: absolute;
		opacity: 0;
        min-height: calc(100% - 4.75rem);
	}

	.industries-cta[active-slider="2"] .industries-slide {
		position: absolute;
		opacity: 0;
        min-height: calc(100% - 4.75rem);
	}
    .industries-slide .cta-title {
        color: var(--Neutrals-White-00, #FFF);
        font-weight: 600;
        line-height: 120%; /* 48px */
        font-size: 2.5rem;
    }


	@media (max-width: 768px) {

		.industries-covered {
			padding: 2.625rem 0;
		}
		.industries-slide {
			display: none;
		}
	}
</style>
