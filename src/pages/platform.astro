---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommonHero from '../components/CommonHero.astro';

import PlatformFeatureCard from '../components/PlatformFeatureCard.astro';
---

<Layout>
	<Header />
	
	<main class="platform-page">
		<!-- Hero Section -->
		<CommonHero pageName="platform" />

		<!-- Core Features Section - Dark -->
		<section class="features-dark features-dark-first">
			<div class="container">
				<PlatformFeatureCard type='Acquisition' />
			</div>
		</section>

		<!-- AI Matching Section - Dark -->
		<section class="features-dark">
			<div class="container">
				<PlatformFeatureCard type='Marketplace' />
			</div>
		</section>

		<!-- Global Talent Section - Dark -->
		<section class="features-dark">
			<div class="container">
				<PlatformFeatureCard type='Development' />
			</div>
		</section>

		<!-- Platform Features Section - Light -->
		<section class="platform-features">
			<div class="container">
				<div class="features-content">
					<div class="feature-visual">
						<div class="visual-orb"></div>
						<div class="visual-dots"></div>
					</div>
					<div class="feature-text">
						<h2 data-i18n="platform.platformFeatures.title"></h2>
						<ul class="feature-list" data-i18n-list="platform.platformFeatures.features">
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- Collaboration Section - Light -->
		<section class="platform-features">
			<div class="container">
				<div class="features-content reverse">
					<div class="feature-text">
						<h2>高效协作</h2>
						<p class="feature-description">
							一站式协作平台，支持团队实时沟通，提升工作效率
						</p>
						<ul class="feature-list">
							<li>实时消息通知</li>
							<li>任务管理系统</li>
							<li>文档协作编辑</li>
							<li>视频会议集成</li>
						</ul>
					</div>
					<div class="feature-visual">
						<div class="visual-orb secondary"></div>
						<div class="visual-dots"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- Data Insights Section - Light -->
		<section class="platform-features">
			<div class="container">
				<div class="features-content">
					<div class="feature-visual">
						<div class="visual-orb tertiary"></div>
						<div class="visual-dots"></div>
					</div>
					<div class="feature-text">
						<h2>数据洞察</h2>
						<p class="feature-description">
							实时数据分析和可视化报表，助力科学决策
						</p>
						<ul class="feature-list">
							<li>招聘漏斗分析</li>
							<li>人才画像报告</li>
							<li>市场趋势预测</li>
							<li>ROI效果评估</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="platform-cta">
			<div class="container">
				<div class="cta-content">
					<h2 data-i18n="platform.cta.title"></h2>
					<p data-i18n="platform.cta.subtitle"></p>
					<button class="btn-primary" data-i18n="platform.cta.button"></button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();
</script>

<style>
	.platform-page {
		/* padding-top: 80px; */
	}

	.container {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	/* Dark Feature Sections */
	.features-dark {
		padding: 0 1rem;
		background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
		color: white;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100vh;;
	}

	.feature-block {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
	}

	.feature-title {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.feature-description {
		font-size: 1.1rem;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.8);
	}

	/* Light Feature Sections */
	.platform-features {
		padding: 6rem 0;
		background: white;
	}

	.features-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.features-content.reverse {
		direction: rtl;
	}

	.features-content.reverse > * {
		direction: ltr;
	}

	.feature-visual {
		position: relative;
		aspect-ratio: 1;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.visual-orb {
		width: 300px;
		height: 300px;
		background: radial-gradient(circle, rgba(139, 92, 246, 0.3) 0%, rgba(99, 102, 241, 0.1) 50%, transparent 70%);
		border-radius: 50%;
		filter: blur(40px);
	}

	.visual-orb.secondary {
		background: radial-gradient(circle, rgba(236, 72, 153, 0.3) 0%, rgba(219, 39, 119, 0.1) 50%, transparent 70%);
	}

	.visual-orb.tertiary {
		background: radial-gradient(circle, rgba(59, 130, 246, 0.3) 0%, rgba(37, 99, 235, 0.1) 50%, transparent 70%);
	}

	.visual-dots {
		position: absolute;
		inset: 0;
		background-image: radial-gradient(circle, rgba(99, 102, 241, 0.2) 2px, transparent 2px);
		background-size: 30px 30px;
		opacity: 0.3;
	}

	.feature-text h2 {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		color: var(--color-text);
	}

	.feature-text p {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--color-text-light);
		margin-bottom: 2rem;
	}

	.feature-list {
		list-style: none;
		padding: 0;
	}

	.feature-list li {
		padding: 0.75rem 0;
		padding-left: 2rem;
		position: relative;
		color: var(--color-text);
		font-size: 1.05rem;
	}

	.feature-list li::before {
		content: "✓";
		position: absolute;
		left: 0;
		color: #6366f1;
		font-weight: bold;
		font-size: 1.2rem;
	}

	/* CTA Section */
	.platform-cta {
		padding: 6rem 0;
		background: linear-gradient(135deg, #f8f9ff 0%, #e0e7ff 100%);
	}

	.cta-content {
		text-align: center;
		max-width: 700px;
		margin: 0 auto;
	}

	.cta-content h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: var(--color-text);
	}

	.cta-content p {
		font-size: 1.25rem;
		color: var(--color-text-light);
		margin-bottom: 2rem;
	}

	.btn-primary {
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
		color: white;
		padding: 1.25rem 2.5rem;
		border-radius: 12px;
		font-size: 1.1rem;
		font-weight: 600;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 24px rgba(99, 102, 241, 0.3);
	}

	/* Footer Dark */
	.footer-dark {
		padding: 2rem 0;
		background: #0f172a;
		color: rgba(255, 255, 255, 0.5);
		text-align: center;
	}

	@media (max-width: 768px) {
		.feature-title {
			font-size: 1.75rem;
		}

		.features-content {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.features-content.reverse {
			direction: ltr;
		}

		.cta-content h2 {
			font-size: 1.75rem;
		}
	}
</style>
