---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommonHero from '../components/hero/CommonHero.astro';
import bgDot from '../assets/index/product/bg_dot.png';

import PlatformFeature from '../components/platform/PlatformFeature.astro';
import AppliedAIAgents from '../components/platform/AppliedAIAgents.astro';
import CTA from '../components/CTA.astro';
---

<Layout>
	<Header />
	
	<main class="platform-page scroll-container">
		<section class="scroll-section" data-section="hero">
			<CommonHero pageName="platform" />
		</section>
		<!-- <h2 class="card-title" data-i18n="platform.coreFeatures.title"></h2> -->
		<!-- Hero Section -->
		<section class="scroll-section features-dark" data-section="features">
			<div class="container">
				<PlatformFeature />
			</div>
		</section>

		<!-- Collaboration Section - Light -->
		<section class="scroll-section platform-features" data-section="agents">
			<AppliedAIAgents />
		</section>


		<!-- CTA Section -->
		<section class="scroll-section platform-cta" data-section="cta">
			<CTA pageName='platform' />
		</section>
		<section class="scroll-section footer-section" data-section="footer">
			<Footer />
		</section>

	</main>
	<!-- <section class="footer-section">
		<Footer />
	</section> -->
</Layout>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();
</script>

<style define:vars={{ 
	bgDot: `url(${bgDot.src})`,
}}>
	.platform-page {
		/* padding-top: 80px; */
	}
	.footer-section,
	.platform-cta {
		min-height: auto;
	}

	.container {
		max-width: var(--max-width);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.card-title {
		position: absolute;
		top: 60vh;
		width: 100%;
		color: var(--grey-gray-60-base, #111827);
		text-align: center;
		font-size: 2.25rem;
		font-weight: 600;
		line-height: 120%; /* 43.2px */
		letter-spacing: -0.396px;
	}

	/* Dark Feature Sections */
	.features-dark {
		padding: 0 1rem;
		background: var(--grey-gray-60-base, #111827);
		color: white;
		min-height: 100vh;
		position: relative;
	}

	.features-dark::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: var(--bgDot);
	}

	.features-dark:nth-of-type(2) .platform-feature-card {
		transform: rotate(-45deg);
		transition: transform 0.6s ease-out;
	}

	.features-dark:nth-of-type(3) .platform-feature-card {
		transform: rotate(45deg);
		transition: transform 0.6s ease-out;
	}

	.features-dark:nth-of-type(4) .platform-feature-card {
		transform: rotate(-45deg);
		transition: transform 0.6s ease-out;
	}

	.features-dark:nth-of-type(2) .platform-feature-card.scrolled,
	.features-dark:nth-of-type(3) .platform-feature-card.scrolled,
	.features-dark:nth-of-type(4) .platform-feature-card.scrolled {
		transform: rotate(0deg);
	}

	.feature-block {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
	}

	.feature-title {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.feature-description {
		font-size: 1.1rem;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.8);
	}

	/* Light Feature Sections */
	.platform-features {
		min-height: 100vh;
	}

	.features-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.features-content.reverse {
		direction: rtl;
	}

	.features-content.reverse > * {
		direction: ltr;
	}

	.feature-visual {
		position: relative;
		aspect-ratio: 1;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.visual-orb {
		width: 300px;
		height: 300px;
		background: radial-gradient(circle, rgba(139, 92, 246, 0.3) 0%, rgba(99, 102, 241, 0.1) 50%, transparent 70%);
		border-radius: 50%;
		filter: blur(40px);
	}

	.visual-orb.secondary {
		background: radial-gradient(circle, rgba(236, 72, 153, 0.3) 0%, rgba(219, 39, 119, 0.1) 50%, transparent 70%);
	}

	.visual-orb.tertiary {
		background: radial-gradient(circle, rgba(59, 130, 246, 0.3) 0%, rgba(37, 99, 235, 0.1) 50%, transparent 70%);
	}

	.visual-dots {
		position: absolute;
		inset: 0;
		background-image: radial-gradient(circle, rgba(99, 102, 241, 0.2) 2px, transparent 2px);
		background-size: 30px 30px;
		opacity: 0.3;
	}

	.feature-text h2 {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		color: var(--color-text);
	}

	.feature-text p {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--color-text-light);
		margin-bottom: 2rem;
	}

	.feature-list {
		list-style: none;
		padding: 0;
	}

	.feature-list li {
		padding: 0.75rem 0;
		padding-left: 2rem;
		position: relative;
		color: var(--color-text);
		font-size: 1.05rem;
	}

	.feature-list li::before {
		content: "✓";
		position: absolute;
		left: 0;
		color: #6366f1;
		font-weight: bold;
		font-size: 1.2rem;
	}

	/* CTA Section */
	.platform-cta {
	}

	.platform-cta::before {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		top: 0;
		background: var(--AI-Gradient-Sky-Aurora-Medium, linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%));
		filter: blur(18.149999618530273px);
		z-index: -1;
	}

	.cta-content {
		text-align: center;
		max-width: 700px;
		margin: 0 auto;
	}

	.cta-content h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: var(--color-text);
	}

	.cta-content p {
		font-size: 1.25rem;
		color: var(--color-text-light);
		margin-bottom: 2rem;
	}

	.btn-primary {
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
		color: white;
		padding: 1.25rem 2.5rem;
		border-radius: 12px;
		font-size: 1.1rem;
		font-weight: 600;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 24px rgba(99, 102, 241, 0.3);
	}

	/* Footer Dark */
	.footer-dark {
		padding: 2rem 0;
		background: #0f172a;
		color: rgba(255, 255, 255, 0.5);
		text-align: center;
	}

	@media (max-width: 768px) {
		.feature-title {
			font-size: 1.75rem;
		}

		.features-content {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.features-content.reverse {
			direction: ltr;
		}

		.cta-content h2 {
			font-size: 1.75rem;
		}

		.container {
		padding: 2.25rem 0 !important;
		}
	}
</style>
