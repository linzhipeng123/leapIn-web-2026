---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommonHero from '../components/hero/CommonHero.astro';
---

<Layout>
	<Header />
	
	<main class="about-page">
		<!-- Hero Section -->
		<CommonHero pageName="about" />

		<!-- Our Story Section - Dark -->
		<section class="story-section dark">
			<div class="container">
				<div class="section-content">
					<h2 class="section-title" data-i18n="about.ourStory.title"></h2>
					<h3 class="section-subtitle" data-i18n="about.ourStory.subtitle"></h3>
					<p class="section-text" data-i18n="about.ourStory.description"></p>
				</div>
			</div>
		</section>

		<!-- Our Mission Section - Dark -->
		<section class="story-section dark">
			<div class="container">
				<div class="section-content">
					<h2 class="section-title" data-i18n="about.ourMission.title"></h2>
					<h3 class="section-subtitle" data-i18n="about.ourMission.subtitle"></h3>
					<p class="section-text" data-i18n="about.ourMission.description"></p>
				</div>
			</div>
		</section>

		<!-- Our Values Section - Dark -->
		<section class="story-section dark">
			<div class="container">
				<div class="section-content">
					<h2 class="section-title" data-i18n="about.ourValues.title"></h2>
					<h3 class="section-subtitle" data-i18n="about.ourValues.subtitle"></h3>
					<p class="section-text" data-i18n="about.ourValues.description"></p>
					<button class="btn-primary" data-i18n="about.ourValues.button"></button>
				</div>
			</div>
		</section>

		<!-- Team Section - Dark with Background -->
		<section class="team-section dark">
			<div class="container">
				<div class="section-content">
					<h2 class="section-title" data-i18n="about.ourTeam.title"></h2>
					<h3 class="section-subtitle" data-i18n="about.ourTeam.subtitle"></h3>
					<p class="section-text" data-i18n="about.ourTeam.description"></p>
					<div class="team-visual">
						<div class="visual-line"></div>
						<div class="visual-dots-pattern"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- Gallery Section - Light -->
		<section class="gallery-section">
			<div class="container">
				<div class="gallery-grid">
					<div class="gallery-item large">
						<div class="gallery-placeholder">
							<span class="gallery-icon">🏢</span>
						</div>
					</div>
					<div class="gallery-item">
						<div class="gallery-placeholder">
							<span class="gallery-icon">👥</span>
						</div>
					</div>
					<div class="gallery-item">
						<div class="gallery-placeholder">
							<span class="gallery-icon">💼</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- More Gallery Section - Light -->
		<section class="gallery-section alt">
			<div class="container">
				<div class="gallery-grid reverse">
					<div class="gallery-item">
						<div class="gallery-placeholder">
							<span class="gallery-icon">🌍</span>
						</div>
					</div>
					<div class="gallery-item">
						<div class="gallery-placeholder">
							<span class="gallery-icon">🤝</span>
						</div>
					</div>
					<div class="gallery-item large">
						<div class="gallery-placeholder">
							<span class="gallery-icon">🎯</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Join Us Section - Light -->
		<section class="join-section">
			<div class="container">
				<div class="join-content">
					<div class="join-image">
						<div class="image-placeholder">
							<span class="image-icon">🚀</span>
						</div>
					</div>
					<div class="join-text">
						<h2 data-i18n="about.joinUs.title"></h2>
						<h3 data-i18n="about.joinUs.subtitle"></h3>
						<p data-i18n="about.joinUs.description"></p>
						<ul class="join-list" data-i18n-list="about.joinUs.features"></ul>
						<button class="btn-primary" data-i18n="about.joinUs.button"></button>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();
</script>

<style>
	.container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* Story Sections - Dark */
	.story-section.dark {
		padding: 5rem 0;
		background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
		color: white;
	}

	.section-content {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
	}

	.section-title {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.section-subtitle {
		font-size: 1.5rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		color: white;
	}

	.section-text {
		font-size: 1.1rem;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.8);
		margin-bottom: 2rem;
	}

	/* Team Section */
	.team-section.dark {
		padding: 5rem 0;
		background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
		color: white;
		position: relative;
		overflow: hidden;
	}

	.team-visual {
		position: relative;
		height: 200px;
		margin-top: 3rem;
	}

	.visual-line {
		position: absolute;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 300px;
		height: 2px;
		background: linear-gradient(90deg, transparent, #6366f1, transparent);
	}

	.visual-dots-pattern {
		position: absolute;
		inset: 0;
		background-image: radial-gradient(circle, rgba(99, 102, 241, 0.3) 2px, transparent 2px);
		background-size: 30px 30px;
		opacity: 0.3;
	}

	/* Gallery Sections */
	.gallery-section {
		padding: 4rem 0;
		background: white;
	}

	.gallery-section.alt {
		background: var(--color-bg-light);
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 1.5rem;
	}

	.gallery-grid.reverse {
		grid-template-columns: 1fr 1fr 2fr;
	}

	.gallery-item {
		aspect-ratio: 1;
	}

	.gallery-item.large {
		aspect-ratio: 2/1;
	}

	.gallery-placeholder {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 2px solid rgba(99, 102, 241, 0.2);
	}

	.gallery-icon {
		font-size: 4rem;
	}

	/* Join Section */
	.join-section {
		padding: 6rem 0;
		background: linear-gradient(135deg, #f8f9ff 0%, #e0e7ff 100%);
	}

	.join-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.join-image {
		aspect-ratio: 4/3;
	}

	.image-placeholder {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(139, 92, 246, 0.15) 100%);
		border-radius: 24px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 2px solid rgba(99, 102, 241, 0.2);
	}

	.image-icon {
		font-size: 6rem;
	}

	.join-text h2 {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		color: var(--color-text);
	}

	.join-text h3 {
		font-size: 1.5rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		color: var(--color-text);
	}

	.join-text p {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--color-text-light);
		margin-bottom: 2rem;
	}

	.join-list {
		list-style: none;
		padding: 0;
		margin-bottom: 2rem;
	}

	.join-list li {
		padding: 0.75rem 0;
		padding-left: 2rem;
		position: relative;
		color: var(--color-text);
		font-size: 1.05rem;
	}

	.join-list li::before {
		content: "✓";
		position: absolute;
		left: 0;
		color: #6366f1;
		font-weight: bold;
		font-size: 1.2rem;
	}

	.btn-primary {
		background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
		color: white;
		padding: 1rem 2rem;
		border-radius: 12px;
		font-size: 1rem;
		font-weight: 600;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 24px rgba(99, 102, 241, 0.3);
	}

	/* Footer Dark */
	.footer-dark {
		padding: 2rem 0;
		background: #0f172a;
		color: rgba(255, 255, 255, 0.5);
		text-align: center;
	}

	@media (max-width: 768px) {
		.hero-title {
			font-size: 2rem;
		}

		.section-title {
			font-size: 1.75rem;
		}

		.gallery-grid,
		.gallery-grid.reverse {
			grid-template-columns: 1fr;
		}

		.join-content {
			grid-template-columns: 1fr;
		}

		.join-text h2 {
			font-size: 1.75rem;
		}
	}
</style>
