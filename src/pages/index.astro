---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Partners from '../components/Partners.astro';
import Features from '../components/Features.astro';
import ProductShowcase from '../components/ProductShowcase.astro';
import Stats from '../components/Stats.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<Header />
	<main class="scroll-container">
		<section class="scroll-section" data-section="hero">
			<Hero />
		</section>
		<section class="scroll-section partners-section" data-section="partners">
			<Partners />
		</section>
		<section class="scroll-section" data-section="features">
			<Features />
		</section>
		<section class="scroll-section" data-section="showcase">
			<ProductShowcase />
		</section>
		<section class="scroll-section" data-section="stats">
			<Stats />
		</section>
		<section class="scroll-section" data-section="cta">
			<CTA />
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.scroll-container {
		overflow-y: scroll;
		height: 100vh;
	}

	.scroll-section {
		min-height: 100vh;
	}

	.partners-section {
		min-height: auto;
	}

	/* PC 端启用滚动捕捉 */
	@media (min-width: 769px) {
		.scroll-container {
			scroll-snap-type: y mandatory;
		}

		.scroll-section {
			scroll-snap-align: start;
			scroll-snap-stop: always;
		}

		/* 除了 hero 外，其他区域需要留出 header 高度 */
		.scroll-section:not([data-section="hero"]) {
			scroll-margin-top: 4.75rem;
		}
	}

	/* 移动端禁用固定高度 */
	@media (max-width: 768px) {
		.scroll-container {
			height: auto;
		}

		.scroll-section {
			min-height: auto;
		}
	}
</style>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();

	// 检测是否为 PC 端
	const isDesktop = window.innerWidth > 768;

	if (isDesktop) {
		let isScrolling = false;
		let currentSectionIndex = 0;
		const sections = document.querySelectorAll('.scroll-section');
		const container = document.querySelector('.scroll-container');

		// 防抖函数
		function debounce(func: Function, wait: number) {
			let timeout: number;
			return function executedFunction(...args: any[]) {
				const later = () => {
					clearTimeout(timeout);
					func(...args);
				};
				clearTimeout(timeout);
				timeout = window.setTimeout(later, wait);
			};
		}

		// 滚动到指定区域
		function scrollToSection(index: number) {
			if (index < 0 || index >= sections.length) return;
			
			isScrolling = true;
			currentSectionIndex = index;
			
			sections[index].scrollIntoView({
				behavior: 'smooth',
				block: 'start'
			});

			// 滚动完成后重置标志
			setTimeout(() => {
				isScrolling = false;
			}, 1000);
		}

		// 处理滚轮事件
		function handleWheel(e: Event) {
			if (!(e instanceof WheelEvent)) return;
			
			if (isScrolling) {
				e.preventDefault();
				return;
			}

			// 判断滚动方向
			if (e.deltaY > 0) {
				// 向下滚动
				if (currentSectionIndex < sections.length - 1) {
					e.preventDefault();
					scrollToSection(currentSectionIndex + 1);
				}
			} else if (e.deltaY < 0) {
				// 向上滚动
				if (currentSectionIndex > 0) {
					e.preventDefault();
					scrollToSection(currentSectionIndex - 1);
				}
			}
		}

		// 监听滚动位置，更新当前区域索引
		const updateCurrentSection = debounce(() => {
			if (isScrolling) return;

			const scrollPosition = container?.scrollTop || 0;
			const windowHeight = window.innerHeight;

			sections.forEach((section, index) => {
				const rect = section.getBoundingClientRect();
				if (rect.top >= -windowHeight / 2 && rect.top < windowHeight / 2) {
					currentSectionIndex = index;
				}
			});
		}, 100);

		// 添加事件监听
		if (container) {
			container.addEventListener('wheel', handleWheel, { passive: false });
			container.addEventListener('scroll', updateCurrentSection);
		}

		// 初始化当前区域
		updateCurrentSection();

		// 监听窗口大小变化
		window.addEventListener('resize', debounce(() => {
			if (window.innerWidth <= 768) {
				// 切换到移动端时移除事件监听
				if (container) {
					container.removeEventListener('wheel', handleWheel);
					container.removeEventListener('scroll', updateCurrentSection);
				}
			}
		}, 250));
	}
</script>
