---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ChatbotButton from '../components/ChatbotButton.astro';
import CountryCodeSelect from '../components/CountryCodeSelect.astro';

import { pxToRem } from '../utils';

import logo1 from '../assets/index/partner/logo1.png';
import logo2 from '../assets/index/partner/logo2.png';
import logo3 from '../assets/index/partner/logo3.png';
import logo4 from '../assets/index/partner/logo4.png';
import logo5 from '../assets/index/partner/logo5.png';
import logo6 from '../assets/index/partner/logo6.png';
import logo7 from '../assets/index/partner/logo7.png';
import logo8 from '../assets/index/partner/logo8.png';
import logo9 from '../assets/index/partner/logo9.png';

const logos = [
  { src: logo1, width: 77.25 },
  { src: logo2, width: 63.75 },
  { src: logo3, width: 120 },
  { src: logo6, width: 135 },
  { src: logo4, width: 102.75 },
  { src: logo5, width: 63 },
  { src: logo8, width: 69.75 },
  { src: logo9, width: 153 },
  { src: logo7, width: 58.5 },
];
---

<Layout>
	<Header />
	
	<main class="request-page">
		<section class="request-hero hero">
            <div class="hero-bg">
                <div class="hero-bg-bottom-1"></div>
                <div class="hero-bg-bottom-2"></div>
            </div>
        </section>

		<section class="request-content">
			<div class="container">
				<div class="request-left">
                    <h1 class="request-title pc" data-i18n="request.title"></h1>
                    <div class="request-logos">
                        {logos.map(({ src, width }, index) => (
                            <div class="partner-item">
                                <img 
                                    src={src.src} 
                                    alt={`Partner ${index + 1}`}
                                    style={`width: ${pxToRem(width)};`}
                                />
                            </div>
                        ))}
                    </div>
                </div>
                <div class="request-right-wrap">
                    <h1 class="request-title mobile" data-i18n="request.title"></h1>
                    <div class="request-right">
                        <h3 class="request-form-title" data-i18n="request.form.title">预约免费演示</h3>
                        <form class="request-form" id="requestForm">
                            <div class="form-group">
                                <label for="name">
                                    <span data-i18n="request.form.name">姓名</span>
                                    <span class="required">*</span>
                                </label>
                                <input type="text" id="name" name="name" required />
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label for="email">
                                        <span data-i18n="request.form.email">工作邮箱</span>
                                        <span class="required">*</span>
                                    </label>
                                    <input type="email" id="email" name="email" required />
                                </div>

                                <div class="form-group">
                                    <label for="phone">
                                        <span data-i18n="request.form.phone">电话</span>
                                        <span class="required">*</span>
                                    </label>
                                    <div class="phone-input">
                                        <CountryCodeSelect />
                                        <input type="tel" id="phone" name="phone" required />
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="company">
                                    <span data-i18n="request.form.company">公司</span>
                                    <span class="required">*</span>
                                </label>
                                <input type="text" id="company" name="company" required />
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label for="position">
                                        <span data-i18n="request.form.position">职位</span>
                                        <span class="required">*</span>
                                    </label>
                                    <input type="text" id="position" name="position" required />
                                </div>

                                <div class="form-group">
                                    <label for="companySize">
                                        <span data-i18n="request.form.companySize">公司规模</span>
                                        <span class="required">*</span>
                                    </label>
                                    <select id="companySize" name="companySize" required>
                                        <option value="" data-i18n="request.form.pleaseSelect">请选择</option>
                                        <option value="1-10" data-i18n="request.form.size1">1-10人</option>
                                        <option value="10-50" data-i18n="request.form.size1">10-50人</option>
                                        <option value="50-100" data-i18n="request.form.size2">50-100人</option>
                                        <option value="100-500" data-i18n="request.form.size3">100-500人</option>
                                        <option value="500+" data-i18n="request.form.size4">500+人</option>
                                    </select>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="message">
                                    <span data-i18n="request.form.message">留言</span>
                                    <span class="required">*</span>
                                </label>
                                <textarea id="message" name="message" rows="4" required></textarea>
                            </div>

                            <button type="submit" class="btn-submit" data-i18n="request.form.submit">提交信息</button>
                            <div class="form-message" id="formMessage"></div>
                        </form>
                    </div>
                </div>
			</div>
		</section>
	</main>

	<ChatbotButton />
</Layout>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();

	// 表单提交处理
	const form = document.getElementById('requestForm') as HTMLFormElement;
	const formMessage = document.getElementById('formMessage') as HTMLDivElement;
	const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

	// API 端点 - 待定
	const API_ENDPOINT = '/api/request-demo';

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();

		if (!form || !submitButton || !formMessage) return;

		submitButton.disabled = true;
		submitButton.textContent = '提交中...';

		const formData = new FormData(form);
		const data = {
			name: formData.get('name'),
			email: formData.get('email'),
			phone: `${formData.get('countryCode')}${formData.get('phone')}`,
			company: formData.get('company'),
			position: formData.get('position'),
			companySize: formData.get('companySize'),
			message: formData.get('message'),
			timestamp: new Date().toISOString(),
		};

		try {
			const response = await fetch(API_ENDPOINT, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify(data),
			});

			if (response.ok) {
				formMessage.className = 'form-message success';
				formMessage.textContent = '提交成功！我们会尽快与您联系。';
				form.reset();
			} else {
				throw new Error('提交失败');
			}
		} catch (error) {
			formMessage.className = 'form-message error';
			formMessage.textContent = '提交失败，请稍后重试或联系我们。';
			console.error('Form submission error:', error);
		} finally {
			submitButton.disabled = false;
			submitButton.textContent = '提交信息';

			setTimeout(() => {
				formMessage.style.display = 'none';
			}, 5000);
		}
	});
</script>

<style>
	.request-page {
		min-height: 100vh;
        box-sizing: border-box;
	}

	.container {
		max-width: 66.75rem;
        height: 100%;
		margin: 0 auto;
		padding: 0 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
	}

    .request-hero {
        padding-top: 0 !important;
        position: absolute;
        width: 100%;
    }

    .request-left {
        width: 24rem;
    }

	.request-content {
		padding: 6.625rem 0 0;
        position: relative;
        width: 100%;
        height: 100%;
        left: 0;
        top: 0;
	}
    
    .request-title {
        font-size: 3.125rem;
        font-weight: 600;
        line-height: 120%;
        background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: flex;
        align-items: center;
        margin-bottom: 3.75rem;
        white-space: pre-wrap;
    }

    .request-logos {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 2.5rem;
        justify-content: space-between;
    }

    .mobile {
        display: none;
    }

    .request-right-wrap {
        z-index: 1;
    }
    .request-right {
        display: flex;
        width: 31.25rem;
        padding: 1.5rem 2rem;
        flex-direction: column;
        justify-content: flex-start;
        align-items: flex-start;
        gap: 1.5rem;
        border-radius: 0.75rem;
        border: 1px solid var(--Neutrals-White-00, #FFF);
        background: linear-gradient(149deg, rgba(255, 255, 255, 0.80) 0%, rgba(255, 255, 255, 0.05) 100%);
        backdrop-filter: blur(7.5px);
    }

    .request-form-title {
        color: var(--grey-gray-60-base, #111827);
        font-feature-settings: 'liga' off, 'clig' off;
        font-family: "PingFang SC";
        font-size: 1.5rem;
        font-style: normal;
        font-weight: 600;
        line-height: 24px; /* 100% */
        letter-spacing: 0.15px;
        text-transform: capitalize;
        text-align: center;
        width: 100%;
    }

    .request-form {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
    }

    .form-row {
        display: flex;
        gap: 1rem;
    }

    .form-group label {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-text);
        display: flex;
        align-items: center;
        gap: 0.25rem;
        line-height: 150%;
    }

    .required {
        color: #ef4444;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 0.5rem;
        font-size: 0.875rem;
        background: white;
        transition: all 0.2s;
        box-sizing: border-box;
        flex: 1;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }

    .phone-input {
        display: flex;
        gap: 0.5rem;
        align-items: stretch;
    }

    .phone-input input {
        flex: 1;
    }

    .form-group textarea {
        resize: vertical;
        min-height: 4rem;
        font-family: inherit;
    }

    .btn-submit {
        width: 100%;
        padding: 0.875rem 1.5rem;
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        color: white;
        border: none;
        border-radius: 0.5rem;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(99, 102, 241, 0.3);
    }

    .btn-submit:active {
        transform: translateY(0);
    }

    .btn-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    .form-message {
        text-align: center;
        padding: 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        display: none;
    }

    .form-message.success {
        display: block;
        background: #dcfce7;
        color: #166534;
        border: 1px solid #86efac;
    }

    .form-message.error {
        display: block;
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
    }

	@media (max-width: 768px) {
        .container {
            gap: 1rem;
            padding: 1rem;
            flex-direction: column-reverse;
        }

        .request-content {
            /* padding: 3rem 0; */
        }


        .request-right-wrap {
            width: 100%;
        }

        .request-title {
            font-size: 2rem;
            line-height: 100%;
            margin-bottom: 2.5rem;
        }

        .hero-bg {
            height: 22rem;
        }

        .hero-bg-bottom-1 {
            height: 22rem;
            background: linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%);
            filter: blur(50px);
            animation: none;
        }

        .hero-bg-bottom-2 {
            display: none;
        }

        .request-left {
            font-size: 2rem;
            max-width: 25rem;
        }

        .request-logos {
            width: 100%;
            gap: 1.5rem;
        }

        .pc {
            display: none;
        }

        .mobile {
            display: block;
        }

        .request-right {
            width: 100%;
            max-width: 100%;
            padding: 1.5rem 1rem;
        }
        
        .request-form-title {
            font-size: 1.25rem;
        }

        .form-row {
            flex-direction: column;
        }

        .phone-input select {
            width: 4rem;
        }
	}
</style>
