<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  loadTranslations();

  // 切换预览图片语言
  const currentLang = localStorage.getItem('language') || 'en';
  const previewImg = document.getElementById('featuresPreviewImg') as HTMLImageElement;
  const sources = document.querySelectorAll('.features-preview picture source');
  
  if (previewImg) {
    const enSrc = previewImg.getAttribute('data-en-src');
    const cnSrc = previewImg.getAttribute('data-cn-src');
    if (currentLang === 'zh' && cnSrc) {
      previewImg.setAttribute('src', cnSrc);
    } else if (enSrc) {
      previewImg.setAttribute('src', enSrc);
    }
  }

  sources.forEach((source) => {
    const enSrcset = source.getAttribute('data-en-srcset');
    const cnSrcset = source.getAttribute('data-cn-srcset');
    if (currentLang === 'zh' && cnSrcset) {
      source.setAttribute('srcset', cnSrcset);
    } else if (enSrcset) {
      source.setAttribute('srcset', enSrcset);
    }
  });

  // Intersection Observer 监听 features 是否在可视区域内
  if (typeof window !== 'undefined') {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const element = entry.target as HTMLElement;
          if (entry.isIntersecting) {
            // 进入可视区域，添加 in-view 类，触发对齐动画
            element.classList.add('in-view');
          } else {
            // 离开可视区域，移除 in-view 类，恢复错位状态
            element.classList.remove('in-view');
          }
        });
      },
      {
        threshold: 0.2, // 当 20% 的元素可见时触发
      }
    );

    const featuresLayout = document.getElementById('features-layout');
    if (featuresLayout) {
      observer.observe(featuresLayout);
    }
  }
</script>

<style define:vars={{
  titleSize: fontSize.title,
  titleMobileSize: fontSize.titleMobile,
  subtitleSize: fontSize.subtitle,
  subtitleMobileSize: fontSize.subtitleMobile,
  cardLabelSize: fontSize.cardLabel,
  cardLabelMobileSize: fontSize.cardLabelMobile,
  cardDescriptionSize: fontSize.cardDescription,
  cardDescriptionMobileSize: fontSize.cardDescriptionMobile,
}}>
  .features {
    position: relative;
    padding-top: 4.75rem;
    background: #FFFFFF;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem;
  }

  .features-header {
    margin-bottom: 4rem;
  }

  .features-title {
    font-size: var(--titleSize);
    font-weight: 600;
    line-height: 1.3;
    color: #111827;
    margin-bottom: 0.5rem;
    max-width: 800px;
  }

  .features-subtitle {
    font-size: var(--subtitleSize);
    line-height: 1.6;
    color: var(--grey-gray-60-base, #111827);;
    max-width: 600px;
  }

  .features-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: center;
  }

  .features-layout.in-view .feature-left {
    transform: translateX(0);
  }

  .feature-left {
    transform: translateX(-50%);
    transition: all 0.8s ease;
    z-index: 1;
  }

  .feature-left-title {
    color: var(--grey-gray-60-base, #111827);
    font-feature-settings: 'liga' off, 'clig' off;
    font-family: Inter;
    font-size: 1.25rem;
    line-height: 150%; /* 24px */
    margin-bottom: 1rem;
  }

  .feature-left-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2.25rem;
  }

  .left-list-item {
    max-width: 12.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
    backdrop-filter: blur(5px);
    border-radius: 0.5rem;
    color: #fff;
    gap: 1rem;
    padding: 1rem;
    aspect-ratio: 100 / 87;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .left-list-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(83, 134, 250, 0.4);
  }

  .left-list-item svg {
    transition: transform 0.3s ease;
  }

  .left-list-item:hover svg {
    transform: scale(1.1);
  }
   
  .left-list-item-info {
    text-align: center;
  }

  .feature-left-info {
    color: #000;;
    font-feature-settings: 'liga' off, 'clig' off;
    font-family: Inter;
    font-size: 1.25rem;
    line-height: 150%; /* 24px */
  }

  .feature-left-description {
    color: #000;
    font-feature-settings: 'liga' off, 'clig' off;
    font-family: Inter;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 150%; /* 24px */
  }

  .features-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  /* Initial state - staggered */
  .feature-item {
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    background: #000;
  }
  .feature-hover {
    position: absolute;
    height: 0;
    overflow: hidden;
  }

  .feature-item:nth-child(1),
  .feature-item:nth-child(2),
  .feature-item:nth-child(3) {
    transform: translateX(-100%);
  }

  .feature-item:nth-child(4),
  .feature-item:nth-child(5),
  .feature-item:nth-child(6) {
    transform: translateX(90px);
  }

  /* When in viewport - aligned */
  .features-layout.in-view .features-list .feature-item {
    transform: translateX(0);
  }

  .features-preview {
