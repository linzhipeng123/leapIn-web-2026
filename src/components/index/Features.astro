---
import { pxToRem } from '../../utils/index';
import bgPreview from '../../assets/index/features/bg.png';
import bgPreviewCn from '../../assets/index/features/bg-cn.png';
import bgPreviewMobile from '../../assets/index/features/bg-mobile.png';
import bgPreviewMobileCn from '../../assets/index/features/bg-cn-mobile.png';
import slow1 from '../../assets/index/features/slow1.png';
import slow2 from '../../assets/index/features/slow2.png';
import slow3 from '../../assets/index/features/slow3.png';
import slow4 from '../../assets/index/features/slow4.png';
import slow5 from '../../assets/index/features/slow5.png';
import slow6 from '../../assets/index/features/slow6.png';

const features = [slow1, slow2, slow3, slow4, slow5, slow6];

const fontSize = {
  title: pxToRem(40),
  titleMobile: pxToRem(24),
  subtitle: pxToRem(16),
  subtitleMobile: pxToRem(14),
  cardLabel: pxToRem(14),
  cardLabelMobile: pxToRem(12),
  cardDescription: pxToRem(14),
  cardDescriptionMobile: pxToRem(12),
};
---

