---
import { pxToRem } from '../../utils/index';
import bgDot from '../../assets/bg_dot_dark.png';

// Pre-compute rem values
const fontSize = {
  titleMobile: pxToRem(24),
  subtitleMobile: pxToRem(14),
  value: pxToRem(40),
  valueMobile: pxToRem(32),
  suffix: pxToRem(18),
  suffixMobile: pxToRem(13),
  label: pxToRem(14),
  labelMobile: pxToRem(12),
  description: pxToRem(16),
  descriptionMobile: pxToRem(13),
  industry: pxToRem(16),
  industryMobile: pxToRem(13),
};

const stats = [
  {value: '↑ + ↓', hasSuffix: false, industry: 'Retail'},
  {value: '8', hasSuffix: false, suffix: 'x', industry: 'FMCG'},
  {value: '63', hasSuffix: false, suffix: '%', industry: 'Hospitality'},
  {value: '40→88', hasSuffix: false, suffix: '%', industry: 'Financial Services'},
  {value: '10', hasSuffix: false, suffix: 'x', industry: 'Manufacturing'},
  {value: '40→15', hasSuffix: false, suffix: '%', industry: 'Healthcare & Biotech'},
]
---

<section class="stats">
  <div class="container">
    <h2 class="stats-title" data-i18n="homepage.stats.title"></h2>
    <p class="stats-subtitle" data-i18n="homepage.stats.subtitle"></p>
    <div class="stats-grid">
      {
        stats.map((item, index) => (
          <div class="stat-card">
            <div class="stat-industry" data-i18n={`homepage.stats.items.${index}.label`}></div>
            <div class="stat-value-wrapper">
              <div class="stat-value">
                <span class="value-text">
                  <span data-i18n={`homepage.stats.items.${index}.value`}></span>{item.hasSuffix ? <span class="stat-suffix">{item.suffix}</span> : null}
                </span>
                <span class="value-text">
                  <span data-i18n={`homepage.stats.items.${index}.value`}></span>{item.hasSuffix ? <span class="stat-suffix">{item.suffix}</span> : null}
                </span>
              </div>
            </div>
            <div class="stat-description" data-i18n={`homepage.stats.items.${index}.description`}></div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  loadTranslations();
</script>

<style define:vars={{ 
  bgDot: `url(${bgDot.src})`,
  titleMobileSize: fontSize.titleMobile,
  subtitleMobileSize: fontSize.subtitleMobile,
  valueSize: fontSize.value,
  valueMobileSize: fontSize.valueMobile,
  suffixSize: fontSize.suffix,
  suffixMobileSize: fontSize.suffixMobile,
  descriptionSize: fontSize.description,
  descriptionMobileSize: fontSize.descriptionMobile,
  labelSize: fontSize.label,
  labelMobileSize: fontSize.labelMobile,
  industrySize: fontSize.industry,
  industryMobileSize: fontSize.industryMobile,
}}>
  .stats {
    padding-top: 4.75rem;
    background: var(--grey-gray-60-base, #111827);
    color: white;
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .stats::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: var(--bgDot);
    background-repeat: repeat;
    background-size: auto;
    opacity: 0.3;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
  }

  .stats-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    line-height: 124%;
    color: var(--Neutrals-White-00, #FFF);
    letter-spacing: -0.44px;
    font-weight: 600;
  }

  .stats-subtitle {
    font-size: 1.25rem;
    color: var(--Neutrals-White-00, #FFF);
    margin-bottom: 2rem;
    line-height: 1.2;
    font-feature-settings: 'liga' off, 'clig' off;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 0 auto;
  }

  .stat-card {
    border-radius: 0.75rem;
    border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
    background: rgba(255, 255, 255, 0.05);

    /* backgroud blur */
    backdrop-filter: blur(15px);
    padding: 1.5rem;
    text-align: left;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow: hidden;
  }

  .stat-industry {
    font-size: var(--industrySize);
    line-height: 1.2;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 2rem;
  }

  .stat-value-wrapper {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0rem;
    margin-bottom: 2rem;
  }

  .stat-value {
    font-size: var(--valueSize);
    font-weight: 600;
    line-height: 1.24;
    display: inline-block;
    overflow: hidden;
    height: 1.2em;
    position: relative;
    letter-spacing: -0.44px;
  }

  .stat-value > span {
    display: block;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-suffix {
    font-size: var(--suffixSize);
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 700;
  }

  .stat-card:hover .stat-value > span:first-child {
    animation: scrollUpFirst 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .stat-card:hover .stat-value > span:last-child {
    animation: scrollUpSecond 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes scrollUpFirst {
    0% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-90%);
    }
    100% {
      transform: translateY(0);
    }
  }

  @keyframes scrollUpSecond {
    0% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-90%);
    }
    100% {
      transform: translateY(0%);
    }
  }

  .stat-description {
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--descriptionSize);
    font-style: normal;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.154px;
  }

  @media (max-width: 768px) {
    .stats {
      padding: 0;
      min-height: fit-content;
    }

    .container {
      padding: 2.25rem 1rem;
    }

    .stats-title {
      font-size: var(--titleMobileSize);
    }

    .stats-subtitle {
      font-size: var(--subtitleMobileSize);
      margin-bottom: 1.5rem;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem;
    }

    .stat-card {
      padding: 1.5rem 1rem;
    }

    .stat-industry {
      font-size: var(--industryMobileSize);
      margin-bottom: 1rem;
    }

    .stat-value-wrapper {
      margin-bottom: 1rem;
    }

    .stat-value {
      font-size: var(--valueMobileSize);
      margin-bottom: 0.125rem;
      line-height: 1;
      height: 2rem;
    }

    .stat-suffix {
      font-size: var(--suffixMobileSize);
    }

    .stat-description {
      font-size: var(--descriptionMobileSize);
      line-height: 1.4;
    }
  }
</style>
