---
import Button from '../Button.astro';
import bgDot from '../../assets/cta_bg_dot.png';

interface Props {
	pageName: 'homepage' | 'about';
}

const { pageName } = Astro.props;
---

<section class="cta">
  <div class="cta-container">
    <!-- CTA Section -->
    <div class="cta-content">
      <h2 class="cta-title" data-i18n={`${pageName}.cta.title`}></h2>
      <p class="cta-subtitle" data-i18n={`${pageName}.cta.subtitle`}></p>
      <Button type="primary" text={`${pageName}.cta.button`} className="cta-btn" href="request" />
    </div>
  </div>
</section>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  loadTranslations();
</script>

<style define:vars={{
  bgDot: `url(${bgDot.src})`,
}}>
  .cta {
    position: relative;
    overflow: hidden;
    min-height: calc(-25.25rem + 100vh);
    padding: 6rem 0px;
    background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FF 50%, #E8ECFF 100%);
    align-items: center;
    display: flex;
    justify-content: center;
  }

  .cta::before {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		top: 0;
		background-image: var(--bgDot);
		background-repeat: no-repeat;
		background-position: center;
		background-size: cover;
    z-index: 1;
    width: 100%;
    height: 100%;
	}

  .cta::after {
		content: '';
		position: absolute;
		background: var(--AI-Gradient-Sky-Aurora-Medium, linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%));
    z-index: 0;
		left: 0;
		right: 0;
		bottom: 0;
		top: 0;
    width: 100%;
    height: 100%;
	}

  .cta-container {
    position: relative;
    z-index: 1;
  }

  /* CTA Section */
  .cta-content {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    max-width: var(--max-width);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .cta-title {
      color: var(--grey-gray-60-base, #111827);
      text-align: center;
      font-size: 2.5rem;
      line-height: 124%; /* 49.6px */
      letter-spacing: -0.44px;
      margin-bottom: 0.5rem;
  }

  .cta-subtitle {
      color: var(--grey-gray-60-base, #111827);
      text-align: center;
      font-feature-settings: 'liga' off, 'clig' off;
      font-size: 1rem;
      line-height: 120%; /* 19.2px */
      margin-bottom: 3.75rem;
  }

  .cta-btn {
      margin: 0 auto;
  }

  @media (max-width: 1024px) {
    .enterprises-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .cta {
      padding: 0;
      min-height: auto;
    }

    .cta::before {
      background-position: left bottom;
      background-size: 200%;
    }

    .cta-content {
      padding: 7.25rem 1rem;
    }

    .cta-title {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .cta-subtitle {
      font-size: 0.8125rem;
      margin-bottom: 1.5rem;
    }
  }
</style>
