---
import bgDot from '../../assets/bg_dot.png';
import enAICoachUI from '../../assets/platform/AppliedAIAgents/en/ai-coach.png';
import cnAICoachUI from '../../assets/platform/AppliedAIAgents/cn/ai-coach.png';
---

<section class="applied-ai-agents" id="applied-ai-agents">
  <div class="container">
    <div class="ai-agents-header">
      <h2 class="section-title" data-i18n="platform.platformFeatures.title">Applied AI Agents</h2>
    </div>

    <div class="ai-agents-content">
      <div class="ai-agents-slider" id="ai-agents-slider">
        <div class="feature-slide" data-index={0}>
          <img class="feature-ai-coach" id="feature-ai-coach" src={enAICoachUI.src} data-en-src={enAICoachUI.src} data-cn-src={cnAICoachUI.src} alt="AI Persona Card">
          <div class="feature-ai-sales-coach">
            <h3 class="sales-coach-title" data-i18n="platform.platformFeatures.salesCoach.title"></h3>
            <div class="sales-coach-subtitle" data-i18n="platform.platformFeatures.salesCoach.subtitle"></div>
            <div class="sales-coach-description" data-i18n="platform.platformFeatures.salesCoach.description"></div>
            <div class="sales-coach-subtitle" data-i18n="platform.platformFeatures.salesCoach.outcomes"></div>
            <div class="sales-coach-list">
              {
                Array(3).fill(0).map((_, index) => (
                  <div class="sales-coach-item" data-index={index}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M7.06536 11.0654L11.7654 6.36536L10.832 5.43203L7.06536 9.1987L5.16536 7.2987L4.23203 8.23203L7.06536 11.0654ZM7.9987 14.6654C7.07648 14.6654 6.20981 14.4904 5.3987 14.1404C4.58759 13.7904 3.88203 13.3154 3.28203 12.7154C2.68203 12.1154 2.20703 11.4098 1.85703 10.5987C1.50703 9.78759 1.33203 8.92092 1.33203 7.9987C1.33203 7.07648 1.50703 6.20981 1.85703 5.3987C2.20703 4.58759 2.68203 3.88203 3.28203 3.28203C3.88203 2.68203 4.58759 2.20703 5.3987 1.85703C6.20981 1.50703 7.07648 1.33203 7.9987 1.33203C8.92092 1.33203 9.78759 1.50703 10.5987 1.85703C11.4098 2.20703 12.1154 2.68203 12.7154 3.28203C13.3154 3.88203 13.7904 4.58759 14.1404 5.3987C14.4904 6.20981 14.6654 7.07648 14.6654 7.9987C14.6654 8.92092 14.4904 9.78759 14.1404 10.5987C13.7904 11.4098 13.3154 12.1154 12.7154 12.7154C12.1154 13.3154 11.4098 13.7904 10.5987 14.1404C9.78759 14.4904 8.92092 14.6654 7.9987 14.6654ZM7.9987 13.332C9.48759 13.332 10.7487 12.8154 11.782 11.782C12.8154 10.7487 13.332 9.48759 13.332 7.9987C13.332 6.50981 12.8154 5.2487 11.782 4.21536C10.7487 3.18203 9.48759 2.66536 7.9987 2.66536C6.50981 2.66536 5.2487 3.18203 4.21536 4.21536C3.18203 5.2487 2.66536 6.50981 2.66536 7.9987C2.66536 9.48759 3.18203 10.7487 4.21536 11.782C5.2487 12.8154 6.50981 13.332 7.9987 13.332Z" fill="url(#paint0_linear_2623_4753)"/>
                      <defs>
                        <linearGradient id="paint0_linear_2623_4753" x1="1.93606" y1="3.41536" x2="13.3186" y2="13.1429" gradientUnits="userSpaceOnUse">
                          <stop stop-color="#5386FA"/>
                          <stop offset="1" stop-color="#8B5CF6"/>
                        </linearGradient>
                      </defs>
                    </svg>
                    <span class="item-description" data-i18n={`platform.platformFeatures.salesCoach.items.${index}.description`}></span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style define:vars={{ 
  bgDot: `url(${bgDot.src})`,
}}>
  .applied-ai-agents {
    box-sizing: border-box;
    overflow: hidden;
    background: #FFF;
    display: flex;
    align-items: center;
    position: relative;
  }

  .applied-ai-agents::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    top: 0;
		background-image: var(--bgDot);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    z-index: 1;
  }
  .applied-ai-agents::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    top: 0;
    margin: auto auto;
		width: 542px;
    height: 542px;
    border-radius: 50%;
    background: var(--AI-Gradient-Sky-Aurora-Medium, linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%));
    filter: blur(18.149999618530273px);
    transition: width 0.5s ease, height 0.5s ease;
  }

  .applied-ai-agents[data-slide="0"]::after {
    width: 542px;
    height: 542px;
  }

  .applied-ai-agents[data-slide="1"]::after {
    width: 862px;
    height: 862px;
  }

  .applied-ai-agents[data-slide="2"]::after {
    width: 1216px;
    height: 1216px;
  }


  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-wrap: wrap;
    z-index: 1;
  }

  .ai-agents-header {
    margin-top: 6.25rem;
    margin-bottom: 3rem;
    margin-left: auto;
    margin-right: auto;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    line-height: 124%;
    letter-spacing: -1.1%;
  }

  .section-subtitle {
    font-size: 1rem;
    line-height: 1.5;
  }

  .ai-agents-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.625rem;
    width: 100%;
    flex: 1;
  }

  .ai-agents-slider {
    width: 100%;
    position: relative;
    z-index: 1;
    flex: 1;
    border-radius: 16px;
    overflow: hidden;
    top: -4rem;
  }

  .feature-slide {
    position: absolute;
    inset: 0;
    /* opacity: 0; */
    transition: all 0.5s;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    gap: 2rem;
  }

  .feature-ai-coach {
    width: 41.25rem;
    transform: translateX(2000px) rotate(180deg);
    transition: all 0.5s;
    position: relative;
    border-radius: 0.75rem;
    border: 1px solid var(--Neutrals-White-00, #FFF);
    transition: all 0.5s;
    /* background: var(--Neutrals-White-30, rgba(255, 255, 255, 0.30)); */
    /* backdrop-filter: blur(7.5px); */
  }

  .feature-ai-sales-coach {
    transition: all 0.5s ease;
    border-radius: 0.75rem;
    border: 1px solid var(--Neutrals-White-00, #FFF);
    background: var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
    backdrop-filter: blur(7.5px);
    display: inline-flex;
    padding: 3.125rem 1.5rem 1.5rem 1.5rem;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    width: 21rem;
    transform: translateX(1000px) rotate(-180deg);
    opacity: 0;
  }
  .feature-slide[data-index="1"] .feature-ai-coach {
    transform: translateX(30%) rotate(0);
  }
  .feature-slide[data-index="2"] .feature-ai-coach {
    transform: translateX(0) rotate(0);
  }
  .feature-slide[data-index="0"] .feature-ai-sales-coach,
  .feature-slide[data-index="1"] .feature-ai-sales-coach {
    transform: translateX(1000px) rotate(-180deg);
    opacity: 0;
  }
  .feature-slide[data-index="2"] .feature-ai-sales-coach {
    transform: translateX(0) rotate(0);
    opacity: 1;
  }

  .sales-coach-title {
    margin-bottom: 2rem;
    background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-feature-settings: 'liga' off, 'clig' off;
    font-family: Inter;
    font-size: 2rem;
  }

  .sales-coach-title.en {
    font-style: italic;
  }

  .sales-coach-subtitle {
    color: var(--grey-gray-60-base, #111827);
    font-feature-settings: 'liga' off, 'clig' off;
    /* Body Text/00 Semibold */
    font-family: Inter;
    font-size: 1.125rem;
    font-style: normal;
    font-weight: 600;
    line-height: 133.333%; /* 133.333% */
    margin-bottom: 0.5rem;
    margin-top: 1rem;
  }

  .sales-coach-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sales-coach-item {
    display: flex;
    padding: 2px 0.5rem;
    align-items: center;
    gap: 0.25rem;
    border-radius: 0.5rem;
    background: var(--Grey-Gray-10, rgba(17, 24, 39, 0.05));
    width: fit-content;
  }

  .item-description {
    color: var(--grey-gray-60-base, #111827);
    font-feature-settings: 'liga' off, 'clig' off;

    /* Body Text/02 Regular */
    font-family: Inter;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 18px; /* 128.571% */
  }


  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1rem;
      min-height: auto;
    }

    .applied-ai-agents {
      padding: 2.25rem 0;
      height: fit-content;
    }
    .applied-ai-agents::after {
      width: 100%;
      height: 100%;
      border-radius: 25ch;
    }

    .section-title {
      font-size: 1.5rem;
    }
    .section-subtitle {
      font-size: 0.8125rem;
    }

    .ai-agents-content {
      gap: 1.5rem;
    }

    .ai-agents-slider {
      height: auto;
      aspect-ratio: unset;
      position: static;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      flex: auto;
    }

    .feature-slide {
      position: static;
      opacity: 1;
      height: auto;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .ai-agents-header {
      padding: 0;
      margin: 0;
      margin-bottom: 1.25rem;
    }

    .feature-ai-sales-coach {
      width: 100%;
      max-width: 100%;
    }

    .sales-coach-title {
      font-size: 1.25rem;
      font-weight: 600;
      line-height: 150%;
    }

    .sales-coach-subtitle {
      font-size: 0.9375rem;
      font-weight: 600;
      line-height: 150%;
    }

    .sales-coach-description,
    .item-description {
      font-size: 0.8125rem;
      line-height: 150%;
    }


    .feature-slide[data-index="0"] .feature-ai-coach,
    .feature-slide[data-index="1"] .feature-ai-coach,
    .feature-slide[data-index="2"] .feature-ai-coach,
    .feature-slide[data-index="0"] .feature-ai-sales-coach,
    .feature-slide[data-index="1"] .feature-ai-sales-coach,
    .feature-slide[data-index="2"] .feature-ai-sales-coach {
      display: block !important;
      transform: translateX(0) rotate(0);
      opacity: 1;
    }

    .feature-slide[data-active="false"] {
      display: flex;
    }
  }
</style>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  loadTranslations();

  const section = document.getElementById('applied-ai-agents');
  const slider = document.getElementById('ai-agents-slider');
  const featureAICoach = document.getElementById('feature-ai-coach');

  const currentLang = localStorage.getItem('language') || 'en';

  // 为英文标题添加斜体样式
  if (currentLang === 'en') {
    const salesCoachTitles = document.querySelectorAll('.sales-coach-title');
    salesCoachTitles.forEach(title => {
      title.classList.add('en');
    });
  }

  if (featureAICoach) {
    const src = currentLang === 'en'
      ? featureAICoach.getAttribute('data-en-src')
      : featureAICoach.getAttribute('data-cn-src');
    if (src) featureAICoach.setAttribute('src', src);
  }
  
  const isMobile = window.matchMedia('(max-width: 768px)').matches;
  if (section && slider && !isMobile) {
    let currentIndex = 0;
    const slides = slider.querySelectorAll('.feature-slide');
    const totalSlides = 3;

    const updateSlide = (index: number) => {
      slides.forEach((slide, i) => {
        slide.setAttribute('data-active', 'true');
        slide.setAttribute('data-index', index.toString());
      });
      section.setAttribute('data-slide', index.toString());
    };

    updateSlide(0);

    let isAnimating = false;
    let scrollAccumulator = 0;
    let lastScrollDirection = 0;
    let animationTimeout: number | null = null;
    const SCROLL_THRESHOLD = 50;
    const ANIMATION_DURATION = 500;

    section.addEventListener('wheel', (e) => {
      const scrollDirection = e.deltaY > 0 ? 1 : -1;

      const atStart = currentIndex === 0 && scrollDirection < 0;
      const atEnd = currentIndex === totalSlides - 1 && scrollDirection > 0;

      if (atStart || atEnd) {
        scrollAccumulator = 0;
        lastScrollDirection = 0;
        return;
      }

      e.preventDefault();
      e.stopPropagation();

      if (lastScrollDirection !== 0 && scrollDirection !== lastScrollDirection) {
        if (animationTimeout) {
          clearTimeout(animationTimeout);
          animationTimeout = null;
        }
        isAnimating = false;
        scrollAccumulator = 0;
      }

      lastScrollDirection = scrollDirection;

      if (isAnimating) {
        scrollAccumulator += Math.abs(e.deltaY);
        if (scrollAccumulator < SCROLL_THRESHOLD) {
          return;
        }
      }

      scrollAccumulator += Math.abs(e.deltaY);

      if (scrollAccumulator < SCROLL_THRESHOLD) {
        return;
      }

      scrollAccumulator = 0;
      isAnimating = true;

      const targetIndex = scrollDirection > 0 ? currentIndex + 1 : currentIndex - 1;
      currentIndex = targetIndex;
      updateSlide(currentIndex);

      if (animationTimeout) {
        clearTimeout(animationTimeout);
      }
      animationTimeout = window.setTimeout(() => {
        isAnimating = false;
        scrollAccumulator = 0;
        animationTimeout = null;
      }, ANIMATION_DURATION);
    }, { passive: false });
  }
</script>
