---
interface Props {
	type: 'Acquisition' | 'Marketplace' | 'Development';
    className?: string;
    dataIndex: number;
}

const { type, className, dataIndex } = Astro.props;
---

<div class="platform-feature-card" data-index={dataIndex}>
    <div class="feature-title-wrap">
        <h2 class="feature-title" data-i18n={`platform.coreFeatures.${type}.title`}></h2>
        <p class="feature-description" data-i18n={`platform.coreFeatures.${type}.description`}></p>
    </div>
    <div class="feature-content">
        <div class="feature-content-title" data-i18n={`platform.coreFeatures.${type}.content.title`}></div>
        <div class="feature-content-description mb-16" data-i18n={`platform.coreFeatures.${type}.content.description`}></div>
        <div class="feature-content-title" data-i18n={`platform.coreFeatures.${type}.result.title`}></div>
        <ul class="result-list">
            {
                Array(3).fill(0).map((_, index) => (
                    <li class="result-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                            <path d="M7.06536 11.0654L11.7654 6.36536L10.832 5.43203L7.06536 9.1987L5.16536 7.2987L4.23203 8.23203L7.06536 11.0654ZM7.9987 14.6654C7.07648 14.6654 6.20981 14.4904 5.3987 14.1404C4.58759 13.7904 3.88203 13.3154 3.28203 12.7154C2.68203 12.1154 2.20703 11.4098 1.85703 10.5987C1.50703 9.78759 1.33203 8.92092 1.33203 7.9987C1.33203 7.07648 1.50703 6.20981 1.85703 5.3987C2.20703 4.58759 2.68203 3.88203 3.28203 3.28203C3.88203 2.68203 4.58759 2.20703 5.3987 1.85703C6.20981 1.50703 7.07648 1.33203 7.9987 1.33203C8.92092 1.33203 9.78759 1.50703 10.5987 1.85703C11.4098 2.20703 12.1154 2.68203 12.7154 3.28203C13.3154 3.88203 13.7904 4.58759 14.1404 5.3987C14.4904 6.20981 14.6654 7.07648 14.6654 7.9987C14.6654 8.92092 14.4904 9.78759 14.1404 10.5987C13.7904 11.4098 13.3154 12.1154 12.7154 12.7154C12.1154 13.3154 11.4098 13.7904 10.5987 14.1404C9.78759 14.4904 8.92092 14.6654 7.9987 14.6654ZM7.9987 13.332C9.48759 13.332 10.7487 12.8154 11.782 11.782C12.8154 10.7487 13.332 9.48759 13.332 7.9987C13.332 6.50981 12.8154 5.2487 11.782 4.21536C10.7487 3.18203 9.48759 2.66536 7.9987 2.66536C6.50981 2.66536 5.2487 3.18203 4.21536 4.21536C3.18203 5.2487 2.66536 6.50981 2.66536 7.9987C2.66536 9.48759 3.18203 10.7487 4.21536 11.782C5.2487 12.8154 6.50981 13.332 7.9987 13.332Z" fill="url(#paint0_linear_2536_7941)"/>
                            <defs>
                                <linearGradient id="paint0_linear_2536_7941" x1="1.93606" y1="3.41536" x2="13.3186" y2="13.1429" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#5386FA"/>
                                <stop offset="1" stop-color="#8B5CF6"/>
                                </linearGradient>
                            </defs>
                        </svg>
                        <div class="feature-content-description" data-i18n={`platform.coreFeatures.${type}.result.list.${index}.label`}></div>
                    </li>
                ))
            }
        </ul>
    </div>
</div>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  loadTranslations();

  // 为英文标题添加斜体样式
  const currentLang = localStorage.getItem('language') || 'en';
  if (currentLang === 'en') {
    const featureTitles = document.querySelectorAll('.platform-feature-card .feature-title');
    featureTitles.forEach(title => {
      title.classList.add('en');
    });
  }
</script>

<style>
    .platform-feature-card {
        display: flex;
        max-width: 28.375rem;
        padding: 5rem 1.5rem 2.25rem 1.5rem;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        border-radius: 0.75rem;
        border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
        gap: 3.125rem;
    }

    .feature-title,
    .feature-description {
        background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .feature-title {
        font-size: 2.25rem;
        line-height: 150%;
    }

    .feature-title.en {
        font-style: italic;
    }

    .feature-description {
        font-size: 1.25rem;
        font-style: italic;
        line-height: 150%;
    }
    .feature-content-title {
        color: var(--Neutrals-White-00, #FFF);
        font-feature-settings: 'liga' off, 'clig' off;
        /* CN/PC/Body text/00 semibold */
        font-size: 1.125rem;
        font-weight: 600;
        line-height: 120%; /* 21.6px */
        margin-bottom: 0.5rem;
    }

    .feature-content-description {
        color: var(--Neutrals-White-00, #FFF);
        font-feature-settings: 'liga' off, 'clig' off;

        /* CN/PC/Body text/02 regular */
        font-size: 0.875rem;
        font-style: normal;
        line-height: 150%; /* 21px */
        white-space: pre-wrap;
    }

    .mb-16 {
        margin-bottom: 1rem;
    }

    .result-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .result-item {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.125rem 0.5rem;
        border-radius: 0.5rem;
        background: rgba(255, 255, 255, 0.10);
        width: fit-content;
    }
</style>