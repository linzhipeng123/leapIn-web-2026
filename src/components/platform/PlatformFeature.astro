---
import PlatformFeatureCard from './PlatformFeatureCard.astro';

const features = [
    {type: 'Acquisition', index: 0},
    {type: 'Marketplace', index: 1},
    {type: 'Development', index: 2}
];
---

<section class="section-container platform-feature-section" id="platform-feature-section">
    <div class="container platform-feature-container" id="platform-feature-container">
        <div class="feature-item" data-index={0}>
            <h2 class="feature-title" data-i18n="platform.coreFeatures.title"></h2>
            <div class="feature-slider-content">
                {
                    features.map(({type, index}) => (
                        <div class="feature-item-card" data-index={index}>
                            <PlatformFeatureCard type={type} dataIndex={index} />
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style>
    .section-container {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 4.75rem);
        position: relative;
        padding-top: 4.75rem;
    }

    .platform-feature-section::before {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        top: 0;
        z-index: -1;
        height: 21.875rem;
        margin: auto;
        background: linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%);
        filter: blur(98.0999984741211px);
    }

    .platform-feature-container {
        width: 100%;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1rem;
        min-height: calc(100vh - 4.75rem);
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        z-index: 1;
    }

    .feature-item {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.375rem;
        width: 100%;
        height: 100%;
        flex: 1;
        flex-wrap: wrap;
        position: relative;
    }

    .feature-slider-content {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1;
        gap: 1.375rem 5.1875rem;
        flex-wrap: wrap;
        position: relative;
        max-width: 81.25rem;
    }

    .feature-title {
        color: var(--grey-gray-60-base, #111827);
        text-align: center;
        font-size: 2.5rem;
        line-height: 124%;
        letter-spacing: -0.352px;
        width: 100%;
        margin: 0 auto;
        transition: all 0.8s ease;
        position: absolute;
    }

    .feature-title.en {
        font-style: italic;
    }

    .platform-feature-container-pre .feature-item[data-index="0"] .feature-title {
        transform: translateY(-85vh);
    }

    .platform-feature-container-inner .feature-item[data-index="0"] .feature-title,
    .platform-feature-container-inner .feature-item[data-index="1"] .feature-title,
    .platform-feature-container-inner .feature-item[data-index="2"] .feature-title {
        color: var(--Neutrals-White-00, #FFF);
        opacity: 0.1;
        text-align: center;
        font-family: "DM Serif Display";
        font-size: 6.25rem;
        line-height: 124%; /* 124px */
        letter-spacing: -1.1px;
    }

    .feature-item-card {
        display: flex;
        justify-content: center;
        align-items: center;
        transition: all 0.8s ease;
        width: fit-content;
        border-radius: 0.75rem;
        border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
    }

    /* pre */
    .platform-feature-container-pre .feature-item[data-index="0"] .feature-item-card[data-index="0"] {
        position: absolute;
        left: 0;
        right: 0;
        margin: 0 auto;
        top: 0;
        transform: translateY(-70vh) rotate(-45deg);
        border: 2px solid var(--Neutrals-White-00, #FFF);
        background: var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        backdrop-filter: blur(7.5px);
    }

    .platform-feature-container-pre .feature-item[data-index="0"] .feature-item-card[data-index="1"],
    .feature-item[data-index="0"] .feature-item-card[data-index="1"] {
        position: absolute;
        transform: translateY(100vh) rotate(-45deg);
    }

    .platform-feature-container-pre .feature-item[data-index="0"] .feature-item-card[data-index="2"],
    .feature-item[data-index="0"] .feature-item-card[data-index="2"],
    .feature-item[data-index="1"] .feature-item-card[data-index="2"] {
        position: absolute;
        transform: translateY(100vh) rotate(45deg);
    }

    /* data-index="0" - 初始状态 */
    .feature-item[data-index="0"] .feature-item-card[data-index="0"] {
        position: absolute;
        margin: 0 auto;
        transform: translateY(0) rotate(0deg);
    }

    /* data-index="1" */
    .feature-item[data-index="1"] .feature-item-card[data-index="0"],
    .feature-item[data-index="2"] .feature-item-card[data-index="0"],
    .feature-item[data-index="2"] .feature-item-card[data-index="1"] {
        position: absolute;
        transform: translateY(-100vh) rotate(0deg);
    }

    .feature-item[data-index="1"] .feature-item-card[data-index="1"] {
        position: absolute;
        margin: 0 auto;
        transform: translateY(0) rotate(0deg);
    }

    .feature-item[data-index="2"] .feature-item-card[data-index="2"] {
        position: absolute;
        margin: 0 auto;
        transform: translateY(0) rotate(0deg);
    }
    
    @media (max-width: 768px) {
      .section-container {
        justify-content: center;
        padding: 2.25rem 0;
      }
      .feature-item {
          gap: 1.5rem;
      }

      .platform-feature-container {
        padding: 0;
        overflow: hidden;
      }

      .feature-title {
          position: relative;
          font-size: 1.5rem;
          line-height: 120%;
          color: var(--Neutrals-White-00, #FFF);
      }

      .feature-slider-content {
          gap: 1rem;
      }

      .feature-item-card {
          /* transform: none !important; */
          left: 0 !important;
          top: 0 !important;
          right: 0 !important;
          position: relative !important;
          margin: 0 !important;
          max-width: calc(100% - 3.75rem);
          margin: 0 auto;
      }

      .platform-feature-section .feature-item-card[data-index="0"],
      .platform-feature-section .feature-item-card[data-index="2"] {
        transform: translateX(-100%) translateY(100%) rotate(30deg);
      }

      .platform-feature-section .feature-item-card[data-index="1"] {
        transform: translateX(100%) translateY(100%) rotate(-30deg);
      }

      .platform-feature-section.in-view .feature-item-card[data-index="0"],
      .platform-feature-section.in-view .feature-item-card[data-index="1"],
      .platform-feature-section.in-view .feature-item-card[data-index="2"] {
        transform: translateX(0) rotate(0);
      }
    }
</style>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  import { inView } from '../../utils/inView';
  loadTranslations();

  // 为英文标题添加斜体样式
  const currentLang = localStorage.getItem('language') || 'en';
  if (currentLang === 'en') {
    const featureTitles = document.querySelectorAll('.feature-title');
    featureTitles.forEach(title => {
      title.classList.add('en');
    });
  }

  const section = document.getElementById('platform-feature-section');
  const slider = document.getElementById('platform-feature-container');
  
  const isMobile = window.matchMedia('(max-width: 768px)').matches;
  if (section && slider && !isMobile) {
    let currentIndex = 0;
    const slides = slider.querySelectorAll('.feature-item');
    const totalSlides = 3; // 0-2 共3个状态

    let isAnimating = false;
    let scrollAccumulator = 0;
    let lastScrollDirection = 0; // 1 for down, -1 for up
    let animationTimeout: number | null = null;
    
    const SCROLL_THRESHOLD = 50; // 滚动阈值
    const ANIMATION_DURATION = 800;

    const updateSlide = (index: number) => {
      section.setAttribute('active-slider', index.toString());
      slides.forEach((slide) => {
        slide.setAttribute('data-active', 'true');
        slide.setAttribute('data-index', index.toString());
      });
    };

    updateSlide(0);

    section.addEventListener('wheel', (e) => {
      const scrollDirection = e.deltaY > 0 ? 1 : -1;

      // 检查是否在边界
      const atStart = currentIndex === 0 && scrollDirection < 0;
      const atEnd = currentIndex === totalSlides - 1 && scrollDirection > 0;

      // 在边界时，不阻止默认行为，让滚动传递到父级 scroll-section
      if (atStart || atEnd) {
        // 重置状态
        scrollAccumulator = 0;
        lastScrollDirection = 0;
        return;
      }

      // 不在边界，阻止默认滚动行为
      e.preventDefault();
      e.stopPropagation();

      // 检测方向改变
      if (lastScrollDirection !== 0 && scrollDirection !== lastScrollDirection) {
        // 反向滚动，中断当前动画
        if (animationTimeout) {
          clearTimeout(animationTimeout);
          animationTimeout = null;
        }
        isAnimating = false;
        scrollAccumulator = 0;
      }

      lastScrollDirection = scrollDirection;

      // 如果正在动画中且方向相同，累积滚动量
      if (isAnimating) {
        scrollAccumulator += Math.abs(e.deltaY);
        // 同方向滚动未达到阈值，忽略
        if (scrollAccumulator < SCROLL_THRESHOLD) {
          return;
        }
      }

      // 累积滚动量
      scrollAccumulator += Math.abs(e.deltaY);

      // 未达到阈值，不触发切换
      if (scrollAccumulator < SCROLL_THRESHOLD) {
        return;
      }

      // 达到阈值，执行切换
      scrollAccumulator = 0;
      isAnimating = true;

      const targetIndex = scrollDirection > 0 ? currentIndex + 1 : currentIndex - 1;

      currentIndex = targetIndex;
      updateSlide(currentIndex);

      // 动画完成后重置状态
      if (animationTimeout) {
        clearTimeout(animationTimeout);
      }
      animationTimeout = window.setTimeout(() => {
        isAnimating = false;
        scrollAccumulator = 0;
        animationTimeout = null;
      }, ANIMATION_DURATION);
    }, { passive: false });
  }

  // Intersection Observer 监听 features 是否在可视区域内
  if (isMobile && typeof window !== 'undefined') {
    inView({id: "platform-feature-section", threshold: 0.3});
  }
</script>
