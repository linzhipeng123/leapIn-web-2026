---
import LanguageSwitcher from './LanguageSwitcher.astro';
import Button from './Button.astro';
import logo from '../assets/logo.png';

// 获取当前路径
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

console.log("base", base)
---

<header class="header">
  <div class="container">
    <div class="header-content">
      <div class="header-content-wrap">
        <a href={base} class="logo">
          <img src={logo.src} alt="LeapIn" />
        </a>
        
        <nav class="nav">
          <div class={`nav-link ${currentPath.includes('/platform') ? 'active' : ''}`}>
            <a href={`${base}platform`} data-i18n="header.platform"></a>
          </div>
          <div class={`nav-link ${currentPath.includes('/solutions') ? 'active' : ''}`}>
            <a href={`${base}solutions`} data-i18n="header.solutions"></a>
          </div>
          <div class={`nav-link ${currentPath.includes('/industries') ? 'active' : ''}`}>
            <a href={`${base}industries`} data-i18n="header.industries"></a>
          </div>
          <div class={`nav-link ${currentPath.includes('/about') ? 'active' : ''}`}>
            <a href={`${base}about`} data-i18n="header.about"></a>
          </div>
        </nav>
      </div>

      <div class="header-actions">
        <div class="header-btn">
          <Button text="header.requestDemo" type="nav" href="request" />
        </div>
        <LanguageSwitcher />
        <button class="mobile-menu-btn" id="mobile-menu-toggle" aria-label="Menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>

    <!-- 移动端菜单下拉 -->
    <div class="mobile-menu" id="mobile-menu">
      <nav class="mobile-nav">
        <a href={`${base}`} class={`mobile-nav-link ${currentPath === '/' ? 'active' : ''}`} data-i18n="header.home"></a>
        <a href={`${base}platform`} class={`mobile-nav-link ${currentPath.includes('/platform') ? 'active' : ''}`} data-i18n="header.platform"></a>
        <a href={`${base}solutions`} class={`mobile-nav-link ${currentPath.includes('/solutions') ? 'active' : ''}`} data-i18n="header.solutions"></a>
        <a href={`${base}industries`} class={`mobile-nav-link ${currentPath.includes('/industries') ? 'active' : ''}`} data-i18n="header.industries"></a>
        <a href={`${base}about`} class={`mobile-nav-link ${currentPath.includes('/about') ? 'active' : ''}`} data-i18n="header.about"></a>
      </nav>
    </div>
  </div>
</header>

<script>
  import { loadTranslations } from '../scripts/i18n-loader';
  loadTranslations();

  // 移动端菜单切换
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    mobileMenuToggle.classList.toggle('active');
    mobileMenu?.classList.toggle('active');
  });

  // 点击外部关闭菜单
  document.addEventListener('click', () => {
    mobileMenuToggle?.classList.remove('active');
    mobileMenu?.classList.remove('active');
  });

  // 阻止菜单内部点击事件冒泡
  mobileMenu?.addEventListener('click', (e) => {
    e.stopPropagation();
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.8);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    z-index: 1000;
    padding: 1rem 0;
    backdrop-filter: blur(14px);
    height: 4.75rem;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header-content-wrap {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .logo {
    display: block;
    text-decoration: none;
  }

  .logo img {
    height: 1.5rem;
    width: auto;
    display: block;
  }

  .nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-link {
    padding: 0.5rem 0.75rem;
    border-radius: 0.25rem;
    border-radius: 8px;
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    border: 1px solid transparent;
    transition: all 0.3s;
  }

  .nav-link:hover,
  .nav-link.active {
    border: 1px solid #fff;
    background: var(--Neutrals-White-20, rgba(255, 255, 255, 0.60));
    box-sizing: border-box;
  }
  .nav-link:hover a,
  .nav-link.active a {
    background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 600;
  }

  .header-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .btn-primary {
    background: linear-gradient(130.52deg, #5386FA 9.64%, #8B5CF6 89.29%);
    color: white;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.3s;
    border: none;
    cursor: pointer;
    height: 2.25rem;
  }

  .btn-primary:hover {
    background: #5558e3;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
  }

  /* 移动端菜单按钮 */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    height: 2.25rem;
  }

  .mobile-menu-btn span {
    display: block;
    width: 1.5rem;
    height: 2px;
    background: var(--color-text);
    transition: all 0.3s;
  }

  .mobile-menu-btn.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .mobile-menu-btn.active span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-btn.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -6px);
  }

  /* 移动端菜单下拉 */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    z-index: 999;
  }

  .mobile-menu.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1rem;
  }

  .mobile-nav-link {
    padding: 1rem;
    color: var(--color-text);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .mobile-nav-link:hover {
    background: rgba(99, 102, 241, 0.08);
    color: #6366f1;
  }

  .mobile-nav-link.active {
    background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 600;
  }

  .mobile-cta-btn {
    margin-top: 1rem;
    background: #6366f1;
    color: white;
    padding: 1rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
  }

  .mobile-cta-btn:hover {
    background: #5558e3;
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }

    .container {
      padding: 0 1rem;
    }

    .header-actions .header-btn {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }

  @media (min-width: 769px) {
    .mobile-menu {
      display: none;
    }
  }
</style>
