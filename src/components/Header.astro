---
import Button from './Button.astro';
import logo from '../assets/logo.png';

// 获取当前路径
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;
---

<header class="header">
  <div class="container">
    <div class="header-content">
      <div class="header-content-wrap">
        <a href={base} class="logo">
          <img src={logo.src} alt="LeapIn" />
        </a>
        
        <nav class="nav">
          <div class={`nav-link ${currentPath.includes('/platform') ? 'active' : ''}`}>
            <a href={`${base}platform`} data-i18n="header.platform"></a>
          </div>
          <div class={`nav-link ${currentPath.includes('/solutions') ? 'active' : ''}`}>
            <a href={`${base}solutions`} data-i18n="header.solutions"></a>
          </div>
          <!-- <div class={`nav-link ${currentPath.includes('/industries') ? 'active' : ''}`}>
            <a href={`${base}industries`} data-i18n="header.industries"></a>
          </div> -->
          <div class={`nav-link ${currentPath.includes('/about') ? 'active' : ''}`}>
            <a href={`${base}about`} data-i18n="header.about"></a>
          </div>
        </nav>
      </div>

      <div class="header-actions">
        <div class="header-btn">
          <Button text="button.RequestDemo" type="nav" href="request" />
        </div>
        <button class="mobile-menu-btn" id="mobile-menu-toggle" aria-label="Menu">
          <svg class="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <mask id="mask0_3838_7554" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
              <rect width="24" height="24" fill="#D9D9D9"/>
            </mask>
            <g mask="url(#mask0_3838_7554)">
              <path d="M3 18V16H21V18H3ZM3 13V11H21V13H3ZM3 8V6H21V8H3Z" fill="#111827"/>
            </g>
          </svg>
          <svg class="close-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <mask id="mask0_1924_24021" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
              <rect width="24" height="24" fill="#D9D9D9"/>
            </mask>
            <g mask="url(#mask0_1924_24021)">
              <path d="M11.9992 14.0876L7.64922 18.4376C7.37422 18.7126 7.02422 18.8501 6.59922 18.8501C6.17422 18.8501 5.82422 18.7126 5.54922 18.4376C5.27422 18.1626 5.13672 17.8126 5.13672 17.3876C5.13672 16.9626 5.27422 16.6126 5.54922 16.3376L9.89922 11.9876L5.54922 7.6751C5.27422 7.4001 5.13672 7.0501 5.13672 6.6251C5.13672 6.2001 5.27422 5.8501 5.54922 5.5751C5.82422 5.3001 6.17422 5.1626 6.59922 5.1626C7.02422 5.1626 7.37422 5.3001 7.64922 5.5751L11.9992 9.9251L16.3117 5.5751C16.5867 5.3001 16.9367 5.1626 17.3617 5.1626C17.7867 5.1626 18.1367 5.3001 18.4117 5.5751C18.7117 5.8751 18.8617 6.23135 18.8617 6.64385C18.8617 7.05635 18.7117 7.4001 18.4117 7.6751L14.0617 11.9876L18.4117 16.3376C18.6867 16.6126 18.8242 16.9626 18.8242 17.3876C18.8242 17.8126 18.6867 18.1626 18.4117 18.4376C18.1117 18.7376 17.7555 18.8876 17.343 18.8876C16.9305 18.8876 16.5867 18.7376 16.3117 18.4376L11.9992 14.0876Z" fill="#111827"/>
            </g>
          </svg>
        </button>
      </div>
    </div>

    <!-- 移动端菜单下拉 -->
    <div class="mobile-menu" id="mobile-menu">
      <nav class="mobile-nav">
        <a href={`${base}`} class={`mobile-nav-link ${currentPath === '/' ? 'active' : ''}`} data-i18n="header.home"></a>
        <a href={`${base}platform`} class={`mobile-nav-link ${currentPath.includes('/platform') ? 'active' : ''}`} data-i18n="header.platform"></a>
        <a href={`${base}solutions`} class={`mobile-nav-link ${currentPath.includes('/solutions') ? 'active' : ''}`} data-i18n="header.solutions"></a>
        <!-- <a href={`${base}industries`} class={`mobile-nav-link ${currentPath.includes('/industries') ? 'active' : ''}`} data-i18n="header.industries"></a> -->
        <a href={`${base}about`} class={`mobile-nav-link ${currentPath.includes('/about') ? 'active' : ''}`} data-i18n="header.about"></a>
      </nav>
    </div>
  </div>
</header>

<script>
  import { loadTranslations } from '../scripts/i18n-loader';
  loadTranslations();

  // 移动端菜单切换
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    mobileMenuToggle.classList.toggle('active');
    mobileMenu?.classList.toggle('active');
  });

  // 点击外部关闭菜单
  document.addEventListener('click', () => {
    mobileMenuToggle?.classList.remove('active');
    mobileMenu?.classList.remove('active');
  });

  // 阻止菜单内部点击事件冒泡
  mobileMenu?.addEventListener('click', (e) => {
    e.stopPropagation();
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.8);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    z-index: 1000;
    padding: 1rem 0;
    backdrop-filter: blur(14px);
    height: 4.75rem;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header-content-wrap {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .logo {
    display: block;
    text-decoration: none;
  }

  .logo img {
    height: 1.5rem;
    width: auto;
    display: block;
  }

  .nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-link {
    padding: 0.5rem 0.75rem;
    border-radius: 0.25rem;
    border-radius: 8px;
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    border: 1px solid transparent;
    transition: all 0.3s;
  }

  .nav-link:hover,
  .nav-link.active {
    border: 1px solid #fff;
    background: var(--Neutrals-White-20, rgba(255, 255, 255, 0.60));
    box-sizing: border-box;
  }
  .nav-link:hover a,
  .nav-link.active a {
    background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 600;
  }

  .header-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .btn-primary {
    background: linear-gradient(130.52deg, #5386FA 9.64%, #8B5CF6 89.29%);
    color: white;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.3s;
    border: none;
    cursor: pointer;
    height: 2.25rem;
  }

  .btn-primary:hover {
    background: #5558e3;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
  }

  .menu-icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  /* 移动端菜单按钮 */
  .mobile-menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    height: 2.25rem;
    width: 2.25rem;
    position: relative;
  }

  .mobile-menu-btn .menu-icon,
  .mobile-menu-btn .close-icon {
    position: absolute;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .mobile-menu-btn .menu-icon {
    opacity: 1;
    transform: rotate(0deg);
  }

  .mobile-menu-btn .close-icon {
    opacity: 0;
    transform: rotate(90deg);
  }

  .mobile-menu-btn.active .menu-icon {
    opacity: 0;
    transform: rotate(-90deg);
  }

  .mobile-menu-btn.active .close-icon {
    opacity: 1;
    transform: rotate(0deg);
  }

  /* 移动端菜单下拉 */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    z-index: 999;
  }

  .mobile-menu.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1rem;
  }

  .mobile-nav-link {
    padding: 1rem;
    color: var(--color-text);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .mobile-nav-link:hover {
    background: rgba(99, 102, 241, 0.08);
    color: #6366f1;
  }

  .mobile-nav-link.active {
    background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 600;
  }

  .mobile-cta-btn {
    margin-top: 1rem;
    background: #6366f1;
    color: white;
    padding: 1rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
  }

  .mobile-cta-btn:hover {
    background: #5558e3;
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }

    .container {
      padding: 0 1rem;
    }

    .header-actions .header-btn {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }

  @media (min-width: 769px) {
    .mobile-menu {
      display: none;
    }
  }
</style>
