---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { marked } from 'marked';
import fs from 'fs';
import path from 'path';

interface Props {
	pageName: string;
}

const { pageName } = Astro.props;

// 读取中英文两个版本的 Markdown 文件
const contentDir = path.join(process.cwd(), 'src/content/legal');

// 读取中文版本
let contentZh = '';
let titleZh = '';
try {
	const markdownZh = fs.readFileSync(path.join(contentDir, `${pageName}-zh.md`), 'utf-8');
	const titleMatch = markdownZh.match(/^#\s+(.+)$/m);
	titleZh = titleMatch ? titleMatch[1] : pageName;
	contentZh = marked.parse(markdownZh);
} catch (error) {
	console.error(`Error reading Chinese legal content file: ${pageName}-zh.md`, error);
	contentZh = '<p>内容不可用。</p>';
	titleZh = pageName;
}

// 读取英文版本
let contentEn = '';
let titleEn = '';
try {
	const markdownEn = fs.readFileSync(path.join(contentDir, `${pageName}-en.md`), 'utf-8');
	const titleMatch = markdownEn.match(/^#\s+(.+)$/m);
	titleEn = titleMatch ? titleMatch[1] : pageName;
	contentEn = marked.parse(markdownEn);
} catch (error) {
	console.error(`Error reading English legal content file: ${pageName}-en.md`, error);
	contentEn = '<p>Content not available.</p>';
	titleEn = pageName;
}
---

<Layout>
	<Header />
    <main>
        <section class="legal-hero">
            
        </section>
        <section class="legal-page">
            <div class="container">
                <!-- <h1 class="title" data-lang-zh={titleZh} data-lang-en={titleEn}></h1> -->
                <div class="content" data-lang-zh={contentZh} data-lang-en={contentEn}></div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<script>
    // 立即执行函数，在页面加载时根据语言设置内容
    (function() {
        const lang = (localStorage.getItem('language') || 'zh');
        
        // 更新标题
        const titleEl = document.querySelector('.title');
        if (titleEl) {
            const title = lang === 'zh' 
                ? titleEl.getAttribute('data-lang-zh') 
                : titleEl.getAttribute('data-lang-en');
            if (title) titleEl.textContent = title;
        }
        
        // 更新内容
        const contentEl = document.querySelector('.content');
        if (contentEl) {
            const content = lang === 'zh'
                ? contentEl.getAttribute('data-lang-zh')
                : contentEl.getAttribute('data-lang-en');
            if (content) contentEl.innerHTML = content;
        }
    })();
</script>

<style>
    .legal-hero {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 22rem;
        background: linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%);
        filter: blur(50px);
        z-index: 0;
    }
	.legal-page {
        z-index: 1;
        position: relative;
		padding-top: 4.75rem;
		min-height: 100vh;
	}
    .container {
		padding: 2rem 4rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .title {
        text-align: center;
        color: var(--grey-gray-60-base, #111827);
        font-size: 2.5rem;
        line-height: 124%;
        letter-spacing: -0.44px;
        margin-bottom: 2rem;
    }

    .content {
        color: var(--grey-gray-60-base, #111827);
        font-family: Inter, sans-serif;
        font-size: 1rem;
        font-weight: 400;
        line-height: 137.5%;
        max-width: 900px;
        margin: 0 auto;
    }

    .content :global(h1) {
        font-size: 2rem;
        font-weight: 700;
        margin-top: 2.5rem;
        margin-bottom: 1.5rem;
        color: var(--grey-gray-60-base, #111827);
    }

    .content :global(h2) {
        font-size: 1.75rem;
        font-weight: 600;
        margin-top: 2.25rem;
        margin-bottom: 1.25rem;
        color: var(--grey-gray-60-base, #111827);
    }

    .content :global(h3) {
        font-size: 1.5rem;
        font-weight: 600;
        margin-top: 2rem;
        margin-bottom: 1rem;
        color: var(--grey-gray-60-base, #111827);
    }

    .content :global(h4) {
        font-size: 1.25rem;
        font-weight: 600;
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
        color: var(--grey-gray-60-base, #111827);
    }

    .content :global(h5) {
        font-size: 1.125rem;
        font-weight: 600;
        margin-top: 1.25rem;
        margin-bottom: 0.5rem;
        color: var(--grey-gray-60-base, #111827);
    }

    .content :global(p) {
        margin-bottom: 1rem;
        text-indent: 2em;
    }

    .content :global(ul),
    .content :global(ol) {
        margin: 1rem 0;
        padding-left: 2rem;
    }

    .content :global(li) {
        margin-bottom: 0.5rem;
        line-height: 1.6;
    }

    .content :global(ul li) {
        list-style-type: disc;
    }

    .content :global(ol li) {
        list-style-type: decimal;
    }

    .content :global(strong) {
        font-weight: 600;
    }

    .content :global(em) {
        font-style: italic;
    }

    .content :global(a) {
        color: #5386FA;
        text-decoration: underline;
    }

    .content :global(a:hover) {
        color: #8B5CF6;
    }

    .content :global(.highlight-email) {
        color: #5386FA;
        font-weight: 600;
        background: linear-gradient(90deg, rgba(83, 134, 250, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
    }
    .content :global(p em) {
        display: block;
        text-align: right;
        width: 100%;
    }

	@media (max-width: 768px) {
		.title {
			font-size: 1.5rem;
		}

        .container {
		    padding: 2rem 1rem;
            gap: 1rem;
        }
	}
</style>