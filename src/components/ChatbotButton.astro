---
// Chatbot 悬浮按钮和弹窗组件
import AIIcon1 from '../assets/AIIcons.svg';
import AIIcon2 from '../assets/AIIcons2.svg';
import AIAvatar from '../assets/chatbot/AIAvatar.png';
import UserAvatar from '../assets/chatbot/UserAvatar.png';
import FullScreenIcon from '../assets/chatbot/fullScreen.svg';
import ShrinkScreenIcon from '../assets/chatbot/shirnkScreen.svg';
import SendIcon from '../assets/chatbot/send.svg';
import SoundIcon from '../assets/chatbot/sound.svg';
---

<div class="chatbot-container">
  <!-- 悬浮按钮 -->
  <button class="chatbot-button" id="chatbot-toggle" aria-label="Open AI Assistant">
    <img class="chatbot-icon" src={AIIcon1.src} alt="AI Icon" id="chatbot-icon" />
  </button>

  <!-- Chatbot 弹窗 -->
  <div class="chatbot-popup" id="chatbot-popup">
    <div class="chatbot-header">
      <div class="chatbot-header-content">
        <img class="chatbot-avatar" src={AIAvatar.src} alt="AI Avatar" />
        <div class="chatbot-info">
          <h3>AI Job Assistant</h3>
        </div>
      </div>
      <div class="chatbot-header-actions">
        <button class="icon-button" id="fullscreen-toggle" aria-label="Toggle fullscreen">
          <img src={FullScreenIcon.src} alt="Fullscreen" id="fullscreen-icon" />
        </button>
        <button class="icon-button" id="chatbot-close" aria-label="Close chat">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <div class="chatbot-messages" id="chatbot-messages">
      <div class="message bot-message">
        <img class="message-avatar" src={AIAvatar.src} alt="AI" />
        <div class="message-content">
          <p>Hi I'm Elsa, how can i help you today? You can ask me anything about our business, culture, team, and more. Or you can start with a quick action below.</p>
        </div>
      </div>
      <div class="quick-actions">
        <button class="quick-action-btn">LeapIn Introduction</button>
        <button class="quick-action-btn">Product & Solution</button>
      </div>
    </div>

    <div class="chatbot-footer">
      <div class="chatbot-input-container">
        <input 
          type="text" 
          class="chatbot-input" 
          id="chatbot-input"
          placeholder="Ask Elsa..."
          aria-label="Chat input"
        />
        <button class="icon-button" id="sound-button" aria-label="Voice input">
          <img src={SoundIcon.src} alt="Voice" />
        </button>
        <button class="icon-button send-button" id="chatbot-send" aria-label="Send message">
          <img src={SendIcon.src} alt="Send" />
        </button>
      </div>
      <p class="privacy-text">Privacy and terms</p>
    </div>
  </div>
</div>

<style>
  .chatbot-container {
    position: fixed;
    bottom: 0.625rem;
    right: 2rem;
    z-index: 9999;
  }

  /* 悬浮按钮 */
  .chatbot-button {
    width: 3.125rem;
    height: 3.125rem;
    border-radius: 50%;
    border: 1px solid var(--AI-Gradient-Sky-Aurora-Medium, #FBE5CF);
    background: linear-gradient(322deg, rgba(251, 229, 207, 0.30) 14.44%, rgba(175, 201, 255, 0.30) 82.53%), #FFF;
    box-shadow: 0 0.75rem 2.5rem 0 rgba(0, 0, 0, 0.05);
    backdrop-filter: blur(10px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.6s ease;
    padding: 0;
  }

  .chatbot-button.icon2 {
    border-radius: 50%;
    background: linear-gradient(142deg, rgba(251, 229, 207, 0.30) 13.69%, rgba(175, 201, 255, 0.30) 87.17%), #FFF;
  }

  .chatbot-button.hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.8);
  }

  .chatbot-button:hover:not(.hidden) {
    transform: scale(1.1);
    box-shadow: 0 0.75rem 2.5rem 0 rgba(0, 0, 0, 0.08);
  }

  .chatbot-icon {
    width: 1.875rem;
    height: 1.875rem;
    transition: opacity 0.3s ease;
  }

  /* Chatbot 弹窗 */
  .chatbot-popup {
    position: fixed;
    bottom: 0.625rem;
    right: 1.5rem;;
    width: 100%;
    max-width: 25rem;
    height: auto;
    max-height: calc(100vh - 5.375rem - 20px);
    background: #F5F5F5;
    border-radius: 1rem;
    box-shadow: 0 0.5rem 2.5rem rgba(0, 0, 0, 0.15);
    display: none;
    flex-direction: column;
    overflow: hidden;
    animation: slideUp 0.3s ease;
    transition: all 0.3s ease;
  }

  .chatbot-popup.active {
    display: flex;
  }

  .chatbot-popup.fullscreen {
    top: 5.375rem;
    bottom: 0.625rem;
    max-height: none;
    height: auto;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Header */
  .chatbot-header {
    padding: 1rem 1.5rem;
    background: #FFF;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #E5E5E5;
  }

  .chatbot-header-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .chatbot-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    object-fit: cover;
  }

  .chatbot-info h3 {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    background: linear-gradient(90deg, #A855F7 0%, #6366F1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .chatbot-header-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .icon-button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    transition: background 0.3s;
    width: 2rem;
    height: 2rem;
  }

  .icon-button:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .icon-button img {
    width: 1.25rem;
    height: 1.25rem;
  }

  .icon-button svg {
    color: #666;
  }

  /* Messages */
  .chatbot-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: #F5F5F5;
    min-height: 20rem;
  }

  .message {
    display: flex;
    gap: 0.75rem;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .message-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
  }

  .message-content {
    flex: 1;
    background: white;
    padding: 1rem;
    border-radius: 1rem;
    box-shadow: 0 0.125rem 0.5rem rgba(0, 0, 0, 0.05);
  }

  .message-content p {
    margin: 0;
    line-height: 1.6;
    color: #333;
    font-size: 0.95rem;
  }

  .user-message {
    flex-direction: row-reverse;
  }

  .user-message .message-content {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: white;
  }

  /* Quick Actions */
  .quick-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .quick-action-btn {
    padding: 0.75rem 1.5rem;
    background: white;
    border: 1px solid #E5E5E5;
    border-radius: 2rem;
    cursor: pointer;
    font-size: 0.9rem;
    color: #333;
    transition: all 0.3s;
    white-space: nowrap;
  }

  .quick-action-btn:hover {
    border-color: #A855F7;
    color: #A855F7;
    transform: translateY(-2px);
    box-shadow: 0 0.25rem 0.75rem rgba(168, 85, 247, 0.2);
  }

  /* Footer */
  .chatbot-footer {
    padding: 1rem 1.5rem;
    background: white;
    border-top: 1px solid #E5E5E5;
  }

  .chatbot-input-container {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    background: #F5F5F5;
    border-radius: 2rem;
    padding: 0.5rem 1rem;
  }

  .chatbot-input {
    flex: 1;
    padding: 0.5rem;
    border: none;
    background: transparent;
    font-size: 0.95rem;
    outline: none;
  }

  .chatbot-input::placeholder {
    color: #999;
  }

  .send-button {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    border-radius: 50%;
  }

  .send-button:hover {
    background: linear-gradient(135deg, #5558e3 0%, #7c4de8 100%);
  }

  .send-button img {
    filter: brightness(0) invert(1);
  }

  .privacy-text {
    margin: 0.75rem 0 0 0;
    text-align: center;
    font-size: 0.8rem;
    color: #999;
  }

  @media (max-width: 768px) {
    .chatbot-container {
      bottom: 0.625rem;
      right: 1rem;
    }

    .chatbot-popup {
      right: 1rem;
      left: 1rem;
      max-width: none;
    }

    .chatbot-popup.fullscreen {
      right: 0;
      left: 0;
      border-radius: 0;
    }
  }
</style>

<script>
  // Chatbot 交互逻辑
  const toggleButton = document.getElementById('chatbot-toggle') as HTMLButtonElement;
  const closeButton = document.getElementById('chatbot-close');
  const fullscreenToggle = document.getElementById('fullscreen-toggle');
  const fullscreenIcon = document.getElementById('fullscreen-icon') as HTMLImageElement;
  const popup = document.getElementById('chatbot-popup');
  const input = document.getElementById('chatbot-input') as HTMLInputElement;
  const sendButton = document.getElementById('chatbot-send');
  const messagesContainer = document.getElementById('chatbot-messages');
  const chatbotIcon = document.getElementById('chatbot-icon') as HTMLImageElement;

  // 图标循环切换
  let currentIcon = 1;
  const icon1Src = new URL('../assets/AIIcons.svg', import.meta.url).href;
  const icon2Src = new URL('../assets/AIIcons2.svg', import.meta.url).href;
  const fullScreenSrc = new URL('../assets/chatbot/fullScreen.svg', import.meta.url).href;
  const shrinkScreenSrc = new URL('../assets/chatbot/shirnkScreen.svg', import.meta.url).href;
  const userAvatarSrc = new URL('../assets/chatbot/UserAvatar.png', import.meta.url).href;

  let isFullscreen = false;

  const cycleIcon = () => {
    currentIcon = currentIcon === 1 ? 2 : 1;
    
    if (currentIcon === 1) {
      chatbotIcon.src = icon1Src;
      toggleButton?.classList.remove('icon2');
    } else {
      chatbotIcon.src = icon2Src;
      toggleButton?.classList.add('icon2');
    }
  };

  // 每3秒切换一次图标
  setInterval(cycleIcon, 3000);

  // 切换弹窗显示
  toggleButton?.addEventListener('click', () => {
    popup?.classList.add('active');
    toggleButton?.classList.add('hidden');
    input?.focus();
  });

  // 关闭弹窗
  closeButton?.addEventListener('click', () => {
    popup?.classList.remove('active');
    popup?.classList.remove('fullscreen');
    toggleButton?.classList.remove('hidden');
    isFullscreen = false;
    if (fullscreenIcon) {
      fullscreenIcon.src = fullScreenSrc;
    }
  });

  // 全屏切换
  fullscreenToggle?.addEventListener('click', () => {
    isFullscreen = !isFullscreen;
    if (isFullscreen) {
      popup?.classList.add('fullscreen');
      if (fullscreenIcon) {
        fullscreenIcon.src = shrinkScreenSrc;
      }
    } else {
      popup?.classList.remove('fullscreen');
      if (fullscreenIcon) {
        fullscreenIcon.src = fullScreenSrc;
      }
    }
  });

  // 发送消息
  const sendMessage = () => {
    const message = input?.value.trim();
    if (!message) return;

    // 添加用户消息
    const userMessage = document.createElement('div');
    userMessage.className = 'message user-message';
    userMessage.innerHTML = `
      <img class="message-avatar" src="${userAvatarSrc}" alt="User" />
      <div class="message-content">
        <p>${message}</p>
      </div>
    `;
    messagesContainer?.appendChild(userMessage);

    // 清空输入框
    if (input) input.value = '';

    // 滚动到底部
    messagesContainer?.scrollTo({
      top: messagesContainer.scrollHeight,
      behavior: 'smooth'
    });

    // 模拟 AI 回复
    setTimeout(() => {
      const botMessage = document.createElement('div');
      botMessage.className = 'message bot-message';
      const aiAvatarSrc = new URL('../assets/chatbot/AIAvatar.png', import.meta.url).href;
      botMessage.innerHTML = `
        <img class="message-avatar" src="${aiAvatarSrc}" alt="AI" />
        <div class="message-content">
          <p>Thank you for your question! Our team will get back to you soon.</p>
        </div>
      `;
      messagesContainer?.appendChild(botMessage);
      
      messagesContainer?.scrollTo({
        top: messagesContainer.scrollHeight,
        behavior: 'smooth'
      });
    }, 1000);
  };

  sendButton?.addEventListener('click', sendMessage);

  input?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      sendMessage();
    }
  });
</script>
