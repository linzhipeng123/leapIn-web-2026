---
// Chatbot 组件 - 使用 LeapIn AI Agent SDK
// SDK 脚本在 Layout head 中加载
---

<script is:inline>
  // 初始化 SDK
  window.leapinAiAgentSDK({
    host: 'https://app.leapin-ai.com',
    tpl: '{{url}}/ai-agent',
    tips: 'Chat here to apply',
    secret: 'f0c31bf6-d230-4940-8327-1a55c5908d97',
    bottom: '120px',
    right: '40px',
    width: '100%',
    onVisibleChange: function (open) {
      if (open) {
        document.body.style['overflow'] = 'hidden';
      } else {
        document.body.style['overflow'] = '';
      }
    }
  });

  // SDK 加载后会动态注入样式，延迟一次性将 SDK 样式移到项目样式之前
  // 这样项目样式在 DOM 中后出现，优先级更高
  setTimeout(function() {
    var projectStyles = document.querySelectorAll('style[data-astro], link[rel="stylesheet"]');
    if (projectStyles.length === 0) return;

    var firstProjectStyle = projectStyles[0];

    // 查找 SDK 注入的样式（不含 data-astro 属性的 style 和 leapin CDN 的 link）
    document.querySelectorAll('head style:not([data-astro]):not([data-vite-dev-id]), head link[href*="leapin-ai.com"]').forEach(function(sdkStyle) {
      if (sdkStyle !== firstProjectStyle) {
        firstProjectStyle.parentNode.insertBefore(sdkStyle, firstProjectStyle);
      }
    });
  }, 2000);
</script>
