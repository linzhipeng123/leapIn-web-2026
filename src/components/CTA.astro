---
import SquareLayer from '../assets/platform/cta/square-layer.png';
import Button from './Button.astro';

const layers = [
    {img: SquareLayer, opacity: 0.2},
    {img: SquareLayer, opacity: 0.4},
    {img: SquareLayer, opacity: 0.6},
    {img: SquareLayer, opacity: 1},
]
---

<section class="cta-section" id="cta-section">
    <div class="cta-bg" id="cta-bg">
        {layers.map(({ img, opacity }, index) => (
            <img 
                class="partner-item"
                data-index={index}
                src={img.src} 
                alt={`Partner ${index + 1}`}
                style={{ opacity }}
            />
        ))}
    </div>
    <div class="container">
        <div class="cta-content">
            <h2 class="cta-title" data-i18n="platform.cta.title"></h2>
            <p class="cta-subtitle" data-i18n="platform.cta.subtitle"></p>
            <Button type="primary" text="platform.cta.button" className="cta-btn" />
        </div>
    </div>
</section>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();

	// 监听 footer-section 的滚动
	if (typeof window !== 'undefined') {
		const isMobile = () => window.innerWidth <= 768;
		
		if (!isMobile()) {
			const footerSection = document.querySelector('.footer-section');
			const ctaSection = document.getElementById('cta-section');
			const ctaBg = document.getElementById('cta-bg');
			const partnerItems = document.querySelectorAll('.partner-item');
			
			let hasScrolledDown = false;

			const observerCallback = (entries: IntersectionObserverEntry[]) => {
				entries.forEach(entry => {
					if (entry.isIntersecting && !hasScrolledDown) {
						hasScrolledDown = true;
						
						// 修改样式
						if (ctaSection) {
							// 先临时设置为 auto 来获取真实内容高度
							const originalMinHeight = ctaSection.style.minHeight;
							ctaSection.style.minHeight = 'auto';
							ctaSection.style.padding = '6rem 0';
							const contentHeight = ctaSection.offsetHeight;
							// 恢复原始值以便触发过渡
							ctaSection.style.minHeight = originalMinHeight || '100vh';
							
							// 使用 requestAnimationFrame 确保过渡生效
							requestAnimationFrame(() => {
								if (ctaSection) {
									ctaSection.style.minHeight = `${contentHeight}px`;
								}
							});
						}
						
						if (ctaBg) {
							ctaBg.style.gap = '2.875rem';
						}
						
						partnerItems.forEach(item => {
							(item as HTMLElement).style.maxWidth = '39.75rem';
						});
					}
				});
			};

			const observer = new IntersectionObserver(observerCallback, {
				threshold: 0.1,
				rootMargin: '0px'
			});

			if (footerSection) {
				observer.observe(footerSection);
			}
		}
	}
</script>

<style>
    .cta-section {
        min-height: 100vh;
        position: relative;
        padding-top: 4.75rem;
        box-sizing: border-box;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        transition: min-height 0.6s ease;
    }
    .cta-bg {
        position: absolute;
        width: 100%;
        height: calc(100% - 4.75rem);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        z-index: -1;
        gap: 4.75rem;
        transition: gap 0.6s ease;
    }

    .partner-item {
        max-width: 65.375rem;
        transition: all 0.6s ease, max-width 0.6s ease;
        animation: float 16s infinite, gap 16s infinite;
        position: relative;
    }

    .partner-item[data-index="0"] {
        animation: float 16s infinite, gap 16s infinite, zIndex0 16s infinite;
    }

    .partner-item[data-index="1"] {
        animation: float 16s infinite, gap 16s infinite, zIndex1 16s infinite;
    }

    .partner-item[data-index="2"] {
        animation: float 16s infinite, gap 16s infinite, zIndex2 16s infinite;
    }

    .partner-item[data-index="3"] {
        animation: float 16s infinite, gap 16s infinite, zIndex3 16s infinite;
    }

    @keyframes zIndex0 {
        0%, 100% { z-index: 1; }
        40% { z-index: 4; }
        50% { z-index: 4; }
        90% { z-index: 1; }
    }

    @keyframes zIndex1 {
        0%, 100% { z-index: 2; }
        40% { z-index: 3; }
        50% { z-index: 3; }
        90% { z-index: 2; }
    }

    @keyframes zIndex2 {
        0%, 100% { z-index: 3; }
        40% { z-index: 2; }
        50% { z-index: 2; }
        90% { z-index: 3; }
    }

    @keyframes zIndex3 {
        0%, 100% { z-index: 4; }
        40% { z-index: 1; }
        50% { z-index: 1; }
        90% { z-index: 4; }
    }

    @keyframes float {
        0% { transform: rotate(0deg) translateY(0); }
        40% { transform: rotate(-180deg) translateY(-4rem); }
        50% { transform: rotate(-180deg) translateY(-4rem); }
        90% { transform: rotate(-360deg) translateY(0); }
        100% { transform: rotate(-360deg) translateY(0); }
    }

    @keyframes gap {
        0%, 100% { margin-top: 0; margin-bottom: 0; }
        40% { margin-top: -4rem; margin-bottom: -4rem; }
        50% { margin-top: -4rem; margin-bottom: -4rem; }
        90% { margin-top: 0; margin-bottom: 0; }
    }

    .container {
    }
    .cta-content {
        align-items: center;
        justify-content: center;
        display: flex;
        flex-direction: column;
        max-width: 41rem;
        margin: 0 auto;
    }

    .cta-title {
        color: var(--grey-gray-60-base, #111827);
        text-align: center;
        font-size: 2.5rem;
        line-height: 124%; /* 49.6px */
        letter-spacing: -0.44px;
        margin-bottom: 0.5rem;
    }

    .cta-subtitle {
        color: var(--grey-gray-60-base, #111827);
        text-align: center;
        font-feature-settings: 'liga' off, 'clig' off;
        font-family: Inter;
        font-size: 1rem;
        line-height: 120%; /* 19.2px */
        margin-bottom: 3.75rem;
    }

    .cta-btn {
        margin: 0 auto;
    }
</style>