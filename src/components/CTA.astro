---
import SquareLayer from '../assets/platform/cta/square-layer.png';
import solutionsBg from '../assets/solutions/cta/bg_data.png';
import bgDot from '../assets/bg_dot.png';
import Button from './Button.astro';
import CardItem from './CardItem.astro';


interface Props {
	pageName: 'platform' | 'solutions' | 'industries';
}

const { pageName } = Astro.props;

const layers = [
    {img: SquareLayer, opacity: 0.2},
    {img: SquareLayer, opacity: 0.4},
    {img: SquareLayer, opacity: 0.6},
    {img: SquareLayer, opacity: 1},
]
---

<section class={`cta-section cta-${pageName}`} id="cta-section">
    {pageName === 'platform' ? <div class="cta-bg" id="cta-bg">
        {layers.map(({ img, opacity }, index) => (
            <img 
                class="partner-item"
                data-index={index}
                src={img.src}
                alt={`Partner ${index + 1}`}
                style={{ opacity }}
            />
        ))}
    </div> : null}
    <div class="container">
        <div class="cta-content" data-index={0}>
            <h2 class="cta-title" data-i18n={`${pageName}.cta.title`}></h2>
            <p class="cta-subtitle" data-i18n={`${pageName}.cta.subtitle`}></p>
            {
                pageName === 'platform' ? (
                    <div class="cta-items">
                        {
                            Array(3).fill(0).map((_, itemIndex) => (
                                <CardItem className="cta-card-item" text={`${pageName}.cta.items.${itemIndex}.description`} />
                            ))
                        }
                    </div>
                ) : null
            }
            <Button type="primary" text={`${pageName}.cta.button`} className="cta-btn" href="request" />
        </div>
    </div>
</section>

<script>
	import { loadTranslations } from '../scripts/i18n-loader';
	loadTranslations();

	// 监听 footer-section 的滚动
	if (typeof window !== 'undefined') {
		const isMobile = () => window.innerWidth <= 768;
		
		if (!isMobile()) {
			const ctaSection = document.getElementById('cta-section');
			const industriesCta = document.getElementById('industries-cta');
            let currentIndex = 0;
            // ----
            if (ctaSection) {
                const totalSlides = industriesCta ? 3 : 2; // 0-2 共3个状态

                const updateSlide = (index: number) => {
                    industriesCta?.setAttribute('active-slider', index.toString());
                    ctaSection.setAttribute('active-slider', index.toString());
                };

                updateSlide(0);

                let isAnimating = false;
                let scrollAccumulator = 0;
                let lastScrollDirection = 0;
                let animationTimeout: number | null = null;
                const SCROLL_THRESHOLD = 50;
                const ANIMATION_DURATION = 500;

                (industriesCta || ctaSection).addEventListener('wheel', (e) => {
                    const scrollDirection = e.deltaY > 0 ? 1 : -1;

                    const atStart = currentIndex === 0 && scrollDirection < 0;
                    const atEnd = currentIndex === totalSlides - 1 && scrollDirection > 0;

                    if (atStart || atEnd) {
                        scrollAccumulator = 0;
                        lastScrollDirection = 0;
                        return;
                    }

                    e.preventDefault();
                    e.stopPropagation();

                    if (lastScrollDirection !== 0 && scrollDirection !== lastScrollDirection) {
                        if (animationTimeout) {
                            clearTimeout(animationTimeout);
                            animationTimeout = null;
                        }
                        isAnimating = false;
                        scrollAccumulator = 0;
                    }

                    lastScrollDirection = scrollDirection;

                    if (isAnimating) {
                        scrollAccumulator += Math.abs(e.deltaY);
                        if (scrollAccumulator < SCROLL_THRESHOLD) {
                            return;
                        }
                    }

                    scrollAccumulator += Math.abs(e.deltaY);

                    if (scrollAccumulator < SCROLL_THRESHOLD) {
                        return;
                    }

                    scrollAccumulator = 0;
                    isAnimating = true;
                    
                    const targetIndex = scrollDirection > 0 ? currentIndex + 1 : currentIndex - 1;
                    currentIndex = targetIndex;
                    updateSlide(currentIndex);

                    if (animationTimeout) {
                        clearTimeout(animationTimeout);
                    }
                    animationTimeout = window.setTimeout(() => {
                        isAnimating = false;
                        scrollAccumulator = 0;
                        animationTimeout = null;
                    }, ANIMATION_DURATION);
                }, { passive: false });
            }
		}
	}
</script>

<style define:vars={{ 
  solutionsBg: `url(${solutionsBg.src})`,
  bgDot: `url(${bgDot.src})`,
}}>
    .cta-section {
        min-height: 100vh;
        position: relative;
        box-sizing: border-box;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        transition: min-height 0.6s ease;
    }
    .cta-section.cta-solutions {
		background-image: var(--solutionsBg);
        background-repeat: no-repeat;
        background-position: center;
        background-size: cover;
    }

	.cta-section.cta-solutions::before {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		top: 0;
		background: var(--AI-Gradient-Sky-Aurora-Medium, linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%));
		filter: blur(18.149999618530273px);
		z-index: -1;
	}

    .cta-industries .container {
        z-index: 1;
    }
	.cta-industries::before {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		top: 0;
		background-image: var(--bgDot);
		background-repeat: no-repeat;
		background-position: center;
		background-size: cover;
		z-index: 1;
	}
    .cta-industries::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        top: 0;
        margin: auto auto;
        width: var(--after-width, 62.25rem);
        height: var(--after-height, 62.25rem);
        border-radius: var(--after-border-radius, 50%);
        background: var(--AI-Gradient-Sky-Aurora-Medium, linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%));
        filter: blur(18.149999618530273px);
        transition: all 0.5s ease;
		z-index: 0;
    }
    .cta-industries[active-slider="2"]::after {
        width: 100%;
        height: 100%;
        border-radius: 0;
    }

	.cta-industries[active-slider="0"].cta-industries {
		position: absolute;
		opacity: 0;
        min-height: 0;
	}

	.cta-industries[active-slider="1"].cta-industries,
    .cta-section.cta-platform[active-slider="0"],
    .cta-section.cta-solutions[active-slider="0"] {
		opacity: 1;
        min-height: 100vh;
	}

	.cta-industries[active-slider="2"].cta-industries,
    .cta-section.cta-platform[active-slider="1"],
    .cta-section.cta-solutions[active-slider="1"] {
		opacity: 1;
        min-height: calc(-25.25rem + 100vh);
	}
    .cta-bg {
        position: absolute;
        width: 100%;
        height: calc(100% - 4.75rem);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        z-index: -1;
        gap: clamp(1.5rem, 3vw, 2.875rem);
        transition: gap 0.6s ease;
    }

    .partner-item {
        max-width: clamp(35rem, 60vw, 65.375rem);
        transition: all 0.6s cubic-bezier(0.68, 0, 0.33, 1);
        animation: float 16s ease-in-out infinite;
        position: relative;
    }

    .partner-item[data-index="0"] {
        opacity: 0.2;
        animation: float0 16s ease-in-out infinite;
    }

    .partner-item[data-index="1"] {
        opacity: 0.4;
        animation: float1 16s ease-in-out infinite;
    }

    .partner-item[data-index="2"] {
        opacity: 0.6;
        animation: float2 16s ease-in-out infinite;
    }

    .partner-item[data-index="3"] {
        opacity: 1;
        animation: float3 16s ease-in-out infinite;
    }

    /* 图层 0: 最大位移 */
    @keyframes float0 {
        0%, 30% { 
            transform: rotate(-180deg) translateY(0); 
            z-index: 1;
        }
        30%, 67.5% { 
            transform: rotate(0deg) translateY(clamp(-4rem, -5vw, -3rem)); 
            z-index: 4;
        }
        67.5%, 100% { 
            transform: rotate(-180deg) translateY(0); 
            z-index: 1;
        }
    }

    /* 图层 1: 中等位移 */
    @keyframes float1 {
        0%, 30% { 
            transform: rotate(-180deg) translateY(0); 
            z-index: 2;
        }
        30%, 67.5% { 
            transform: rotate(0deg) translateY(clamp(-2rem, -2.5vw, -1.5rem)); 
            z-index: 3;
        }
        67.5%, 100% { 
            transform: rotate(-180deg) translateY(0); 
            z-index: 2;
        }
    }

    /* 图层 2: 较小位移 */
    @keyframes float2 {
        0%, 30% { 
            transform: rotate(-180deg) translateY(0); 
            z-index: 3;
        }
        30%, 67.5% { 
            transform: rotate(0deg) translateY(clamp(1.5rem, 2.5vw, 2.5rem)); 
            z-index: 2;
        }
        67.5%, 100% { 
            transform: rotate(-180deg) translateY(0); 
            z-index: 3;
        }
    }

    /* 图层 3: 最小位移 */
    @keyframes float3 {
        0%, 30% { 
            transform: rotate(-180deg) translateY(0); 
            z-index: 4;
        }
        30%, 67.5% { 
            transform: rotate(0deg) translateY(clamp(3rem, 5vw, 4rem)); 
            z-index: 1;
        }
        67.5%, 100% { 
            transform: rotate(-180deg) translateY(0); 
            z-index: 4;
        }
    }

    .container {
        position: relative;
    }
    .cta-content {
        align-items: center;
        justify-content: center;
        display: flex;
        flex-direction: column;
        margin: 0 auto;
    }

    .cta-title {
        color: var(--grey-gray-60-base, #111827);
        text-align: center;
        font-size: 2.5rem;
        line-height: 124%; /* 49.6px */
        letter-spacing: -0.44px;
        margin-bottom: 0.5rem;
    }

    .cta-subtitle {
        color: var(--grey-gray-60-base, #111827);
        text-align: center;
        font-feature-settings: 'liga' off, 'clig' off;
        font-family: Inter;
        font-family: "PingFang SC";
        font-size: 1rem;
        line-height: 150%; /* 19.2px */
        max-width: 41rem;
    }
    
    :global(.cta-items) {
        display: flex;
        gap: 0.5rem;
        margin-top: 1.5rem;
    }
    
    :global(.card-item.cta-card-item) {
        background: var(--Grey-Gray-10, rgba(17, 24, 39, 0.05));
    }

    :global(.cta-card-item .card-item-description) {
        color: var(--grey-gray-60-base, #111827);
    }

    :global(.cta-content .cta-btn) {
        margin: 0 auto;
        margin-top: 3.75rem;
    }

	@media (max-width: 768px) {
        .cta-section {
            min-height: auto;
            padding: 8.25rem 1rem;
        }
        .cta-industries::after {
            width: 100%;
            height: 100%;
            border-radius: 0;
        }
        .partner-item {
            max-width: 100%;
        }
    }
</style>