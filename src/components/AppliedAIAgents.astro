---
import bgDot from '../assets/platform/AppliedAIAgents/bg_dot.png';
import AICoachUI from '../assets/platform/AppliedAIAgents/AICoachUI.png';
---

<section class="applied-ai-agents" id="applied-ai-agents">
  <div class="container">
    <div class="ai-agents-header">
      <h2 class="section-title" data-i18n="platform.platformFeatures.title">Applied AI Agents</h2>
    </div>

    <div class="ai-agents-content">
      <div class="ai-agents-slider" id="ai-agents-slider">
        <div class="feature-slide" data-index={0}>
          <h3>11111</h3>
        </div>
        <div class="feature-slide" data-index={1}>
          <div class="feature-ai-coach"></div>
        </div>
        <div class="feature-slide" data-index={2}>
          <h3>333333</h3>
        </div>
      </div>
    </div>
  </div>
</section>

<style define:vars={{ 
  bgDot: `url(${bgDot.src})`,
  aiCoachUI: `url(${AICoachUI.src})`
}}>
  .applied-ai-agents {
    box-sizing: border-box;
    overflow: hidden;
    background: #FFF;
    display: flex;
    align-items: center;
    position: relative;
  }

  .applied-ai-agents::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    top: 0;
		background-image: var(--bgDot);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
  }
  .applied-ai-agents::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    top: 0;
    margin: auto auto;
		width: 542px;
    height: 542px;
    border-radius: 542px;
    background: var(--AI-Gradient-Sky-Aurora-Medium, linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%));
    filter: blur(18.149999618530273px);
  }


  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-wrap: wrap;
    z-index: 1;
  }

  .ai-agents-header {
    margin-top: 6.25rem;
    margin-bottom: 3rem;
    margin-left: auto;
    margin-right: auto;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    line-height: 124%;
    letter-spacing: -1.1%;
    font-family: DM Serif Display;
  }

  .section-subtitle {
    font-size: 1rem;
    line-height: 1.5;
  }

  .ai-agents-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.625rem;
    width: 100%;
    flex: 1;
  }

  .ai-agents-slider {
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1;
    aspect-ratio: 16 / 10;
    border-radius: 16px;
    overflow: hidden;
  }

  .feature-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
  }

  .feature-slide[data-active="true"] {
    opacity: 1;
  }

  .feature-slide[data-active="false"] {
    display: none;
  }

  .feature-ai-coach {
		background-image: var(--aiCoachUI);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1rem;
    }

    .applied-ai-agents {
      padding: 1.5rem 0;
      height: fit-content;
    }

    .section-title {
      font-size: 1.5rem;
    }
    .section-subtitle {
      font-size: 0.8125rem;
    }

    .ai-agents-content {
      gap: 1.5rem;
    }

    .ai-agents-slider {
      height: auto;
      aspect-ratio: unset;
      position: static;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .feature-slide {
      position: static;
      opacity: 1;
      height: auto;
      background: #111827;
      border-radius: 1rem;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .feature-slide[data-active="false"] {
      display: flex;
    }
  }
</style>

<script>
  import { loadTranslations } from '../scripts/i18n-loader';
  loadTranslations();

  const darkBox = document.getElementById('ai-agents-content');
  const slider = document.getElementById('ai-agents-slider');
  
  if (darkBox && slider) {
    let currentIndex = 0;
    const slides = slider.querySelectorAll('.feature-slide');
    const totalSlides = slides.length;

    const updateSlide = (index: number) => {
      slides.forEach((slide, i) => {
        slide.setAttribute('data-active', i === index ? 'true' : 'false');
      });
    };

    // 初始化第一个
    updateSlide(0);

    // 监听滚动
    let isScrolling = false;
    darkBox.addEventListener('wheel', (e) => {
      if (isScrolling) return;
      
      e.preventDefault();
      isScrolling = true;

      if (e.deltaY > 0) {
        // 向下滚动
        currentIndex = (currentIndex + 1) % totalSlides;
      } else {
        // 向上滚动
        currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
      }

      updateSlide(currentIndex);

      setTimeout(() => {
        isScrolling = false;
      }, 500);
    }, { passive: false });
  }
</script>
