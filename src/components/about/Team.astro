---
import bgDot from '../../assets/bg_dot.png';
import bgDotDark from '../../assets/bg_dot_dark.png';
import img1 from '../../assets/about/1.png';
import img2 from '../../assets/about/2.png';
import img3 from '../../assets/about/3.png';
import img4 from '../../assets/about/4.png';
import img5 from '../../assets/about/5.png';
import img6 from '../../assets/about/6.png';
import img7 from '../../assets/about/7.png';

const imgs = [img2, img6, img4, img5, img7];
---

<section class="section-container team-section-inner" id="team-section-inner">
    <!-- <div class="bg-earth"> -->
    <div class="container" id="team-section-inner-container">
        <div class="team-slider">
            <h2 class="team-title" data-i18n="about.team.title"></h2>
            <h2 class="team-card-title" data-i18n="about.team.card.title"></h2>
            <div class="team-slider-content">
                <div class="team-card-wrap the-team-card" data-index={0}>
                    <h3 class="the-team-card-title" data-i18n="about.team.card.title"></h3>
                    <div class="the-team-card-description" data-i18n="about.team.card.description"></div>
                </div>
                {
                    imgs.map((img,index) => (
                        <div class="team-card-wrap" data-index={index + 1}>
                            {index === 2 || index === 4 ? <div class={`team-card-info team-card-info-${index}`} data-i18n={`about.team.card.cardInfo${index}`}></div> : null}
                            <img src={img.src} alt="" />
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style define:vars={{ 
  bgDot: `url(${bgDot.src})`,
//   bgDotDark: `url(${bgDotDark.src})`,
}}>
    .section-container {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        position: relative;
        overflow: hidden;
    }

    .section-container[active-slider="0"] {
        background: var(--grey-gray-60-base, #111827);
    }

    .section-container[active-slider="0"]::after {
        background: none
    }

    .team-section-inner::before {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-image: var(--bgDot);
        background-repeat: no-repeat;
        background-position: center;
        background-size: contain;
        z-index: 1;
    }

    .section-container::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        top: 0;
        width: 100%;
        height: 100%;
        border-radius: 0;
        background: var(--AI-Gradient-Sky-Aurora-Medium, linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%));
        filter: blur(18.149999618530273px);
        z-index: 0;
    }

    .container {
        max-width: var(--max-width);
        margin: 0 auto;
        min-height: calc(100vh - 4.75rem);
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        z-index: 1;
    }

    .team-section-inner[active-slider="1"],
    .team-section-inner[active-slider="2"],
    .team-section-inner[active-slider="3"],
    .team-section-inner[active-slider="4"] {
        overflow: hidden;
    }

    .team-slider {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.375rem;
        width: 100%;
        flex: 1;
        flex-wrap: wrap;
        position: relative;
    }

    .team-slider-content {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1;
        flex-wrap: wrap;
        position: absolute;
        width: 81.25rem;
        min-height: 100vh;
        padding-top: 4.75rem;
        transition: all 0.5s ease;
    }
    .team-title {
        color: #FFF;
        font-size: 2.5rem;
        line-height: 124%; /* 49.6px */
        letter-spacing: -0.44px;
        transition: all 0.5s ease;
    }

    .team-card-title {
        color: var(--Neutrals-White-00, #FFF);
        text-align: center;
        font-size: 12.5rem;
        font-style: normal;
        font-weight: 400;
        line-height: 124%; /* 248px */
        letter-spacing: -2.2px;
        position: absolute;
        opacity: 0.4;
        margin-top: -10rem;
        transition: all 0.5s ease;
    }

    .the-team-card {
        display: flex;
        width: 35rem;
        padding: 2.25rem 1.5rem;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        gap: 3.125rem;
        border-radius: 0.75rem;
        border: 1px solid var(--Neutrals-White-00, #FFF);
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
        z-index: 1;
    }

    .the-team-card-title {
        font-size: 2.5rem;
        font-weight: 600;
        line-height: 120%;
        background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .the-team-card-title.en {
        font-style: italic;
    }

    .the-team-card-description {
        color: var(--grey-gray-60-base, #111827);
        font-size: 1rem;
        line-height: 150%;
    }

    .team-card-wrap {
        transition: all 0.8s ease;
        position: absolute;
        border-radius: 1rem;
        overflow: hidden;
    }

    .team-card-wrap::before {
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        bottom: 0;
        width: 100%;
        height: 11.25rem;
        content: '';
        /* z-index: 1; */
        display: block;
        background: linear-gradient(-14deg, rgba(255, 255, 255, 0.00) 57.16%, #5386FA 98.88%);
    }

    .team-card-info {
        position: absolute;
        color: var(--azure-azure-50-brand, #2257BF);
        font-weight: 600;
        line-height: 120%;
        white-space: pre-wrap;
    }

    .team-card-info-2 {
        left: 1.25rem;
        top: 1.5rem;
        font-size: 0.875rem;
    }

    .team-card-info-4 {
        left: 1.25rem;
        top: 1.5rem;
        font-size: 1rem;
    }
    .team-card-wrap[data-index="1"] {
        width: 10.625rem;
    }
    .team-card-wrap[data-index="2"] {
        width: 16.375rem;
    }
    .team-card-wrap[data-index="3"] {
        width: 15rem;
    }
    .team-card-wrap[data-index="4"] {
        width: 11.875rem;
    }
    .team-card-wrap[data-index="5"] {
        width: 27.375rem;
    }

    /* data-index="0" - 初始状态 */
    .team-slider[data-index="0"] .team-slider-content, 
    .team-slider[data-index="0"] .team-card-title {
        transform: translateY(100vh);
    }
    .team-slider[data-index="1"] .team-title,
    .team-slider[data-index="2"] .team-title {
        transform: translateY(-100vh);
    }

    .team-slider[data-index="1"] .team-slider-content,
    .team-slider[data-index="2"] .team-slider-content {
        transform: translateY(0);
    }
    .team-slider[data-index="0"] .team-card-wrap[data-index="0"] .the-team-card-description {
        color: #FFF;
    }

    .team-slider[data-index="0"] .team-card-wrap[data-index="0"] {
        transform: translateY(-45vh) rotate(-45deg);
        width: 23.5rem;
    }

    .team-slider[data-index="1"] .team-card-wrap[data-index="0"] {
        transform: translateX(20%) translateY(-15vh) rotate(0)
    }

    .team-slider[data-index="1"] .team-card-wrap[data-index="1"] {
        transform: translateX(-160%) translateY(40vh) rotate(-6deg);
    }

    .team-slider[data-index="1"] .team-card-wrap[data-index="2"] {
        transform: translateX(-35%) translateY(10vh) rotate(8deg);
    }

    .team-slider[data-index="1"] .team-card-wrap[data-index="3"] {
        transform: translateX(-160%) translateY(-10vh) rotate(-8deg);
    }
    
    .team-slider[data-index="1"] .team-card-wrap[data-index="4"] {
        right: 6rem;
        transform: translateY(2vh) rotate(-6deg);
    }

    .team-slider[data-index="1"] .team-card-wrap[data-index="5"] {
        transform: translateX(70%) translateY(40vh) rotate(8deg);
    }

    .team-slider[data-index="2"] .team-card-wrap[data-index="0"] {
        transform: translateX(20%) translateY(-100vh) rotate(0);
    }

    .team-slider[data-index="2"] .team-card-wrap[data-index="1"] {
        /* left: 5rem; */
        transform: translateX(-260%) translateY(-15vh) rotate(-6deg);
    }

    .team-slider[data-index="2"] .team-card-wrap[data-index="2"] {
        transform: translateY(-25vh) rotate(8deg);
    }

    .team-slider[data-index="2"] .team-card-wrap[data-index="3"] {
        transform: translateX(-115%) translateY(20vh) rotate(-8deg);
    }

    .team-slider[data-index="2"] .team-card-wrap[data-index="4"] {
        right: 2rem;
        transform: translateY(-18vh) rotate(-6deg);
    }

    .team-slider[data-index="2"] .team-card-wrap[data-index="5"] {
        transform: translateX(50%) translateY(20vh) rotate(8deg);
    }
    
    @media (max-width: 768px) {
        .section-container {
            padding: 2.25rem 0;
        }
        .container {
            padding: 0 1rem;
        }
        .team-slider {
            gap: 2.875rem;
        }

        .section-container[active-slider="0"] {
            background: none;
        }

        .section-container::before {
            background-size: 200%;
            background-position: top right;
        }

        .section-container[active-slider="0"]::after {
            background: var(--AI-Gradient-Sky-Aurora-Medium, linear-gradient(90deg, #FBE5CF 0%, #AFC9FF 100%));
        }

        .team-title {
            position: relative;
            font-size: 1.5rem;
            line-height: 120%;
            text-align: center;
            font-weight: 600;
            opacity: 1;
            color: var(--grey-gray-60-base, #111827);
            word-break: keep-all;
            transform: none !important;
        }

        .team-card-title {
            margin-top: 0;
            display: none;
            transform: none;
        }
        .team-card-wrap.the-team-card {
            padding: 1.5rem 1.25rem;
            width: 100% !important;
            margin-bottom: 3rem !important;
        }
        
        .the-team-card-title {
            font-size: 1.5rem;
        }

        .the-team-card-description {
            color: var(--grey-gray-60-base, #111827) !important;
            font-size: 0.8125rem;
        }

        .team-slider[data-index="0"] .team-slider-content, 
        .team-slider[data-index="0"] .team-card-title {
            transform: none;
        }
        .team-slider-content {
            gap: 1rem;
            padding: 0;
            padding-bottom: 7rem;
            position: relative;
            width: 100%;
            align-items: normal;
        }
		.team-card-wrap {
			transform: none;
            /* left: 0 !important; */
            /* top: 0 !important; */
            /* right: 0 !important; */
            position: relative;
            gap: 0;
		}

        .team-card-wrap[data-index="0"] {
            transform: none !important;
            transform: translateX(100%) translateY(100%) rotate(-30deg) !important;
        }

        .team-card-wrap[data-index="1"] {
            margin: 0;
            right: 0;
            transform: translateX(-100%) translateY(100%) rotate(30deg) !important;
        }

        .team-card-wrap[data-index="2"] {
            transform: translateX(70%) translateY(50%) rotate(-45deg) !important;
        }

        .team-card-wrap[data-index="3"] {
            transform: translateX(-70%) translateY(40%) rotate(-30deg) !important;
        }

        .team-card-wrap[data-index="4"] {
            left: 0;
            bottom: none;
            position: absolute;
            transform: translateX(100%) translateY(190%) rotate(-30deg) !important;
        }
        
        .team-card-wrap[data-index="5"] {
            right: 0;
            transform: translateX(100%) translateY(-80%) rotate(15deg) !important;
        }

        .team-card-wrap[data-index="6"] {
            transform: translateX(-100%) translateY(-100%) rotate(-15deg) !important;
        }

        .team-card-wrap[data-index="7"] {
            position: absolute;
            width: 21rem;
            transform: translateX(100%) translateY(100%) rotate(30deg) !important;
        }

        .team-card-wrap-title {
            font-size: 0.8125rem;
            line-height: 133.333%;
            margin-bottom: 0;
            transform: none;
        }

        .team-section-inner.in-view .team-card-wrap[data-index="0"] {
            transform: translateX(0) translateY(0) !important;
        }

        .team-section-inner.in-view .team-card-wrap[data-index="1"] {
            margin: 0;
            right: 0;
            transform: translateX(0) translateY(0) !important;
        }

        .team-section-inner.in-view .team-card-wrap[data-index="2"] {
            transform: translateX(-70%) translateY(-50%) !important;
        }

       .team-section-inner.in-view  .team-card-wrap[data-index="3"] {
            transform: translateX(70%) translateY(-140%) !important;
        }

        .team-section-inner.in-view .team-card-wrap[data-index="4"] {
            left: 0;
            bottom: none;
            position: absolute;
            transform: translateX(0%) translateY(150%) !important;
        }
        
        .team-section-inner.in-view .team-card-wrap[data-index="5"] {
            right: 0;
            transform: translateX(50%) translateY(-20%) !important;
        }

        .team-section-inner.in-view .team-card-wrap[data-index="6"] {
            transform: translateX(-20%) translateY(-90%) !important;
        }

       .team-section-inner.in-view .team-card-wrap[data-index="7"] {
            bottom: 0;
            transform: translateX(0) translateY(0%) !important;
        }
	}
</style>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  import { inView } from '../../utils/inView';
  import { createSectionScroll } from '../../utils/sectionScroll';
  loadTranslations();

  // 为英文标题添加斜体样式
  const currentLang = localStorage.getItem('language') || 'en';
  if (currentLang === 'en') {
    const teamCardTitles = document.querySelectorAll('.the-team-card-title');
    teamCardTitles.forEach(title => {
      title.classList.add('en');
    });
  }

  const section = document.getElementById('team-section-inner');
  const slider = document.getElementById('team-section-inner-container');
  
  const isMobile = window.matchMedia('(max-width: 768px)').matches;
  
  // 使用通用滚动控制器
  if (section && slider && !isMobile) {
    const slides = slider.querySelectorAll('.team-slider');
    
    createSectionScroll({
      sectionId: 'team-section-inner',
      totalSlides: 3,
      scrollThreshold: 100,
      animationDuration: 800,
      onSlideUpdate: (index) => {
        section.setAttribute('active-slider', index.toString());
        slides.forEach((slide) => {
          slide.setAttribute('data-active', 'true');
          slide.setAttribute('data-index', index.toString());
        });
      },
    });
  }
  
  // Intersection Observer 监听 features 是否在可视区域内
  if (isMobile && typeof window !== 'undefined') {
    inView({id: "team-section-inner", threshold: 0.2})
  }
</script>