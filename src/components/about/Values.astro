---
import ValuesCard from './ValuesCard.astro';
import bgDot from '../../assets/bg_dot_dark.png';

const cards = [
    {
        detailList: [
            { title: "Respect", info: "RespectInfo" },
            { title: "Empathy", info: "EmpathyInfo" },
            { title: "ContinuousGrowth", info: "ContinuousGrowthInfo" },
        ]
    },
    {
        detailList: [
            { title: "CustomerFirst", info: "CustomerFirstInfo" },
            { title: "PromptResponse", info: "PromptResponseInfo" },
            { title: "StriveForPerfection", info: "StriveForPerfectionInfo" },
        ]
    },
    {
        detailList: [
            { info: "AlForGood" },
        ],
        btn: {
            text: "btn", href: "https://www.baai.ac.cn/"
        }
    },
    {
        detailList: [
            { title: "Passion", info: "PassionInfo" },
            { title: "BeBold", info: "BeBoldInfo" },
        ]
    },
];
---

<section class="section-container values-section-inner" id="values-section-inner">
    <!-- <div class="bg-earth"> -->
    <div class="container" id="values-section-inner-container">
        <div class="values-slider" data-index={0}>
            <h2 class="covered-title" data-i18n="industries.covered.title"></h2>
            <div class="values-slider-content">
                {
                    cards.map((cardItem,index) => (
                        <div class="values-card-wrap" data-index={index}>
                            <ValuesCard {...cardItem} cardIndex={index} />
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style define:vars={{ 
  bgDot: `url(${bgDot.src})`,
}}>
    .section-container {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        position: relative;
        background: var(--grey-gray-60-base, #111827);
        overflow: hidden;
    }

    .values-section-inner::before {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-image: var(--bgDot);
        background-repeat: no-repeat;
        background-position: center;
        background-size: contain;
        transition: all 0.8s ease;
        z-index: 0;
    }

    .container {
        max-width: var(--max-width);
        margin: 0 auto;
        min-height: calc(100vh - 4.75rem);
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        z-index: 1;
    }

    .values-section-inner[active-slider="1"],
    .values-section-inner[active-slider="2"],
    .values-section-inner[active-slider="3"],
    .values-section-inner[active-slider="4"] {
        overflow: hidden;
    }

    .values-slider {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.375rem;
        width: 100%;
        flex: 1;
        flex-wrap: wrap;
        position: relative;
    }

    .values-slider-content {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1;
        flex-wrap: wrap;
        position: relative;
        max-width: 81.25rem;
        min-height: 100vh;
        padding-top: 4.75rem;
    }
    .covered-title {
        color: var(--grey-gray-60-base, #111827);
        text-align: center;
        font-size: 6.25rem;
        line-height: 124%;
        width: 100%;
        margin: 0 auto;
        transition: all 0.8s ease;
        position: absolute;
        color: var(--Neutrals-White-00, #FFF);
        font-weight: 600;
        letter-spacing: -1.1px;
        opacity: 0.1;
    }

    .values-card-wrap {
        transition: all 0.8s ease;
        position: absolute;
        margin-top: 2.1875rem;
    }

    /* pre */
    .values-slider-pre.values-slider[data-index="0"] .values-card-wrap[data-index="0"] {
        transform: translateX(1000px) translateY(30vh) rotate(30deg);
    }

    .values-slider-pre.values-slider[data-index="0"] .values-card-wrap[data-index="1"],
    .values-slider[data-index="0"] .values-card-wrap[data-index="1"] {
        transform: translateX(1000px) translateY(40vh) rotate(30deg);
    }

    .values-slider-pre.values-slider[data-index="0"] .values-card-wrap[data-index="2"],
    .values-slider[data-index="0"] .values-card-wrap[data-index="2"],
    .values-slider[data-index="1"] .values-card-wrap[data-index="2"]{
        transform: translateX(1000px) translateY(50vh) rotate(45deg);
    }

    .values-slider-pre.values-slider[data-index="0"] .values-card-wrap[data-index="3"],
    .values-slider[data-index="0"] .values-card-wrap[data-index="3"],
    .values-slider[data-index="1"] .values-card-wrap[data-index="3"],
    .values-slider[data-index="2"] .values-card-wrap[data-index="3"] {
        transform: translateX(1000px) translateY(60vh) rotate(45deg);
    }
    /* pre */


    /* data-index="0" - 初始状态 */
    .values-slider[data-index="0"] .values-card-wrap[data-index="0"],
    .values-slider[data-index="1"] .values-card-wrap[data-index="1"],
    .values-slider[data-index="2"] .values-card-wrap[data-index="2"],
    .values-slider[data-index="3"] .values-card-wrap[data-index="3"] {
        margin: 0 auto;
        transform: translateX(0) translateY(0) rotate(0deg);
    }

    .values-slider[data-index="1"] .values-card-wrap[data-index="0"],
    .values-slider[data-index="2"] .values-card-wrap[data-index="0"],
    .values-slider[data-index="3"] .values-card-wrap[data-index="2"] {
        margin: 0;
        transform: translateX(-150%) translateY(0) rotate(0deg);
    }
    .values-slider[data-index="3"] .values-card-wrap[data-index="0"] {
        margin: 0;
        transform: translateX(-1500px) translateY(0) rotate(0deg);
    }

    .values-slider[data-index="2"] .values-card-wrap[data-index="1"],
    .values-slider[data-index="3"] .values-card-wrap[data-index="1"] {
        margin: 0;
        transform: translateX(150%) translateY(0) rotate(0deg);
    }
    
    @media (max-width: 768px) {
        .section-container {
            padding: 2.25rem 0;
        }
        .container {
            padding: 0 1rem;
        }
        .values-slider {
            gap: 1.5rem;
        }

        .covered-title {
            position: relative;
            font-size: 1.5rem;
            line-height: 120%;
            text-align: center;
            font-weight: 600;
            opacity: 1;
        }
        .values-slider-content {
            gap: 1rem;
            flex-direction: column;
            padding: 0;
        }
		.values-card-wrap {
			transform: none !important;
            left: 0 !important;
            top: 0 !important;
            right: 0 !important;
            position: relative !important;
            margin: 0 !important;
            width: 100%;
            gap: 0.75rem;
		}

        .values-card-wrap-title {
            font-size: 0.8125rem;
            line-height: 133.333%;
            margin-bottom: 0;
            transform: none;
        }
	}
</style>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  loadTranslations();

  const section = document.getElementById('values-section-inner');
  const slider = document.getElementById('values-section-inner-container');
  
  const isMobile = window.matchMedia('(max-width: 768px)').matches;
  if (section && slider && !isMobile) {
    let currentIndex = 0;
    const slides = slider.querySelectorAll('.values-slider');
    const totalSlides = 4; // 0-3 共4个状态

    const updateSlide = (index: number) => {
        section.setAttribute('active-slider', index.toString())
      slides.forEach((slide) => {
        slide.setAttribute('data-active', 'true');
        slide.setAttribute('data-index', index.toString());
      });
    };

    updateSlide(0);

    let isAnimating = false;
    let scrollAccumulator = 0;
    let lastScrollDirection = 0;
    let animationTimeout: number | null = null;
    const SCROLL_THRESHOLD = 50;
    const ANIMATION_DURATION = 800;

    section.addEventListener('wheel', (e) => {
      const scrollDirection = e.deltaY > 0 ? 1 : -1;

      const atStart = currentIndex === 0 && scrollDirection < 0;
      const atEnd = currentIndex === totalSlides - 1 && scrollDirection > 0;

      if (atStart || atEnd) {
        scrollAccumulator = 0;
        lastScrollDirection = 0;
        return;
      }

      e.preventDefault();
      e.stopPropagation();

      if (lastScrollDirection !== 0 && scrollDirection !== lastScrollDirection) {
        if (animationTimeout) {
          clearTimeout(animationTimeout);
          animationTimeout = null;
        }
        isAnimating = false;
        scrollAccumulator = 0;
      }

      lastScrollDirection = scrollDirection;

      if (isAnimating) {
        scrollAccumulator += Math.abs(e.deltaY);
        if (scrollAccumulator < SCROLL_THRESHOLD) {
          return;
        }
      }

      scrollAccumulator += Math.abs(e.deltaY);

      if (scrollAccumulator < SCROLL_THRESHOLD) {
        return;
      }

      scrollAccumulator = 0;
      isAnimating = true;

      const targetIndex = scrollDirection > 0 ? currentIndex + 1 : currentIndex - 1;
      currentIndex = targetIndex;
      updateSlide(currentIndex);

      if (animationTimeout) {
        clearTimeout(animationTimeout);
      }
      animationTimeout = window.setTimeout(() => {
        isAnimating = false;
        scrollAccumulator = 0;
        animationTimeout = null;
      }, ANIMATION_DURATION);
    }, { passive: false });
  }
</script>