---
import position from '../../assets/about/position.png';
---

<section class="position">
  <div class="container">
    <h2 class="position-title" data-i18n="about.position.title"></h2>
    <p class="position-subtitle" data-i18n="about.position.subtitle"></p>
    <div class="position-content">
        <img class="position-img" src={position.src} alt="">
        <div class="open-positions">
            <div class="open-positions-title" data-i18n="about.position.OpenPositions"></div>
            <div class="position-list"></div>
        </div>
    </div>
  </div>
</section>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  loadTranslations();

  // 获取职位列表
  async function fetchPositions() {
    try {
      // 使用本地 API 路由避免 CORS 问题
      const base = import.meta.env.BASE_URL || '';
      const url = `${base}api/positions`;
      
      const response = await fetch(url, {
        method: 'GET',
        headers: {
          'accept': 'application/json',
        }
      });
      
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      
      const data = await response.json();
      
      // 根据实际接口返回的数据结构: { code: 0, data: { pageData: [...] } }
      if (data.code === 0 && data.data && data.data.pageData) {
        return data.data.pageData;
      }
      
      return [];
    } catch (error) {
      console.error('Failed to fetch positions:', error);
      // 返回空数组，避免页面崩溃
      return [];
    }
  }

  function renderPositions(positions: any[]) {
    const positionList = document.querySelector('.position-list');
    if (!positionList) return;

    const currentLang = localStorage.getItem('language') || 'en';
    
    // 如果没有职位数据，显示提示信息
    if (positions.length === 0) {
      positionList.innerHTML = `
        <div style="padding: 2rem; text-align: center; color: #6B7280;">
          <p data-i18n="about.position.noPositions">暂无职位</p>
        </div>
      `;
      loadTranslations();
      return;
    }

    positionList.innerHTML = positions.map(position => {
      // 接口返回的字段: { id, title, ... }
      // 目前只有英文标题，中文暂时也使用 title
      const positionName = position.title;
      const detailUrl = `https://app.unfolds.ai/company/client/AHIJRH/detail/${position.id}`;
      
      return `
        <div class="position-item">
          <div class="position-name">${positionName}</div>
          <a href="${detailUrl}" target="_blank" rel="noopener noreferrer" class="button button-primary position-apply-btn">
            <span class="button-text" data-i18n="about.position.apply">申请</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <mask id="mask0_apply_${position.id}" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="24" height="24">
                <rect width="24" height="24" fill="#D9D9D9"/>
              </mask>
              <g mask="url(#mask0_apply_${position.id})">
                <path d="M18.175 12.9998H3C2.71667 12.9998 2.47917 12.904 2.2875 12.7123C2.09583 12.5206 2 12.2831 2 11.9998C2 11.7165 2.09583 11.479 2.2875 11.2873C2.47917 11.0956 2.71667 10.9998 3 10.9998H18.175L14.3 7.0998C14.1167 6.91647 14.0208 6.6873 14.0125 6.4123C14.0042 6.1373 14.1 5.8998 14.3 5.6998C14.4833 5.51647 14.7167 5.4248 15 5.4248C15.2833 5.4248 15.5167 5.51647 15.7 5.6998L21.3 11.2998C21.4 11.3998 21.4708 11.5081 21.5125 11.6248C21.5542 11.7415 21.575 11.8665 21.575 11.9998C21.575 12.1331 21.5542 12.2581 21.5125 12.3748C21.4708 12.4915 21.4 12.5998 21.3 12.6998L15.7 18.2998C15.5167 18.4831 15.2875 18.5748 15.0125 18.5748C14.7375 18.5748 14.5 18.4831 14.3 18.2998C14.1 18.0998 14 17.8623 14 17.5873C14 17.3123 14.1 17.0748 14.3 16.8748L18.175 12.9998Z" fill="white"/>
              </g>
            </svg>
          </a>
        </div>
      `;
    }).join('');

    // 重新加载翻译
    loadTranslations();
  }

  // 初始化：从接口获取数据
  fetchPositions().then(positions => {
    renderPositions(positions);
  });
</script>

<style define:vars={{
  position: position.src,
}}>
  .position {
    width: 100%;
    position: relative;
    padding: 6rem 0;
    background: #FFFFFF;
    overflow: hidden;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem;
  }

  .position-title {
    font-size: 2.5rem;
    color: var(--grey-gray-60-base, #111827);
    line-height: 124%; /* 49.6px */
    letter-spacing: -0.44px;
    margin-bottom: 0.5rem;
    margin-top: 1.25rem;
  }

  .position-subtitle {
    font-size: 0.875rem;
    color: var(--grey-gray-60-base, #111827);
    line-height: 124%; /* 17.36px */
    letter-spacing: -0.154px;
    margin-bottom: 2.375rem;
  }

  .position-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .position-img {
    max-width: 33.5rem;
    flex: 1;
  }

  .open-positions {
    max-width: 42rem;
    display: flex;
    flex-direction: column;
    flex-basis: 50%;
  }

  .open-positions-title {
    padding: 1rem 1.5rem;
    color: var(--grey-gray-60-base, #111827);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 120%;
    margin-bottom: 1.5rem;
  }

  .position-list {
    display: flex;
    flex-direction: column;
  }

  :global(.position-item) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    background: #FFFFFF;
    border-bottom: 1px solid rgba(17, 24, 39, 0.1);
    transition: all 0.3s ease;
    gap: 1rem;
  }

  :global(.position-item:hover) {
    border-color: rgba(83, 134, 250, 0.3);
    box-shadow: 0 2px 8px rgba(83, 134, 250, 0.1);
  }

  :global(.position-name) {
    color: var(--grey-gray-60-base, #111827);
    font-size: 1.125rem;
    font-weight: 500;
    flex: 1;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  :global(.position-apply-btn) {
    text-align: center;
    display: flex;
    gap: 0rem;
    transition: all 0.3s;
    text-decoration: none;
    cursor: pointer;
    min-width: 6.625rem;
    padding: 0.5rem 1rem;
    border-radius: 0.75rem;
    width: fit-content;
    justify-content: center;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
  }

  :global(.position-apply-btn:hover) {
    gap: 0.5rem;
    border: 1px solid var(--Neutrals-White-10, rgba(255, 255, 255, 0.75));
    background: linear-gradient(131deg, #8B5CF6 9.64%, #5386FA 89.29%);
    box-shadow: 0 0 6px 0 rgba(255, 255, 255, 0.90) inset;
  }

  :global(.position-apply-btn .button-text) {
    color: var(--Neutrals-White-00, #FFF);
    font-family: "PingFang SC";
    font-size: 0.875rem;
    font-style: normal;
    font-weight: 500;
    line-height: 120%;
    white-space: nowrap;
  }

  :global(.position-apply-btn svg) {
    width: 0;
    height: 1rem;
    transition: all 0.3s;
    flex-shrink: 0;
  }

  :global(.position-apply-btn:hover svg) {
    width: 1.5rem;
  }

  @media (max-width: 768px) {
    .position-title {
      font-size: 1.5rem;
      line-height: 120%;
    }

    .position-subtitle {
      font-size: 0.875rem;
      line-height: 120%;
    }

    .position-content {
      flex-direction: column;
      gap: 2rem;
    }

    .position-img {
      max-width: 100%;
    }

    .open-positions {
      min-width: 100%;
      max-width: 100%;
    }

    .open-positions-title {
      font-size: 1.25rem;
      padding: 0.5rem 0;
    }

    :global(.position-item) {
      padding: 0.5rem 0;
      gap: 1rem;
    }

    :global(.position-name) {
      font-size: 0.9375rem;
    }

    :global(.position-name-apply-btn) {
      font-size: 0.9375rem;
      height: 4rem !important;
    }

    :global(.position-apply-btn) {
      min-width: 5.75rem;
    }
  }
</style>
