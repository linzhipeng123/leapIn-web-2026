---
import PlatformFeatureCard from './PlatformFeatureCard.astro';
---

<div class="platform-feature-container" id="platform-feature-container">
  <h2 class="feature-card-title" id="feature-card-title" data-i18n="platform.coreFeatures.title"></h2>
    <div class="feature-card-wrapper" data-index="0" data-active="false">
        <PlatformFeatureCard type='Acquisition' />
    </div>
    <div class="feature-card-wrapper" data-index="1" data-active="false">
        <PlatformFeatureCard type='Marketplace' />
    </div>
    <div class="feature-card-wrapper" data-index="2" data-active="false">
        <PlatformFeatureCard type='Development' />
    </div>
</div>

<style>
  .platform-feature-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feature-card-wrapper {
    position: absolute;
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
  }
  
  .feature-card-title {
    color: var(--grey-gray-60-base, #111827);
    text-align: center;
    font-size: 2rem;
    font-style: normal;
    line-height: 120%; /* 38.4px */
    letter-spacing: -0.352px;
    top: -30vh;
    position: relative;
    transition: all 0.8s;
    z-index: 0;
  }

  .platform-feature-container[data-in-viewport="true"] .feature-card-title {
    color: var(--Neutrals-White-00, #FFF);
    text-align: center;
    font-size: 100px;
    font-style: normal;
    font-weight: 400;
    line-height: 124%; /* 124px */
    letter-spacing: -1.1px;
    top: 45vh;
    opacity: 0.1;
    position: relative;
  }

  /* Initial state - Card 0 (Acquisition) */
  .feature-card-wrapper[data-index="0"] {
    top: -15vh;
    transform: rotate(-45deg);
    opacity: 1;
  }

  /* Initial state - Card 1 (Marketplace) */
  .feature-card-wrapper[data-index="1"] {
    transform: rotate(45deg);
    opacity: 0;
  }

  /* Initial state - Card 2 (Development) */
  .feature-card-wrapper[data-index="2"] {
    transform: rotate(-45deg);
    opacity: 0;
  }

  /* Active state - all cards centered and straight */
  .feature-card-wrapper[data-active="true"] {
    top: 25vh !important;
    transform: rotate(0deg) !important;
    opacity: 1 !important;
    pointer-events: auto !important;
  }

  /* When in viewport, ALL inactive cards (including card 0) are hidden */
  .platform-feature-container[data-in-viewport="true"] .feature-card-wrapper[data-active="false"] {
    opacity: 0 !important;
    pointer-events: none;
  }

  /* When NOT in viewport, only non-card-0 inactive cards are hidden (card 0 stays as preview) */
  .platform-feature-container:not([data-in-viewport="true"]) .feature-card-wrapper[data-active="false"]:not([data-index="0"]) {
    opacity: 0 !important;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .platform-feature-container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      position: static;
      height: auto;
    }

    .feature-card-wrapper {
      position: static;
      transform: none !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      top: 0 !important;
    }

    .feature-card-title {
      top: 0 !important;
      color: var(--Neutrals-White-00, #FFF);
      text-align: center;
      /* title-mobile */
      font-size: 1.5rem !important;
      font-style: normal;
      font-weight: 400;
      line-height: 120%; /* 28.8px */
      opacity: 1 !important;
      margin-bottom: 0.5rem;
    }

  .platform-feature-container[data-in-viewport="true"] .feature-card-wrapper[data-active="false"] {
    opacity: 1 !important;
  }

  /* When NOT in viewport, only non-card-0 inactive cards are hidden (card 0 stays as preview) */
  .platform-feature-container:not([data-in-viewport="true"]) .feature-card-wrapper[data-active="false"]:not([data-index="0"]) {
    opacity: 1 !important;
  }
  }
</style>

<script>
  import { loadTranslations } from '../scripts/i18n-loader';
  loadTranslations();

  const container = document.getElementById('platform-feature-container');
  const scrollSection = document.querySelector('.scroll-section.features-dark');
  const title = document.getElementById('feature-card-title');
  // feature-card-title
  const isMobile = window.matchMedia('(max-width: 768px)').matches;

  if (title && container && scrollSection && !isMobile) {
    let currentIndex = -1;
    const cards = container.querySelectorAll('.feature-card-wrapper');
    const totalCards = cards.length;
    let isScrolling = false;
    let isInViewport = false;
    let scrollDirection: 'down' | 'up' = 'down';
    let lastScrollY = window.scrollY;

    const updateCards = (index: number) => {
      currentIndex = index;
      cards.forEach((card, i) => {
        card.setAttribute('data-active', i === index ? 'true' : 'false');
      });
    };

    window.addEventListener('scroll', () => {
      const currentY = window.scrollY;
      if (currentY > lastScrollY) {
        scrollDirection = 'down';
      } else if (currentY < lastScrollY) {
        scrollDirection = 'up';
      }
      lastScrollY = currentY;
    }, { passive: true });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const wasInViewport = isInViewport;
        isInViewport = entry.isIntersecting;

        if (isInViewport && !wasInViewport) {
          title.setAttribute('data-in-viewport', 'true');
          container.setAttribute('data-in-viewport', 'true');

          if (scrollDirection === 'down') {
            updateCards(0);
          } else {
            updateCards(totalCards - 1);
          }
        } else if (!isInViewport && wasInViewport) {
          title.setAttribute('data-in-viewport', 'true');
          container.setAttribute('data-in-viewport', 'false');
          currentIndex = -1;
          cards.forEach(card => {
            card.setAttribute('data-active', 'false');
          });
        }
      });
    }, { root: null, rootMargin: '0px', threshold: 0.3 });

    observer.observe(scrollSection);

    scrollSection.addEventListener('wheel', (e: WheelEvent) => {
      if (!isInViewport || isScrolling) return;

      const scrollingDown = e.deltaY > 0;
      const scrollingUp = e.deltaY < 0;

      const shouldHandleDown = scrollingDown && currentIndex < totalCards - 1;
      const shouldHandleUp = scrollingUp && currentIndex > 0;

      if (shouldHandleDown || shouldHandleUp) {
        e.preventDefault();
        e.stopPropagation();
        isScrolling = true;

        if (shouldHandleDown) {
          updateCards(currentIndex + 1);
        } else if (shouldHandleUp) {
          updateCards(currentIndex - 1);
        }

        setTimeout(() => {
          isScrolling = false;
        }, 800);
      }
    }, { passive: false });
  }
</script>
