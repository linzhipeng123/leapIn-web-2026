---
import Card from './Card.astro';
import Avatar from '../../assets/solutions/section/section2-avatar.png';
import Score from '../../assets/solutions/section/section2-score.png';
import ScoreMobile from '../../assets/solutions/section/section2-score-mobile.png';
import cnAvatar from '../../assets/solutions/section/cn/section2-avatar.png';
import cnScore from '../../assets/solutions/section/cn/section2-score.png';
---

<section class="section-container" id="solutions-section-2">
    <div class="container">
        <Card index={2} itemLength={3} className="card-section2"></Card>
        <div class="section-avatar2">
            <img src={Avatar.src} alt="" data-en-src={Avatar.src} data-cn-src={cnAvatar.src} class="lang-image">
        </div>
        <div class="section-score2">
            <picture>
                <source media="(max-width: 768px)" srcset={ScoreMobile.src} data-en-srcset={ScoreMobile.src} data-cn-srcset={cnScore.src} class="lang-source" />
                <img src={Score.src} alt="" data-en-src={Score.src} data-cn-src={cnScore.src} class="lang-image">
            </picture>
        </div>
    </div>
</section>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  import { inView } from '../../utils/inView';
  loadTranslations();
  // 根据语言切换图片
  const updateImages = () => {
      const currentLang = localStorage.getItem('language') || 'en';
      const images = document.querySelectorAll('.lang-image');
      const sources = document.querySelectorAll('.lang-source');
      
      images.forEach((img) => {
          const enSrc = img.getAttribute('data-en-src');
          const cnSrc = img.getAttribute('data-cn-src');
          
          if (currentLang === 'zh' && cnSrc) {
              img.setAttribute('src', cnSrc);
          } else if (enSrc) {
              img.setAttribute('src', enSrc);
          }
      });

      sources.forEach((source) => {
          const enSrcset = source.getAttribute('data-en-srcset');
          const cnSrcset = source.getAttribute('data-cn-srcset');
          
          if (currentLang === 'zh' && cnSrcset) {
              source.setAttribute('srcset', cnSrcset);
          } else if (enSrcset) {
              source.setAttribute('srcset', enSrcset);
          }
      });
  };

  // 页面加载时更新
  updateImages();

  // // 监听语言切换事件
  // window.addEventListener('languageChanged', updateImages);
  const isMobile = window.matchMedia('(max-width: 768px)').matches;
  // Intersection Observer 监听 features 是否在可视区域内
  if (isMobile && typeof window !== 'undefined') {
    inView({id: "solutions-section-2", threshold: 0.2});
  }
</script>

<style>
    .section-container {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .container {
        display: flex;
        justify-content: space-between;
        position: relative;
    }

    .section-avatar2 {
        position: absolute;
        right: 0;
        padding: 1rem;
        border-radius: 0.75rem;
        border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
        transform: translateY(-5rem);
        transition: all 0.6s ease;
    }

    .section-avatar2 img {
        width: 36.75rem;
        aspect-ratio: 294/47;
    }

    .section-score2 {
        position: absolute;
        padding: 1rem;
        align-items: center;
        aspect-ratio: 334/163;
        border-radius: 0.75rem;
        border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
        position: relative;
        transform: translateX(-12.5rem) translateY(12rem);
        z-index: 1;
        transition: all 0.6s ease;
    }

    .section-score2 img {
        width: 100%;
        /* height: 100%; */
        display: block;
        /* max-width: 43.875rem; */
        max-height: 20.375rem;
    }

    .score-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

	@media (max-width: 768px) {
    .container {
      flex-direction: column;
      margin: 0;
      padding: 0 1rem;
      overflow: hidden;
    }
		.section-avatar2 {
      width: 38.875rem;
			position: relative;
      z-index: 1;
		}

    .section-score2 {
      position: relative;
      width: calc(100% - 1rem);
      z-index: 0;
      aspect-ratio: auto;
    }

    .score-image {
        width: 100%;
        height: auto;
    }

    .in-view .section-avatar2 {
      transform: translateX(8rem) translateY(200%);
		}
    .section-avatar2 {
      transform: translateX(-8rem) translateY(200%) rotate(30deg);
		}
    .in-view .section-score2 {
      transform: translateY(-40%);
		}
    .section-score2 {
      transform: translateY(-40%) rotate(-30deg);
		}

    :global(.card-section2) {
      transform: translateX(1.875rem) translateY(100%) rotate(45deg);
    }
    .in-view :global(.card-section2) {
      transform: translateX(0) translateY(0);
    }
	}
</style>