---
import Card from './Card.astro';
import Avatar from '../../assets/solutions/section/section2-avatar.png';
import Score from '../../assets/solutions/section/section2-score.png';
import ScoreMobile from '../../assets/solutions/section/section2-score-mobile.png';
---

<section class="section-container">
    <div class="container">
        <Card index={2} itemLength={3} className="card-section2"></Card>
        <div class="section-avatar2">
            <img src={Avatar.src} alt="">
        </div>
        <div class="section-score2">
            <picture>
                <source media="(max-width: 768px)" srcset={ScoreMobile.src} />
                <img src={Score.src} alt="" class="score-image">
            </picture>
        </div>
    </div>
</section>

<style>
    .section-container {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .container {
        display: flex;
        justify-content: space-between;
        position: relative;
    }

    .section-avatar2 {
        position: absolute;
        right: 0;
        padding: 1rem;
        border-radius: 0.75rem;
        border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
        transform: translateY(-5rem);
        transition: all 0.6s ease;
    }

    .section-avatar2 img {
        width: 36.75rem;
        aspect-ratio: 294/47;
    }

    .section-score2 {
        position: absolute;
        width: 43.875rem;
        padding: 1rem;
        align-items: center;
        aspect-ratio: 334/163;
        border-radius: 0.75rem;
        border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
        position: relative;
        transform: translateX(-12.5rem) translateY(12rem);
        z-index: 1;
        transition: all 0.6s ease;
    }

    .section-score2 picture {
        width: 100%;
        height: 100%;
        display: block;
    }

    .score-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

	@media (max-width: 768px) {
        .container {
            flex-direction: column;
            margin: 0;
            padding: 0 1rem;
		    overflow: hidden;
        }
		.section-avatar2 {
            width: 38.875rem;
			position: relative;
            transform: translateX(8rem) translateY(200%);
            z-index: 1;
		}

        .section-score2 {
            position: relative;
            width: calc(100% - 1rem);
            transform: translateY(-40%);
            z-index: 0;
            aspect-ratio: auto;
        }

        .score-image {
            width: 100%;
            height: auto;
        }
	}
</style>