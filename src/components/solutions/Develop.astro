---
import circleBg from '../../assets/solutions/section/circle.png';
import developImg from '../../assets/solutions/section/develop.png';
import developMobileImg from '../../assets/solutions/section/develop-mobile.png';
import developImgCn from '../../assets/solutions/section/cn/develop.png';
import developMobileImgCn from '../../assets/solutions/section/cn/develop-mobile.png';
import bgDot from '../../assets/bg_dot_dark.png';
import Card from './Card.astro';

const stats = [
  { value: '8', suffix: 'x' },
  { value: '63', suffix: '%' },
  { value: '40→88', suffix: '%' },
];
---

<section class="develop-section">
  <div class="develop-container">
    <div class="develop-left">
      <div class="develop-visual">
        <picture>
          <source media="(max-width: 768px)" srcset={developMobileImg.src} class="develop-img-mobile" data-en={developMobileImg.src} data-cn={developMobileImgCn.src} />
          <img src={developImg.src} alt="Leadership Pipeline" class="visual-image develop-img" data-en={developImg.src} data-cn={developImgCn.src} />
        </picture>
      </div>
    </div>
    <Card index={3} itemLength={3} className="card-section3" cardName='develop'></Card>
  </div>

  <!-- Stats Section -->
  <div class="stats-container">
    <div class="stats-grid">
      {stats.map((item, index) => (
        <div class="stat-card">
          <div class="stat-value-wrapper">
            <span class="stat-value" data-i18n={`solutions.develop.stats.${index}.value`}>{item.value}</span>
            <span class="stat-suffix">{item.suffix}</span>
          </div>
          <div class="stat-description" data-i18n={`solutions.develop.stats.${index}.description`}></div>
          <div class="stat-industry" data-i18n={`solutions.develop.stats.${index}.industry`}></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style define:vars={{
  circleBg: `url(${circleBg.src})`,
  bgDot: `url(${bgDot.src})`
}}>
  .develop-section {
    width: 100%;
    min-height: 100vh;
    padding-top: 4.75rem;
    padding-bottom: 6rem;
    position: relative;
    overflow: visible;
    display: flex;
    flex-direction: column;
  }

  .develop-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: var(--bgDot);
    background-repeat: repeat;
    background-size: auto;
    opacity: 0.3;
    z-index: 0;
  }

  .develop-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .develop-left {
    position: relative;
    flex: 0 0 auto;
    width: calc(654 / 1134 * 100%);
  }

  .develop-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    max-width: 41.625rem;
  }

  .visual-image {
    width: 100%;
    height: auto;
    border-radius: 12px;
  }

  /* Stats Section */
  .stats-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 4rem;
    width: 100%;
    margin-top: 3rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.30);;
    padding-top: 3.25rem;
  }

  .stat-card {
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(15px);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.3s ease;
  }

  .stat-card:hover {
    border-color: rgba(90, 59, 221, 0.5);
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-4px);
  }

  .stat-value-wrapper {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .stat-value {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .stat-suffix {
    font-size: 1.5rem;
    font-weight: 700;
    background: linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .stat-description {
    font-size: 1rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
  }

  .stat-industry {
    font-size: 0.875rem;
    line-height: 1.2;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 768px) {
    .develop-section {
      padding: 0;
      min-height: auto;
    }

    .develop-container {
      flex-direction: column-reverse;
      gap: 1rem;
      padding: 0 1rem;
    }

    .develop-left {
      width: 100%;
    }

    .stats-container {
      padding: 0 1rem;
      margin-top: 1rem;
      width: 100%;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding-top: 1.25rem;
    }

    .stat-card {
      padding: 1.5rem 1rem;
    }

    .stat-value {
      font-size: 2rem;
    }

    .stat-suffix {
      font-size: 1.25rem;
    }

    .stat-description {
      font-size: 0.875rem;
    }

    .stat-industry {
      font-size: 0.75rem;
    }
  }
</style>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  loadTranslations();

  // 切换图片语言
  function switchImageLanguage() {
    const currentLang = localStorage.getItem('language') || 'en';
    const img = document.querySelector('.develop-img') as HTMLImageElement;
    const source = document.querySelector('.develop-img-mobile') as HTMLSourceElement;
    
    if (img && source) {
      if (currentLang === 'zh') {
        img.src = img.getAttribute('data-cn') || img.src;
        source.srcset = source.getAttribute('data-cn') || source.srcset;
      } else {
        img.src = img.getAttribute('data-en') || img.src;
        source.srcset = source.getAttribute('data-en') || source.srcset;
      }
    }
  }

  // 初始化时切换
  switchImageLanguage();

  // 监听语言切换事件
  window.addEventListener('languageChanged', switchImageLanguage);
</script>
