---
import CardItem from '../CardItem.astro';
interface Props {
	index: number;
    itemLength: number;
    className?: string;
    cardName?: string;
}
const { index, itemLength, className, cardName } = Astro.props;
---

<div class={`card ${className}`}>
    <div class="card-index">0{index} · <span data-i18n={`solutions.${cardName || ('section' + index)}.label`}></span></div>
    <h3 class="card-title" data-i18n={`solutions.${cardName || ('section' + index)}.title`}></h3>
    <div class="card-description" data-i18n={`solutions.${cardName || ('section' + index)}.description`}></div>
    <div class="card-items">
        {
            Array(itemLength).fill(0).map((_, itemIndex) => (
                <CardItem text={`solutions.${cardName || ('section' + index)}.items.${itemIndex}`} />
            ))
        }
    </div>
    <div class="tag-line">
        <span data-i18n={`solutions.${cardName || ('section' + index)}.tagline`}></span>
    </div>
</div>

<script>
	import { loadTranslations } from '../../scripts/i18n-loader';
	loadTranslations();

	// 为英文标题添加斜体样式
	const currentLang = localStorage.getItem('language') || 'en';
	if (currentLang === 'en') {
		const cardTitles = document.querySelectorAll('.card-title');
		cardTitles.forEach(title => {
			title.classList.add('en');
		});
	}
</script>

<style>
    .card {
        display: flex;
        width: 22.5rem;
        padding: 5rem 1.5rem 1.5rem 1.5rem;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        border-radius: 0.75rem;
        border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
        position: relative;
        transition: all 0.6s ease;
    }

    .card::before {
        position: absolute;
        content: '';
        width: 2rem;
        height: 14.75rem;
        border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        opacity: 0.3;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
        top: 0;
        bottom: 0;
        margin: auto;
    }

    .card::after {
        position: absolute;
        content: '';
        height: 14.75rem;
        border: 1px solid var(--Neutrals-White-30, rgba(255, 255, 255, 0.30));
        opacity: 0.2;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(7.5px);
    }

    .card.card-section1::before,
    .card.card-section3::before {
        width: 2rem;
        border-radius: 1.25rem 0 0 1.25rem;
        border-right: none;
        left: -2rem;
    }

    .card.card-section1::after,
    .card.card-section3::after {
        width: 4rem;
        border-radius: 1.25rem 0 0 1.25rem;
        border-right: none;
        left: -4rem;
        bottom: 2.625rem;
    }

    .card.card-section2::before {
        width: 5.625rem;
        border-radius: 0 1.25rem 1.25rem 0;
        border-left: none;
        right: -5.625rem;
    }

    .card.card-section2::after {
        width: 7.625rem;
        border-radius: 0 1.25rem 1.25rem 0;
        border-left: none;
        right: -7.625rem;
    }

    .card-index {
        position: absolute;
        text-align: right;
        right: 1.125rem;
        top: 1rem;
        color: rgba(255, 255, 255, 0.57);
        font-size: 1.25rem;
        font-weight: 700;
        line-height: 100%; /* 20px */
        text-transform: capitalize;
    }

    .card-title {
        width: 100%;
        font-size: 2.25rem;
        line-height: 130%; /* 36px */
        white-space: pre-wrap;
        margin-bottom: 2.5rem;
        background: var(--AI-Gradient-Neon-Horizon-Heavy, linear-gradient(131deg, #5386FA 9.64%, #8B5CF6 89.29%));
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .card-title.en {
        font-style: italic;
    }

    .card-description {
        color: var(--Neutrals-White-00, #FFF);
        font-feature-settings: 'liga' off, 'clig' off;
        font-size: 0.875rem;
        line-height: 128.571%; /* 128.571% */
        margin-bottom: 1rem;
    }

    .card-items {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .tag-line {
        width: 100%;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.60);
        color: var(--Neutrals-White-00, #FFF);
        font-size: 0.875rem;
        font-weight: 600;
        line-height: 128.571%; /* 128.571% */
    }

	@media (max-width: 768px) {
        .card {
            width: 100%;
            margin: 0 auto;
            margin-bottom: 2rem;
        }

        .card.card-section1::before,
        .card.card-section2::before,
        .card.card-section3::before {
            width: calc(100% - 2rem);
            height: 1rem;
            border-radius: 0 0 1.25rem 1.25rem;
            border-top: none;
            left: 0;
            right: 0;
            top: auto;
            bottom: -1rem;
            margin: 0 auto;
        }

        .card.card-section1::after,
        .card.card-section2::after,
        .card.card-section3::after {
            width: calc(100% - 4rem);
            height: 1rem;
            border-radius: 0 0 1.25rem 1.25rem;
            border-top: none;
            left: 0;
            right: 0;
            top: auto;
            bottom: -2rem;
            margin: 0 auto;
        }
    }
</style>