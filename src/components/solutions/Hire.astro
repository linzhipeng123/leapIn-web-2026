---
import circleBg from '../../assets/solutions/section/circle.png';
import hireImg from '../../assets/solutions/section/hire.png';
import hireMobileImg from '../../assets/solutions/section/hire-mobile.png';
import hireImgCn from '../../assets/solutions/section/cn/hire.png';
import hireMobileImgCn from '../../assets/solutions/section/cn/hire-mobile.png';
import bgDot from '../../assets/bg_dot_dark.png';
import Card from './Card.astro';
---

<section class="hire-section">
  <div class="hire-container">
    <div class="hire-left" id="hire-left">
      <div class="hire-left-inner">
        <div class="hire-visual">
          <picture>
            <source media="(max-width: 768px)" srcset={hireMobileImg.src} class="hire-img-mobile" data-en={hireMobileImg.src} data-cn={hireMobileImgCn.src} />
            <img src={hireImg.src} alt="Predictive Hiring" class="visual-image hire-img" data-en={hireImg.src} data-cn={hireImgCn.src} />
          </picture>
        </div>
      </div>
    </div>
    <div class="card-section-wrap" id="card-section1">
      <Card index={1} itemLength={3} className="card-section1" cardName='hire'></Card>
    </div>
  </div>
</section>

<style define:vars={{
  circleBg: `url(${circleBg.src})`,
  bgDot: `url(${bgDot.src})`
}}>
  .hire-section {
    width: 100%;
    height: 100vh;
    padding-top: 4.75rem;
    position: relative;
    align-items: center;
    display: flex;
    overflow: hidden;
  }

  .hire-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: var(--bgDot);
    background-repeat: repeat;
    background-size: auto;
    opacity: 0.3;
    z-index: 0;
  }

  .hire-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .hire-left {
    position: relative;
    flex: 0 0 auto;
    width: calc(654 / 1134 * 100%);
    transform: translateX(0) translateY(0) rotate(0) !important;
    transition: all 0.8s ease;
  }

  .hire-left-inner {
    position: relative;
    transition: all 0.8s ease;
    transform: translateX(-2000px) rotate(-15deg);
    opacity: 0;
  }

  .hire-left.in-view .hire-left-inner {
    transform: translateX(0) rotate(0);
    opacity: 1;
  }

  .card-section-wrap {
    position: relative;
    transform: translateX(0) translateY(0) rotate(0) !important;
    transition: all 0.8s ease;
  }

  :global(.card-section1) {
    transition: all 0.8s ease;
    transform: translateX(2000px) rotate(15deg);
    opacity: 0;
  }

  .card-section-wrap.in-view :global(.card-section1) {
    transform: translateX(0) rotate(0);
    opacity: 1;
  }

  .hire-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    max-width: 41.625rem;
  }

  .visual-image {
    width: 100%;
    height: auto;
    border-radius: 12px;
  }

  @media (max-width: 768px) {
    .hire-section {
      padding: 0;
      height: fit-content;
    }

    .hire-container {
      flex-direction: column-reverse;
      gap: 1rem;
      padding: 0 1rem;
    }

    .hire-left {
      width: 100%;
      transform: translateX(0) translateY(0) rotate(0) !important;
    }

    .hire-left-inner {
      transform: translateX(-2000px) translateY(100%) rotate(-45deg);
      opacity: 0;
    }

    .hire-left.in-view .hire-left-inner {
      transform: translateX(0) translateY(0) rotate(0);
      opacity: 1;
    }

    .card-section-wrap {
      transform: translateX(0) translateY(0) rotate(0) !important;
    }

    :global(.card-section1) {
      transform: translateX(2000px) translateY(100%) rotate(45deg);
      opacity: 0;
    }

    .card-section-wrap.in-view :global(.card-section1) {
      transform: translateX(0) translateY(0) rotate(0);
      opacity: 1;
    }
  }
</style>

<script>
  import { loadTranslations } from '../../scripts/i18n-loader';
  import { inView } from '../../utils/inView';
  loadTranslations();

  // 切换图片语言
  function switchImageLanguage() {
    const currentLang = localStorage.getItem('language') || 'en';
    const img = document.querySelector('.hire-img') as HTMLImageElement;
    const source = document.querySelector('.hire-img-mobile') as HTMLSourceElement;
    
    if (img && source) {
      if (currentLang === 'zh') {
        img.src = img.getAttribute('data-cn') || img.src;
        source.srcset = source.getAttribute('data-cn') || source.srcset;
      } else {
        img.src = img.getAttribute('data-en') || img.src;
        source.srcset = source.getAttribute('data-en') || source.srcset;
      }
    }
  }

  // 初始化时切换
  switchImageLanguage();

  // 监听语言切换事件
  window.addEventListener('languageChanged', switchImageLanguage);

  // Intersection Observer 监听元素是否在可视区域内
  if (typeof window !== 'undefined') {
    inView({id: "hire-left", threshold: 0.2});
    inView({id: "card-section1", threshold: 0.2});
  }
</script>
